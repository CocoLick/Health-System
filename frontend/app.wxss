page {
  --c-primary: #2d6a4f;
  --c-primary-strong: #245542;
  --c-primary-soft: rgba(45, 106, 79, 0.1);
  --c-accent-warm: #c07b4f;
  --c-accent-soft: rgba(192, 123, 79, 0.14);
  --c-bg: #f3f1ed;
  --c-surface: #fffcf8;
  --c-border: rgba(40, 38, 34, 0.1);
  --c-text: #1f1f1c;
  --c-text-2: #59564e;
  --c-text-3: #8f8a80;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 20rpx;
  --space-1: 12rpx;
  --space-2: 20rpx;
  --space-3: 28rpx;
  --shadow-card: 0 6rpx 24rpx rgba(33, 30, 26, 0.06), 0 1rpx 2rpx rgba(0, 0, 0, 0.04);
  --shadow-press: 0 3rpx 12rpx rgba(33, 30, 26, 0.05);
  --ease-natural: cubic-bezier(0.22, 0.68, 0.28, 1);

  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  color: var(--c-text);
  line-height: 1.6;
  background-color: var(--c-bg);
  background-image:
    radial-gradient(rgba(60, 54, 45, 0.03) 0.8rpx, transparent 0.8rpx),
    linear-gradient(160deg, #f0ede8 0%, #f7f4ef 58%, #f1eee9 100%);
  background-size: 8rpx 8rpx, 100% 100%;
}

.container {
  padding: 24rpx;
}

.ui-section {
  margin-bottom: 36rpx;
}

.ui-eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0.12em;
  color: var(--c-text-3);
  margin-bottom: 8rpx;
}

.ui-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 8rpx;
}

.ui-desc {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.55;
}

.ui-card {
  background: var(--c-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.ui-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.3;
}

.ui-chip-ok {
  color: var(--c-primary);
  background: var(--c-primary-soft);
}

.ui-chip-warn {
  color: #9a4d22;
  background: var(--c-accent-soft);
}

.btn-primary {
  background: var(--c-primary);
  color: #ffffff;
  border-radius: 22rpx;
  padding: 24rpx 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 18rpx rgba(45, 106, 79, 0.22);
  transition: transform 0.18s var(--ease-natural), box-shadow 0.18s var(--ease-natural), background 0.18s var(--ease-natural);
}

.btn-primary:active {
  transform: translateY(2rpx);
  background: var(--c-primary-strong);
  box-shadow: 0 3rpx 10rpx rgba(45, 106, 79, 0.2);
}

.btn-secondary {
  background: var(--c-surface);
  color: var(--c-text-2);
  border-radius: 22rpx;
  padding: 24rpx 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: 1rpx solid var(--c-border);
}

.btn-secondary:active {
  background: #f4f0ea;
}

.input {
  border: 1rpx solid var(--c-border);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background: #fffdf9;
  transition: border-color 0.2s var(--ease-natural), box-shadow 0.2s var(--ease-natural), background 0.2s var(--ease-natural);
}

.input:focus {
  border-color: rgba(45, 106, 79, 0.4);
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(45, 106, 79, 0.08);
}

.error-message {
  color: #b42318;
  font-size: 24rpx;
  padding: 10rpx 0;
}

.success-message {
  color: #276749;
  font-size: 24rpx;
  padding: 10rpx 0;
}