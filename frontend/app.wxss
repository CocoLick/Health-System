page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f8f9fa;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.25);
}

.btn-primary:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.2);
}

.btn-secondary {
  background: #f8f9fa;
  color: #1a1a1a;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
  border: 2rpx solid #dee2e6;
}

.btn-secondary:active {
  background: #e9ecef;
}

.input {
  border: 2rpx solid #dee2e6;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  font-size: 32rpx;
  background: #f8f9fa;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #4caf50;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
}

.error-message {
  color: #dc3545;
  font-size: 26rpx;
  padding: 10rpx 0;
}

.success-message {
  color: #28a745;
  font-size: 26rpx;
  padding: 10rpx 0;
}