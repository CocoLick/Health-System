.wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 40rpx;
  padding-top: calc(48rpx + env(safe-area-inset-top));
  background: linear-gradient(165deg, #ebe8e4 0%, #f4f2ef 42%, #efece8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.brand {
  font-size: 36rpx;
  font-weight: 600;
  color: #3d3a36;
  letter-spacing: 2rpx;
  margin-bottom: 56rpx;
}

.loading-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c4a882;
  animation: bounce 0.9s ease-in-out infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.15s;
}

.dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes bounce {
  0%,
  80%,
  100% {
    transform: translateY(0);
    opacity: 0.45;
  }
  40% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}
