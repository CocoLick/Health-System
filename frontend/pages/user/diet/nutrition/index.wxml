<view class="container page-surface-bg">
  <view wx:if="{{!isLoggedIn}}" class="auth-guard">
    <view class="auth-title">请先登录</view>
    <view class="auth-login-btn" bindtap="gotoLogin">去登录</view>
  </view>
  <block wx:else>
  <view class="header card">
    <view class="header-title">营养分析</view>
    <view class="header-subtitle">记录饮食，分析营养</view>
  </view>

  <view class="tabs">
    <view class="tab-item {{activeTab === 'record' ? 'active' : ''}}" bindtap="switchTab" data-tab="record">饮食记录</view>
    <view class="tab-item {{activeTab === 'analysis' ? 'active' : ''}}" bindtap="switchTab" data-tab="analysis">营养分析</view>
    <view class="tab-item {{activeTab === 'history' ? 'active' : ''}}" bindtap="switchTab" data-tab="history">历史记录</view>
  </view>

  <view class="content">
    <view class="tab-content" wx:if="{{activeTab === 'record'}}">
      <view class="today-summary card">
        <view class="summary-header">
          <text class="summary-title">今日摄入总览</text>
          <text class="summary-date">{{today}}</text>
        </view>

        <view class="hero-nutr card">
          <view class="hero-main">
            <text class="hero-label">热量</text>
            <view class="hero-value-row">
              <text class="hero-value">{{todayIntake.calories}}</text>
              <text class="hero-unit">kcal</text>
            </view>
            <text class="hero-target">目标 {{targetIntake.calories}} kcal</text>
            <view class="nutr-progress">
              <view class="progress-bar">
                <view class="progress-fill" style="width: {{todayIntake.calories / targetIntake.calories * 100}}%"></view>
              </view>
            </view>
          </view>
          <text class="hero-trend {{todayIntake.calories > targetIntake.calories ? 'up' : 'down'}}">
            {{todayIntake.calories > targetIntake.calories ? '↑' : '↓'}}
          </text>
        </view>

        <view class="nutrition-grid">
          <view class="nutr-card card">
            <view class="nutr-value">{{todayIntake.protein}}<text class="nutr-unit">g</text></view>
            <view class="nutr-label">蛋白质</view>
            <view class="nutr-trend {{todayIntake.protein > targetIntake.protein ? 'up' : 'down'}}">{{todayIntake.protein > targetIntake.protein ? '↑' : '↓'}}</view>
            <view class="nutr-progress">
              <view class="progress-bar protein">
                <view class="progress-fill" style="width: {{todayIntake.protein / targetIntake.protein * 100}}%"></view>
              </view>
            </view>
          </view>
          <view class="nutr-card card">
            <view class="nutr-value">{{todayIntake.carbohydrate}}<text class="nutr-unit">g</text></view>
            <view class="nutr-label">碳水</view>
            <view class="nutr-trend {{todayIntake.carbohydrate > targetIntake.carbohydrate ? 'up' : 'down'}}">{{todayIntake.carbohydrate > targetIntake.carbohydrate ? '↑' : '↓'}}</view>
            <view class="nutr-progress">
              <view class="progress-bar carbohydrate">
                <view class="progress-fill" style="width: {{todayIntake.carbohydrate / targetIntake.carbohydrate * 100}}%"></view>
              </view>
            </view>
          </view>
          <view class="nutr-card card">
            <view class="nutr-value">{{todayIntake.fat}}<text class="nutr-unit">g</text></view>
            <view class="nutr-label">脂肪</view>
            <view class="nutr-trend {{todayIntake.fat > targetIntake.fat ? 'up' : 'down'}}">{{todayIntake.fat > targetIntake.fat ? '↑' : '↓'}}</view>
            <view class="nutr-progress">
              <view class="progress-bar fat">
                <view class="progress-fill" style="width: {{todayIntake.fat / targetIntake.fat * 100}}%"></view>
              </view>
            </view>
          </view>
          <view class="nutr-card card nutr-card-bmr">
            <view class="nutr-value">{{bmr || '--'}}<text class="nutr-unit">kcal</text></view>
            <view class="nutr-label">基础代谢</view>
            <view class="nutr-trend neutral">参考值</view>
          </view>
        </view>
      </view>

      <view class="add-record-btn card" catchtap="addRecord">
        <text class="add-icon">+</text>
        <text class="add-text">添加饮食记录</text>
      </view>

      <view class="records-section">
        <view class="section-title">今日饮食</view>
        <view class="record-list" wx:if="{{records.length > 0}}">
          <view class="record-item" wx:for="{{records}}" wx:key="record_id" bindtap="viewRecordDetail" data-index="{{index}}">
            <view class="record-icon">{{item.meal_type === 'breakfast' ? '🌅' : item.meal_type === 'lunch' ? '☀️' : item.meal_type === 'dinner' ? '🌙' : '🍎'}}</view>
            <view class="record-info">
              <view class="record-type">{{item.meal_type === 'breakfast' ? '早餐' : item.meal_type === 'lunch' ? '午餐' : item.meal_type === 'dinner' ? '晚餐' : '加餐'}}</view>
              <view class="record-time">{{item.formattedTime}}</view>
            </view>
            <view class="record-foods">{{item.items.length}}种食物</view>
            <view class="record-calories">{{item.total_calories}}kcal</view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <text class="empty-icon">🍽️</text>
          <text class="empty-text">暂无饮食记录</text>
          <text class="empty-tip">点击上方按钮添加今日饮食</text>
        </view>
      </view>
    </view>

    <view class="tab-content" wx:if="{{activeTab === 'analysis'}}">
      <view class="analysis-card card">
        <view class="card-title">营养摄入对比</view>
        <view class="comparison-list">
          <view class="comparison-item">
            <view class="comp-label">热量</view>
            <view class="comp-bar">
              <view class="comp-fill" style="width: {{todayIntake.calories / targetIntake.calories * 100}}%"></view>
            </view>
            <view class="comp-value">{{todayIntake.calories}} / {{targetIntake.calories}}</view>
          </view>
          <view class="comparison-item">
            <view class="comp-label">蛋白质</view>
            <view class="comp-bar">
              <view class="comp-fill protein" style="width: {{todayIntake.protein / targetIntake.protein * 100}}%"></view>
            </view>
            <view class="comp-value">{{todayIntake.protein}} / {{targetIntake.protein}}g</view>
          </view>
          <view class="comparison-item">
            <view class="comp-label">碳水</view>
            <view class="comp-bar">
              <view class="comp-fill carbohydrate" style="width: {{todayIntake.carbohydrate / targetIntake.carbohydrate * 100}}%"></view>
            </view>
            <view class="comp-value">{{todayIntake.carbohydrate}} / {{targetIntake.carbohydrate}}g</view>
          </view>
          <view class="comparison-item">
            <view class="comp-label">脂肪</view>
            <view class="comp-bar">
              <view class="comp-fill fat" style="width: {{todayIntake.fat / targetIntake.fat * 100}}%"></view>
            </view>
            <view class="comp-value">{{todayIntake.fat}} / {{targetIntake.fat}}g</view>
          </view>
        </view>
      </view>

      <view class="suggestions-section card">
        <view class="section-title">饮食建议</view>
        <view class="suggestion-list">
          <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="title">
            <view class="suggestion-icon">{{item.icon}}</view>
            <view class="suggestion-content">
              <view class="suggestion-title">{{item.title}}</view>
              <view class="suggestion-desc">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="tab-content" wx:if="{{activeTab === 'history'}}">
      <view class="history-header card">
        <view class="date-selector-section">
          <view class="section-label">选择日期查看记录</view>
          <picker mode="date" value="{{selectedDate}}" bindchange="changeDate">
            <view class="date-picker">
              <text class="date-icon">📅</text>
              <text class="date-value">{{selectedDateText}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="selected-date-records card">
        <view class="section-title">当日饮食记录</view>
        <view class="records-for-date" wx:if="{{selectedDateRecords.length > 0}}">
          <view class="date-summary">
            <text class="summary-label">当日总摄入</text>
            <text class="summary-value">{{selectedDateTotal.calories}}kcal</text>
          </view>
          <view class="nutrition-summary">
            <view class="nutrition-item">
              <text class="nutrition-label">蛋白质</text>
              <text class="nutrition-value">{{selectedDateTotal.protein || 0}}g</text>
            </view>
            <view class="nutrition-item">
              <text class="nutrition-label">碳水</text>
              <text class="nutrition-value">{{selectedDateTotal.carbohydrate || 0}}g</text>
            </view>
            <view class="nutrition-item">
              <text class="nutrition-label">脂肪</text>
              <text class="nutrition-value">{{selectedDateTotal.fat || 0}}g</text>
            </view>
          </view>
          <view class="meal-list">
            <view class="meal-item" wx:for="{{selectedDateRecords}}" wx:key="meal_type" bindtap="showFoodDetails" data-index="{{index}}">
              <view class="meal-icon">{{item.meal_type === 'breakfast' ? '🌅' : item.meal_type === 'lunch' ? '☀️' : item.meal_type === 'dinner' ? '🌙' : '🍎'}}</view>
              <view class="meal-info">
                <view class="meal-name">{{item.meal_type === 'breakfast' ? '早餐' : item.meal_type === 'lunch' ? '午餐' : item.meal_type === 'dinner' ? '晚餐' : '加餐'}}</view>
                <view class="meal-foods">{{item.foods.length}}种食物</view>
              </view>
              <view class="meal-calories">{{item.calories}}kcal</view>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <text class="empty-icon">🍽️</text>
          <text class="empty-text">当日暂无饮食记录</text>
        </view>
      </view>

      <!-- 食物详情弹窗 -->
      <view class="food-details-modal" wx:if="{{showFoodDetailsModal}}">
        <view class="record-detail-content card">
          <view class="record-detail-header">
            <view>
              <text class="record-detail-title">{{selectedMealName}}</text>
              <text class="record-detail-time">{{selectedDateText}}</text>
            </view>
            <text class="record-detail-close" bindtap="closeFoodDetails">×</text>
          </view>

          <view class="record-detail-hero">
            <text class="record-detail-hero-label">本餐热量</text>
            <text class="record-detail-hero-value">
              {{selectedMealCalories}}<text class="record-detail-unit">kcal</text>
            </text>
          </view>

          <view class="record-detail-macros">
            <view class="record-detail-macro-item">
              <text class="record-detail-macro-label">蛋白质</text>
              <text class="record-detail-macro-value">{{selectedMealNutrition.protein || 0}}<text class="record-detail-unit">g</text></text>
            </view>
            <view class="record-detail-macro-item">
              <text class="record-detail-macro-label">碳水</text>
              <text class="record-detail-macro-value">{{selectedMealNutrition.carbohydrate || 0}}<text class="record-detail-unit">g</text></text>
            </view>
            <view class="record-detail-macro-item">
              <text class="record-detail-macro-label">脂肪</text>
              <text class="record-detail-macro-value">{{selectedMealNutrition.fat || 0}}<text class="record-detail-unit">g</text></text>
            </view>
          </view>

          <view class="record-detail-foods">
            <text class="record-detail-foods-title">食物明细</text>
            <view class="record-detail-food-item" wx:for="{{selectedMealFoods}}" wx:key="index">
              <text class="record-detail-food-name">{{item.food_name}}</text>
              <view class="record-detail-food-meta">
                <text class="record-detail-food-amount">{{item.amount}}{{item.unit}}</text>
                <text class="record-detail-food-calories">{{item.calories}}kcal</text>
            </view>
            </view>
          </view>
        </view>
      </view>

      <view class="nutrition-trend card">
        <view class="trend-header">
          <view class="section-title">营养摄入趋势</view>
          <view class="trend-time-selector">
            <view class="filter-item {{trendTimeRange === '7' ? 'active' : ''}}" bindtap="setTrendTimeRange" data-range="7">近7天</view>
            <view class="filter-item {{trendTimeRange === '30' ? 'active' : ''}}" bindtap="setTrendTimeRange" data-range="30">近30天</view>
          </view>
        </view>
        <view class="trend-chart">
          <view class="chart-placeholder" wx:if="{{trendData.length === 0}}">
            <text class="chart-icon">📊</text>
            <text class="chart-text">暂无趋势数据</text>
          </view>
          <view class="chart-content" wx:else>
            <view class="chart-bars">
              <view class="chart-bar-item" wx:for="{{trendData}}" wx:key="date">
                <view class="bar" style="height: {{item.height}}%"></view>
                <view class="bar-label">{{item.day}}</view>
              </view>
            </view>
            <view class="chart-summary">
              <text class="summary-item">平均摄入：{{trendAvgCalories}}kcal</text>
              <text class="summary-item">最高摄入：{{trendMaxCalories}}kcal</text>
            </view>
          </view>
        </view>
      </view>

      <view class="export-btn card" bindtap="exportData">
        <text class="export-icon">📤</text>
        <text class="export-text">导出数据</text>
      </view>
    </view>
  </view>

  <!-- 今日饮食记录详情弹窗 -->
  <view class="record-detail-modal" wx:if="{{showRecordDetailModal}}">
    <view class="record-detail-mask" bindtap="closeRecordDetail"></view>
    <view class="record-detail-content card" wx:if="{{selectedRecordDetail}}">
      <view class="record-detail-header">
        <view>
          <text class="record-detail-title">{{selectedRecordDetail.mealTypeText}}</text>
          <text class="record-detail-time">{{selectedRecordDetail.timeText}}</text>
        </view>
        <text class="record-detail-close" bindtap="closeRecordDetail">×</text>
      </view>

      <view class="record-detail-hero">
        <text class="record-detail-hero-label">本餐热量</text>
        <text class="record-detail-hero-value">
          {{selectedRecordDetail.calories}}<text class="record-detail-unit">kcal</text>
        </text>
      </view>

      <view class="record-detail-macros">
        <view class="record-detail-macro-item">
          <text class="record-detail-macro-label">蛋白质</text>
          <text class="record-detail-macro-value">{{selectedRecordDetail.protein}}<text class="record-detail-unit">g</text></text>
        </view>
        <view class="record-detail-macro-item">
          <text class="record-detail-macro-label">碳水</text>
          <text class="record-detail-macro-value">{{selectedRecordDetail.carbohydrate}}<text class="record-detail-unit">g</text></text>
        </view>
        <view class="record-detail-macro-item">
          <text class="record-detail-macro-label">脂肪</text>
          <text class="record-detail-macro-value">{{selectedRecordDetail.fat}}<text class="record-detail-unit">g</text></text>
        </view>
      </view>

      <view class="record-detail-foods">
        <text class="record-detail-foods-title">食物明细</text>
        <view class="record-detail-food-item" wx:for="{{selectedRecordDetail.foods}}" wx:key="index">
          <text class="record-detail-food-name">{{item.name}}</text>
          <view class="record-detail-food-meta">
            <text class="record-detail-food-amount">{{item.amount}}{{item.unit}}</text>
            <text class="record-detail-food-calories">{{item.calories}}kcal</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  </block>
</view>