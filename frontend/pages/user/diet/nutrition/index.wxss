.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.tabs {
  display: flex;
  padding: 0 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4caf50;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #4caf50;
  border-radius: 2rpx;
}

.content {
  padding: 24rpx;
}

.today-summary {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.summary-date {
  font-size: 24rpx;
  color: #999;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.nutr-card {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.nutr-value {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.nutr-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.nutr-progress {
  margin-top: 8rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ff9800;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-fill.protein {
  background: #4caf50;
}

.progress-fill.carbohydrate {
  background: #2196f3;
}

.progress-fill.fat {
  background: #9c27b0;
}

.add-record-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.add-text {
  font-size: 30rpx;
  font-weight: 500;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.record-info {
  flex: 1;
}

.record-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-foods {
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.record-calories {
  font-size: 26rpx;
  font-weight: 500;
  color: #4caf50;
}

.empty-state {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}

.analysis-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comparison-item {
  display: flex;
  align-items: center;
}

.comp-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
}

.comp-bar {
  flex: 1;
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.comp-fill {
  height: 100%;
  background: #ff9800;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.comp-fill.protein {
  background: #4caf50;
}

.comp-fill.carbohydrate {
  background: #2196f3;
}

.comp-fill.fat {
  background: #9c27b0;
}

.comp-value {
  width: 180rpx;
  font-size: 22rpx;
  color: #999;
  text-align: right;
}

.suggestions-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.suggestion-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.suggestion-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}