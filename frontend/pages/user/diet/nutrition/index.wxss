.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.tabs {
  display: flex;
  padding: 0 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4caf50;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #4caf50;
  border-radius: 2rpx;
}

.content {
  padding: 24rpx;
}

.today-summary {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.auth-guard {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.auth-title {
  font-size: 32rpx;
  color: #666;
}

.auth-login-btn {
  padding: 18rpx 56rpx;
  border-radius: 999rpx;
  background: #4caf50;
  color: #fff;
  font-size: 28rpx;
}

.summary-date {
  font-size: 24rpx;
  color: #999;
}

/* 活动水平选择器 */
.activity-level-selector {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  padding: 0 20rpx;
}

.activity-label {
  font-size: 32rpx;
  color: #666;
  margin-right: 20rpx;
}

.picker-view {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 32rpx;
  color: #333;
  min-width: 120rpx;
  text-align: center;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.nutr-card {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.nutr-value {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.nutr-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.nutr-progress {
  margin-top: 8rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ff9800;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-fill.protein {
  background: #4caf50;
}

.progress-fill.carbohydrate {
  background: #2196f3;
}

.progress-fill.fat {
  background: #9c27b0;
}

.add-record-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.add-text {
  font-size: 30rpx;
  font-weight: 500;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.record-info {
  flex: 1;
}

.record-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-foods {
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.record-calories {
  font-size: 26rpx;
  font-weight: 500;
  color: #4caf50;
}

.empty-state {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}

.analysis-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comparison-item {
  display: flex;
  align-items: center;
}

.comp-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
}

.comp-bar {
  flex: 1;
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.comp-fill {
  height: 100%;
  background: #ff9800;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.comp-fill.protein {
  background: #4caf50;
}

.comp-fill.carbohydrate {
  background: #2196f3;
}

.comp-fill.fat {
  background: #9c27b0;
}

.comp-value {
  width: 180rpx;
  font-size: 22rpx;
  color: #999;
  text-align: right;
}

.suggestions-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.suggestion-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.suggestion-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 历史记录标签页样式 */
.history-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.date-selector-section {
  display: flex;
  flex-direction: column;
}

.section-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.date-picker {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.date-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.date-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.selected-date-records {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.records-for-date {
  margin-top: 16rpx;
}

.date-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.summary-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.summary-value {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.meal-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.meal-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.meal-info {
  flex: 1;
}

.meal-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.meal-foods {
  font-size: 22rpx;
  color: #999;
}

.meal-calories {
  font-size: 26rpx;
  color: #4caf50;
  font-weight: 500;
  margin-right: 16rpx;
}

.meal-arrow {
  font-size: 24rpx;
  color: #999;
}

.meal-item {
  cursor: pointer;
  transition: all 0.3s ease;
}

.meal-item:active {
  background: #f0f0f0;
}

.nutrition-summary {
  display: flex;
  justify-content: space-around;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin: 16rpx 0;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nutrition-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.nutrition-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* 食物详情弹窗样式 */
.food-details-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  width: 80%;
  max-width: 500rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
}

.modal-body {
  padding: 24rpx;
}

.modal-nutrition {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.modal-nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-nutrition-label {
  font-size: 20rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.modal-nutrition-value {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.food-list {
  margin-top: 16rpx;
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.food-item:last-child {
  border-bottom: none;
}

.food-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.food-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.food-amount {
  font-size: 24rpx;
  color: #666;
}

.food-calories {
  font-size: 24rpx;
  font-weight: 500;
  color: #ff6b6b;
}

.nutrition-trend {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.trend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.trend-time-selector {
  display: flex;
  gap: 12rpx;
}

.filter-item {
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border: 2rpx solid #ddd;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: #4caf50;
  color: #fff;
  border-color: #4caf50;
}

.trend-chart {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  min-height: 200rpx;
}

.chart-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.chart-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.chart-text {
  font-size: 26rpx;
  color: #999;
}

.chart-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 160rpx;
  padding: 0 10rpx;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar {
  width: 32rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx 4rpx 0 0;
  transition: height 0.3s ease;
  min-height: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.chart-summary {
  display: flex;
  justify-content: space-around;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.summary-item {
  font-size: 24rpx;
  color: #666;
}

.export-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  color: #4caf50;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #4caf50;
  transition: all 0.3s ease;
  margin-bottom: 24rpx;
}

.export-btn:active {
  background: #4caf50;
  color: #fff;
}

.export-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.export-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* --------------------------------
   Nutrition tab redesign (80/20)
--------------------------------- */
.container {
  --nutr-green: #07c160;
  --nutr-green-soft: rgba(7, 193, 96, 0.12);
  --nutr-gray-1: #1a1a1a;
  --nutr-gray-2: #3a3a3a;
  --nutr-gray-3: #8e8e93;
  --nutr-surface: #ffffff;
  --nutr-surface-soft: #f9fafb;
  --radius-lg: 20rpx;
  --shadow-sm: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
  min-height: 100vh;
  background: transparent;
}

.card {
  transition: transform 0.2s ease-in-out, background-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}

.card:active {
  transform: scale(0.98);
  background-color: #f5f5f5;
}

.header {
  margin: 20rpx 24rpx 14rpx;
  border-radius: var(--radius-lg);
  background: var(--nutr-surface);
  color: var(--nutr-gray-1);
  padding: 30rpx 28rpx 22rpx;
  box-shadow: var(--shadow-sm);
}

.header-title {
  color: var(--nutr-gray-1);
  font-size: 38rpx;
  font-weight: 700;
}

.header-subtitle {
  color: var(--nutr-gray-3);
  font-size: 24rpx;
}

.tabs {
  margin: 0 24rpx 12rpx;
  padding: 0;
  border-bottom: none;
  background: transparent;
}

.tab-item {
  color: var(--nutr-gray-3);
  font-weight: 500;
  height: 84rpx;
  line-height: 84rpx;
}

.tab-item.active {
  color: var(--nutr-gray-1);
  font-weight: 700;
}

.tab-item.active::after {
  width: 52rpx;
  height: 6rpx;
  background: var(--nutr-green);
  border-radius: 8rpx;
}

.content {
  padding: 0 24rpx 24rpx;
}

.today-summary,
.analysis-card,
.suggestions-section,
.history-header,
.selected-date-records,
.nutrition-trend,
.record-list,
.empty-state {
  background: var(--nutr-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: none;
}

.today-summary {
  padding: 26rpx;
  margin-bottom: 16rpx;
}

.summary-title,
.section-title,
.card-title,
.modal-title {
  color: var(--nutr-gray-1);
  font-weight: 700;
}

.summary-date,
.record-time,
.section-label,
.picker-arrow,
.meal-foods,
.chart-text,
.bar-label,
.comp-value,
.summary-item,
.food-amount,
.nutrition-label {
  color: var(--nutr-gray-3);
}

.hero-nutr {
  background: var(--nutr-surface-soft);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.hero-label {
  display: block;
  font-size: 24rpx;
  color: var(--nutr-gray-3);
  margin-bottom: 6rpx;
}

.hero-value-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.hero-value {
  font-size: 70rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--nutr-green);
}

.hero-unit {
  font-size: 22rpx;
  color: var(--nutr-gray-3);
  margin-bottom: 8rpx;
}

.hero-target {
  display: block;
  font-size: 23rpx;
  color: var(--nutr-gray-2);
  margin: 10rpx 0 12rpx;
}

.hero-trend {
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.hero-trend.up {
  color: #ea580c;
}

.hero-trend.down {
  color: var(--nutr-green);
}

.nutrition-grid {
  gap: 12rpx;
}

.nutr-card {
  border-radius: 16rpx;
  background: var(--nutr-surface-soft);
  padding: 18rpx 16rpx;
  text-align: left;
}

.nutr-value {
  color: var(--nutr-gray-1);
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.nutr-unit {
  color: var(--nutr-gray-3);
  font-size: 20rpx;
  margin-left: 4rpx;
}

.nutr-label {
  color: var(--nutr-gray-2);
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.nutr-trend {
  font-size: 20rpx;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.nutr-trend.up {
  color: #ea580c;
}

.nutr-trend.down {
  color: var(--nutr-green);
}

.nutr-trend.neutral {
  color: var(--nutr-gray-3);
}

.progress-bar,
.comp-bar {
  background: #e6e8eb;
}

.progress-fill,
.progress-fill.protein,
.progress-fill.carbohydrate,
.progress-fill.fat,
.comp-fill,
.comp-fill.protein,
.comp-fill.carbohydrate,
.comp-fill.fat {
  background: var(--nutr-green);
}

.add-record-btn {
  margin-bottom: 16rpx;
  border-radius: var(--radius-lg);
  background: var(--nutr-green);
  color: #fff;
  border: none;
  box-shadow: var(--shadow-sm);
}

.add-text {
  font-weight: 600;
}

.record-item {
  border-bottom: none;
  border-radius: 14rpx;
  margin: 8rpx;
  background: var(--nutr-surface-soft);
  padding: 18rpx;
}

.record-type,
.meal-name,
.food-name {
  color: var(--nutr-gray-1);
}

.record-foods,
.meal-foods {
  color: var(--nutr-gray-3);
}

.record-calories,
.meal-calories,
.nutrition-value,
.modal-nutrition-value {
  color: var(--nutr-gray-1);
  font-weight: 700;
}

.comparison-item {
  align-items: center;
  gap: 10rpx;
}

.comp-label {
  color: var(--nutr-gray-2);
}

.suggestion-item {
  border-radius: 14rpx;
  background: var(--nutr-surface-soft);
}

.suggestion-title {
  color: var(--nutr-gray-1);
}

.suggestion-desc {
  color: var(--nutr-gray-2);
}

.date-picker,
.meal-item,
.nutrition-summary,
.trend-chart,
.modal-nutrition {
  background: var(--nutr-surface-soft);
  border: none;
}

.date-summary {
  background: var(--nutr-surface-soft);
  border-radius: 14rpx;
}

.summary-label {
  color: var(--nutr-gray-3);
}

.summary-value {
  color: var(--nutr-gray-1);
}

.meal-arrow {
  color: var(--nutr-gray-3);
}

.food-details-modal {
  background: rgba(0, 0, 0, 0.42);
}

.modal-content {
  border-radius: 20rpx;
}

.modal-header,
.food-item,
.chart-summary {
  border: none;
}

.nutrition-trend {
  margin-bottom: 16rpx;
}

.filter-item {
  border: none;
  background: var(--nutr-surface-soft);
  color: var(--nutr-gray-3);
}

.filter-item.active {
  background: var(--nutr-green-soft);
  color: #06693a;
}

.bar {
  background: var(--nutr-green);
}

.export-btn {
  border: none;
  background: var(--nutr-surface);
  color: var(--nutr-gray-2);
  box-shadow: var(--shadow-sm);
  border-radius: var(--radius-lg);
}

.export-btn:active {
  background: #f2f4f7;
  color: var(--nutr-gray-1);
}

/* 今日饮食详情弹窗 */
.record-detail-modal {
  position: fixed;
  inset: 0;
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-detail-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
}

.food-details-modal .record-detail-content {
  animation: detailIn 0.2s ease-out;
}

@keyframes detailIn {
  from {
    transform: translateY(12rpx) scale(0.98);
    opacity: 0;
  }
  to {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

.record-detail-content {
  position: relative;
  width: 86%;
  max-width: 640rpx;
  max-height: 82vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.16);
}

.record-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.record-detail-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--nutr-gray-1);
  margin-bottom: 4rpx;
}

.record-detail-time {
  display: block;
  font-size: 22rpx;
  color: var(--nutr-gray-3);
}

.record-detail-close {
  font-size: 44rpx;
  color: var(--nutr-gray-3);
  line-height: 1;
  padding: 0 6rpx;
}

.record-detail-hero {
  background: var(--nutr-surface-soft);
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 12rpx;
}

.record-detail-hero-label {
  display: block;
  font-size: 22rpx;
  color: var(--nutr-gray-3);
  margin-bottom: 6rpx;
}

.record-detail-hero-value {
  display: block;
  font-size: 58rpx;
  font-weight: 800;
  color: var(--nutr-green);
  line-height: 1;
}

.record-detail-unit {
  font-size: 20rpx;
  color: var(--nutr-gray-3);
  margin-left: 4rpx;
}

.record-detail-macros {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.record-detail-macro-item {
  background: var(--nutr-surface-soft);
  border-radius: 12rpx;
  padding: 10rpx 12rpx;
}

.record-detail-macro-label {
  display: block;
  font-size: 20rpx;
  color: var(--nutr-gray-3);
  margin-bottom: 4rpx;
}

.record-detail-macro-value {
  display: block;
  font-size: 28rpx;
  color: var(--nutr-gray-1);
  font-weight: 700;
}

.record-detail-foods {
  background: var(--nutr-surface-soft);
  border-radius: 14rpx;
  padding: 12rpx;
}

.record-detail-foods-title {
  display: block;
  font-size: 24rpx;
  color: var(--nutr-gray-2);
  font-weight: 600;
  margin-bottom: 10rpx;
}

.record-detail-food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 8rpx;
  border-radius: 10rpx;
  background: #fff;
  margin-bottom: 8rpx;
}

.record-detail-food-item:last-child {
  margin-bottom: 0;
}

.record-detail-food-name {
  flex: 1;
  color: var(--nutr-gray-1);
  font-size: 24rpx;
}

.record-detail-food-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.record-detail-food-amount {
  color: var(--nutr-gray-3);
  font-size: 21rpx;
}

.record-detail-food-calories {
  color: var(--nutr-gray-2);
  font-size: 22rpx;
  font-weight: 600;
}