<view class="container">
  <!-- 有膳食计划时，显示详情页面内容 -->
  <view wx:if="{{planStatus === 4}}" class="plan-detail-view">
    <view class="dashboard-card detail-card">
      <view class="dashboard-main">
        <view class="plan-source">
          <text wx:if="{{currentPlan.source === 'ai'}}">系统智能推荐</text>
          <text wx:else>规划师定制</text>
        </view>
        <view class="plan-title">{{currentPlan.title}}</view>
        <view class="plan-generation-source" wx:if="{{currentPlan.source === 'ai' && currentPlan.generationSourceText}}">
          {{currentPlan.generationSourceText}}
        </view>
        <view class="plan-meta-line">
          <text>目标：{{currentPlan.goalText || currentPlan.goal || '未设置'}}</text>
          <text class="meta-dot">·</text>
          <text>周期：7天</text>
          <text class="meta-dot">·</text>
          <text wx:if="{{currentPlan.source !== 'ai'}}">规划师：{{currentPlan.dietitianName}}</text>
          <text wx:else>来源：智能生成</text>
        </view>
      </view>
    </view>

    <view class="metrics-wrap">
      <view class="metrics-grid">
        <view class="metric-card detail-card">
          <view class="metric-main">
            <text class="metric-value">{{currentPlan.calories}}</text>
            <text class="metric-unit">kcal</text>
          </view>
          <text class="metric-label">总热量</text>
        </view>
        <view class="metric-card detail-card">
          <view class="metric-main">
            <text class="metric-value">{{currentPlan.protein}}</text>
            <text class="metric-unit">g</text>
          </view>
          <text class="metric-label">蛋白质</text>
        </view>
        <view class="metric-card detail-card">
          <view class="metric-main">
            <text class="metric-value">{{currentPlan.carbohydrate}}</text>
            <text class="metric-unit">g</text>
          </view>
          <text class="metric-label">碳水</text>
        </view>
        <view class="metric-card detail-card">
          <view class="metric-main">
            <text class="metric-value">{{currentPlan.fat}}</text>
            <text class="metric-unit">g</text>
          </view>
          <text class="metric-label">脂肪</text>
        </view>
      </view>
    </view>

    <view class="date-selector detail-picker">
      <text class="selector-label">查看日期</text>
      <picker mode="date" value="{{selectedDate}}" bindchange="changeDate">
        <view class="picker-view">
          <text class="date-value">{{selectedDateText}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </picker>
    </view>

    <view class="section-title">每日膳食安排</view>
    <view class="timeline-list">
      <view wx:if="{{currentPlan.hasPlanForDate !== false && currentPlan.meals.length > 0}}">
        <view class="timeline-item {{item.executed ? 'executed' : ''}}" wx:for="{{currentPlan.meals}}" wx:key="type" bindtap="executeMeal" data-meal-index="{{index}}">
          <view class="timeline-left">
            <text class="meal-time">{{item.time}}</text>
            <view class="timeline-line"></view>
          </view>
          <view class="timeline-right">
            <view class="meal-head">
              <text class="meal-type">{{item.type}}</text>
              <text class="meal-calories">{{item.calories}}kcal</text>
            </view>
            <view class="meal-foods">
              <text wx:for="{{item.foods}}" wx:for-item="food" wx:key="name">{{food.name}} {{food.amount}}；</text>
            </view>
          </view>
          <view class="meal-check {{item.executed ? 'checked' : ''}}">
            <text wx:if="{{item.executed}}">✓</text>
          </view>
        </view>
      </view>
      <view wx:else class="no-plan">
        <view class="no-plan-icon">📅</view>
        <view class="no-plan-text">当日无饮食计划</view>
      </view>
    </view>

    <view class="section-title">营养分析</view>
    <view class="analysis-card detail-card">
      <view class="bar-group">
        <text class="bar-title">蛋白质</text>
        <view class="bar-track">
          <view class="bar-fill bar-protein" style="width: {{proteinPercentage}}%"></view>
        </view>
        <text class="bar-percent">{{proteinPercentage}}%</text>
      </view>
      <view class="bar-group">
        <text class="bar-title">碳水</text>
        <view class="bar-track">
          <view class="bar-fill bar-carbohydrate" style="width: {{carbohydratePercentage}}%"></view>
        </view>
        <text class="bar-percent">{{carbohydratePercentage}}%</text>
      </view>
      <view class="bar-group">
        <text class="bar-title">脂肪</text>
        <view class="bar-track">
          <view class="bar-fill bar-fat" style="width: {{fatPercentage}}%"></view>
        </view>
        <text class="bar-percent">{{fatPercentage}}%</text>
      </view>
    </view>

    <view class="action-grid detail-card">
      <view class="action-item" bindtap="applyOptimization">
        <view class="action-icon icon-opt"></view>
        <text class="action-text">申请优化</text>
      </view>
      <view class="action-item" bindtap="viewDetailedComparison">
        <view class="action-icon icon-compare"></view>
        <text class="action-text">查看对比</text>
      </view>
      <view class="action-item" bindtap="goToNutritionEvaluation">
        <view class="action-icon icon-eval"></view>
        <text class="action-text">营养评估</text>
      </view>
      <view class="action-item" bindtap="goFeedbackPlan">
        <view class="action-icon icon-feedback"></view>
        <text class="action-text">反馈计划</text>
      </view>
      <view class="action-item action-danger" bindtap="terminateService">
        <view class="action-icon icon-stop"></view>
        <text class="action-text">解除服务</text>
      </view>
    </view>

    <view class="sticky-action">
      <button class="primary-btn" bindtap="recordDiet">记录饮食</button>
    </view>
  </view>

  <!-- 无膳食计划时，显示初始页面内容 -->
  <view wx:else>
    <view class="header">
      <view class="header-title">膳食管理</view>
      <view class="header-subtitle">规划您的健康饮食</view>
    </view>

    <!-- 我的申请模块 -->
    <view class="application-module" wx:if="{{latestRequest}}">
      <view class="application-card">
        <view class="application-header">
          <view class="application-title">我的申请</view>
          <view class="application-status {{latestRequest.status}}">{{latestRequest.statusText}}</view>
        </view>
        <view class="application-info">
          <view class="info-row">
            <text class="label">规划师：</text>
            <text class="value">{{latestRequest.dietitian_name || latestRequest.dietitian_id}}</text>
          </view>
          <view class="info-row">
            <text class="label">服务类型：</text>
            <text class="value">{{latestRequest.serviceTypeText}}</text>
          </view>
          <view class="info-row">
            <text class="label">饮食目标：</text>
            <text class="value">{{latestRequest.dietGoalText}}</text>
          </view>
          <view class="info-row">
            <text class="label">提交时间：</text>
            <text class="value">{{latestRequest.createTimeText}}</text>
          </view>
        </view>
        <view class="application-actions">
          <view class="action-btn" bindtap="viewRequestDetail">查看详情</view>
          <view class="action-btn reapply" bindtap="reapplyRequest" wx:if="{{latestRequest.status === 'rejected' || latestRequest.status === 'cancelled'}}">重新申请</view>
        </view>
      </view>
    </view>

    <view class="content">
      <view class="status-0" wx:if="{{planStatus === 0}}">
        <view class="entry-cards">
          <view class="entry-card ai-card" bindtap="requestAiRecommendation">
            <view class="entry-icon">🤖</view>
            <view class="entry-title">系统智能推荐</view>
            <view class="entry-desc">根据您的健康数据，自动生成个性化膳食方案</view>
          </view>
          <view class="entry-card dietitian-card" bindtap="goToSelectDietitian">
            <view class="entry-icon">👨‍⚕️</view>
            <view class="entry-title">选择规划师</view>
            <view class="entry-desc">专业营养师为您量身定制膳食计划</view>
          </view>
        </view>
        <view class="tips">
          <text class="tip-title">温馨提示</text>
          <text class="tip-item">• 系统智能推荐：根据您的健康数据自动生成</text>
          <text class="tip-item">• 规划师定制：专业营养师根据您的情况制定</text>
        </view>
        <view class="ai-progress-hint" wx:if="{{aiGenerating}}">
          <text class="ai-progress-dot">⏳</text>
          <text class="ai-progress-text">{{aiProgressText}}</text>
        </view>
      </view>

      <view class="status-2" wx:if="{{planStatus === 2}}">
        <view class="request-card">
          <view class="request-status">
            <text class="status-icon">⏳</text>
            <text class="status-text">等待规划师响应</text>
          </view>
          <view class="request-info">
            <view class="info-row">
              <text class="label">规划师：</text>
              <text class="value">{{pendingRequest.dietitian_name || pendingRequest.dietitian_id}}</text>
            </view>
            <view class="info-row">
              <text class="label">服务类型：</text>
              <text class="value">{{pendingRequest.service_type === 'diet_plan' ? '膳食计划定制' : '营养咨询服务'}}</text>
            </view>
            <view class="info-row">
              <text class="label">饮食目标：</text>
              <text class="value">{{pendingRequest.diet_goal}}</text>
            </view>
            <view class="info-row">
              <text class="label">提交时间：</text>
              <text class="value">{{pendingRequest.create_time}}</text>
            </view>
          </view>
          <view class="request-actions">
            <view class="action-btn" bindtap="viewPendingRequestDetail">查看详情</view>
            <view class="action-btn cancel" bindtap="cancelRequest">取消请求</view>
          </view>
        </view>
        <view class="tips">
          <text class="tip-item">规划师一般在24小时内响应</text>
          <text class="tip-item">您可以随时查看请求状态或取消</text>
        </view>
      </view>

      <view class="status-3" wx:if="{{planStatus === 3}}">
        <view class="plan-card pending">
          <view class="plan-status">待审核</view>
          <view class="plan-title">{{currentPlan.title}}</view>
          <view class="plan-info">
            <text>规划师：{{currentPlan.dietitianName}}</text>
            <text>目标：{{currentPlan.goalText || currentPlan.goal}}</text>
          </view>
          <view class="plan-desc">您的膳食计划已提交，正在等待管理员审核</view>
          <view class="action-btn" bindtap="viewPlanDetail">查看计划详情</view>
        </view>
      </view>
    </view>

    <view class="history-section" wx:if="{{historyPlans.length > 0}}">
      <view class="section-title">历史计划</view>
      <view class="history-list">
        <view class="history-item" wx:for="{{historyPlans}}" wx:key="id">
          <view class="history-title">{{item.title}}</view>
          <view class="history-date">{{item.dateRange}}</view>
        </view>
      </view>
    </view>
  </view>
</view>