.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.content {
  padding: 24rpx;
}

.entry-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.entry-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.ai-card {
  border: 2rpx solid #667eea;
}

.dietitian-card {
  border: 2rpx solid #4caf50;
}

.entry-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.entry-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.tips {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.dietitian-card-layout {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.change-btn {
  font-size: 26rpx;
  color: #4caf50;
}

.dietitian-info {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
}

.info {
  flex: 1;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.specialty {
  font-size: 22rpx;
  color: #999;
}

.request-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  text-align: center;
}

.request-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.request-status {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.status-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff9800;
}

.request-info {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #999;
  width: 140rpx;
}

.value {
  color: #333;
  flex: 1;
}

.request-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.action-btn.cancel {
  background: #ffebee;
  color: #f44336;
}

.action-btn.optimize {
  background: #e8f5e9;
  color: #4caf50;
}

.plan-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.plan-card.pending {
  border: 2rpx solid #ff9800;
}

.plan-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #fff3e0;
  color: #ff9800;
  font-size: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.plan-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.plan-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.current-plan {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-source {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.plan-goal {
  font-size: 26rpx;
  color: #4caf50;
  margin-bottom: 24rpx;
}

.nutrition-summary {
  display: flex;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.nutr-item {
  flex: 1;
  text-align: center;
}

.nutr-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.nutr-label {
  font-size: 22rpx;
  color: #999;
}

.meals-list {
  margin-bottom: 24rpx;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.meal-item.executed {
  background: #e8f5e9;
}

.meal-time {
  font-size: 24rpx;
  color: #999;
  width: 100rpx;
}

.meal-info {
  flex: 1;
}

.meal-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.meal-foods {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meal-foods text {
  font-size: 22rpx;
  color: #666;
  background: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meal-calories {
  font-size: 26rpx;
  color: #4caf50;
  font-weight: 500;
  margin-right: 16rpx;
}

.meal-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.meal-check.checked {
  background: #4caf50;
  border-color: #4caf50;
  color: #fff;
}

.plan-actions {
  display: flex;
  gap: 20rpx;
}

.history-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.history-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.history-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.history-item:last-child {
  border-bottom: none;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.history-date {
  font-size: 24rpx;
  color: #999;
}

/* 我的申请模块样式 */
.application-module {
  padding: 24rpx;
}

.application-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.application-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.application-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.application-status {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.application-status.pending {
  background: #fff3cd;
  color: #856404;
}

.application-status.approved {
  background: #d4edda;
  color: #155724;
}

.application-status.rejected {
  background: #f8d7da;
  color: #721c24;
}

.application-status.cancelled {
  background: #e0e0e0;
  color: #666;
}

.application-status.completed {
  background: #cce5ff;
  color: #004085;
}

.application-info {
  margin-bottom: 20rpx;
}

.application-actions {
  display: flex;
  gap: 20rpx;
}

.application-actions .action-btn {
  flex: 1;
  min-width: 0;
}

.action-btn.reapply {
  background: #e8f5e9;
  color: #4caf50;
}

/* 详情页面样式 */
.plan-overview {
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.plan-date {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.plan-period {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.date-selector {
  margin: 20rpx 0;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.selector-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.picker-view {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.date-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.meals-section {
  margin: 20rpx;
}

.meals-list {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  overflow: hidden;
  margin-bottom: 0;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
  background-color: #fff;
  border-radius: 0;
  margin-bottom: 0;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-item:hover {
  background-color: #f9f9f9;
}

.meal-item.executed {
  background-color: #f0f9ff;
}

.meal-time {
  font-size: 24rpx;
  color: #666;
  width: 100rpx;
  text-align: center;
}

.meal-info {
  flex: 1;
  margin: 0 20rpx;
}

.meal-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 5rpx;
}

.meal-foods {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  display: block;
  background: none;
  padding: 0;
  gap: 0;
}

.meal-foods text {
  font-size: 24rpx;
  color: #666;
  background: none;
  padding: 0;
  border-radius: 0;
}

.meal-calories {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: 500;
  width: 100rpx;
  text-align: right;
  margin-right: 20rpx;
}

.meal-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 0;
  transition: all 0.3s ease;
}

.meal-check.checked {
  background-color: #4caf50;
  border-color: #4caf50;
  color: #fff;
  font-weight: 600;
}

.nutrition-analysis {
  margin: 20rpx;
}

.analysis-card {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  padding: 30rpx;
}

.analysis-item {
  margin-bottom: 20rpx;
}

.analysis-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.analysis-chart {
  display: flex;
  align-items: flex-end;
  height: 150rpx;
  margin-bottom: 20rpx;
}

.chart-bar {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 4rpx 4rpx 0 0;
  transition: height 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.chart-bar.protein {
  background-color: #4caf50;
}

.chart-bar.carbohydrate {
  background-color: #2196f3;
}

.chart-bar.fat {
  background-color: #9c27b0;
}

.chart-legend {
  display: flex;
  justify-content: space-around;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.legend-color.protein {
  background-color: #4caf50;
}

.legend-color.carbohydrate {
  background-color: #2196f3;
}

.legend-color.fat {
  background-color: #9c27b0;
}

.legend-text {
  font-size: 22rpx;
  color: #666;
}

.plan-actions {
  display: flex;
  margin: 30rpx 20rpx;
  gap: 10rpx;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 45%;
  padding: 18rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  height: auto;
  line-height: normal;
  background-color: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.action-btn:first-child {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.action-btn.optimize {
  background-color: #ff9800;
  color: #fff;
  border: none;
}

.action-btn.compare {
  background-color: #fff;
  color: #2196f3;
  border: 2rpx solid #2196f3;
}

.action-btn.abandon {
  background-color: #fff;
  color: #f44336;
  border: 2rpx solid #f44336;
}

/* 动画效果已移除，以确保点击事件正常工作 */

/* 响应式设计 */
@media (max-width: 375px) {
  .nutrition-summary {
    flex-wrap: wrap;
  }
  
  .nutr-item {
    width: 50%;
    margin-bottom: 20rpx;
  }
  
  .meal-time {
    width: 80rpx;
  }
  
  .meal-calories {
    width: 80rpx;
  }
}

/* 无计划提示样式 */
.no-plan {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.no-plan-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.no-plan-text {
  font-size: 32rpx;
  color: #666;
  text-align: center;
}