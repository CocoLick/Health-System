.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.content {
  padding: 24rpx;
}

.entry-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.entry-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.ai-card {
  border: 2rpx solid #667eea;
}

.dietitian-card {
  border: 2rpx solid #4caf50;
}

.entry-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.entry-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.tips {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.dietitian-card-layout {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.change-btn {
  font-size: 26rpx;
  color: #4caf50;
}

.dietitian-info {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
}

.info {
  flex: 1;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.specialty {
  font-size: 22rpx;
  color: #999;
}

.request-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  text-align: center;
}

.request-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.request-status {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.status-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff9800;
}

.request-info {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #999;
  width: 140rpx;
}

.value {
  color: #333;
  flex: 1;
}

.request-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.action-btn.cancel {
  background: #ffebee;
  color: #f44336;
}

.action-btn.optimize {
  background: #e8f5e9;
  color: #4caf50;
}

.plan-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.plan-card.pending {
  border: 2rpx solid #ff9800;
}

.plan-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #fff3e0;
  color: #ff9800;
  font-size: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.plan-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.plan-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.current-plan {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-source {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.plan-goal {
  font-size: 26rpx;
  color: #4caf50;
  margin-bottom: 24rpx;
}

.nutrition-summary {
  display: flex;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.nutr-item {
  flex: 1;
  text-align: center;
}

.nutr-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.nutr-label {
  font-size: 22rpx;
  color: #999;
}

.meals-list {
  margin-bottom: 24rpx;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.meal-item.executed {
  background: #e8f5e9;
}

.meal-time {
  font-size: 24rpx;
  color: #999;
  width: 100rpx;
}

.meal-info {
  flex: 1;
}

.meal-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.meal-foods {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meal-foods text {
  font-size: 22rpx;
  color: #666;
  background: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meal-calories {
  font-size: 26rpx;
  color: #4caf50;
  font-weight: 500;
  margin-right: 16rpx;
}

.meal-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.meal-check.checked {
  background: #4caf50;
  border-color: #4caf50;
  color: #fff;
}

.plan-actions {
  display: flex;
  gap: 20rpx;
}

.history-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.history-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.history-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.history-item:last-child {
  border-bottom: none;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.history-date {
  font-size: 24rpx;
  color: #999;
}

/* 我的申请模块样式 */
.application-module {
  padding: 24rpx;
}

.application-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.application-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.application-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.application-status {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.application-status.pending {
  background: #f0f0f0;
  color: #666;
}

.application-status.approved {
  background: #e6f7ee;
  color: #389e7a;
}

.application-status.rejected {
  background: #f7e6e6;
  color: #9e3838;
}

.application-status.cancelled {
  background: #f0f0f0;
  color: #666;
}

.application-info {
  margin-bottom: 20rpx;
}

.application-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn.reapply {
  background: #e8f5e9;
  color: #4caf50;
}