<view class="container">
  <view class="header">
    <view class="header-left"></view>
    <view class="header-title">膳食计划详情</view>
    <view class="header-right"></view>
  </view>

  <view class="plan-overview">
    <view class="plan-header">
      <view class="plan-source">
        <text wx:if="{{plan.source === 'ai'}}">🤖</text>
        <text wx:else>👨‍⚕️</text>
        <text>{{plan.source === 'ai' ? '系统智能推荐' : '规划师定制'}}</text>
      </view>
    </view>
    <view class="plan-dietitian-meta" wx:if="{{plan.source !== 'ai' && plan.dietitianDisplay}}">
      <text class="plan-dietitian-text">规划师：{{plan.dietitianDisplay}}</text>
    </view>
    <view class="plan-title">{{plan.title}}</view>
    <view class="plan-goal">饮食目标：{{plan.goalText || plan.goal || '未填写'}}</view>
    <view class="plan-date">创建时间：{{plan.createTime}}</view>
    
    <view class="date-selector">
      <view class="selector-label">选择日期</view>
      <picker mode="date" value="{{selectedDate}}" bindchange="changeDate">
        <view class="picker-view">
          <text class="date-icon">📅</text>
          <text class="date-value">{{selectedDateText}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="nutrition-summary">
      <view class="nutr-item">
        <view class="nutr-value">{{plan.calories}}</view>
        <view class="nutr-label">千卡</view>
      </view>
      <view class="nutr-item">
        <view class="nutr-value">{{plan.protein}}g</view>
        <view class="nutr-label">蛋白质</view>
      </view>
      <view class="nutr-item">
        <view class="nutr-value">{{plan.carbohydrate}}g</view>
        <view class="nutr-label">碳水</view>
      </view>
      <view class="nutr-item">
        <view class="nutr-value">{{plan.fat}}g</view>
        <view class="nutr-label">脂肪</view>
      </view>
    </view>
  </view>

  <view class="meals-section">
    <view class="section-title">每日膳食安排</view>
    <view class="meals-list">
      <view class="meal-item {{meal.executed ? 'executed' : ''}}" wx:for="{{plan.meals}}" wx:key="type" bindtap="executeMeal" data-meal-index="{{index}}">
        <view class="meal-time">{{item.time}}</view>
        <view class="meal-info">
          <view class="meal-type">{{item.type}}</view>
          <view class="meal-foods">
            <text wx:for="{{item.foods}}" wx:for-item="food" wx:key="name">{{food.name}} {{food.amount}}；</text>
          </view>
        </view>
        <view class="meal-calories">{{item.calories}}kcal</view>
        <view class="meal-check {{meal.executed ? 'checked' : ''}}">
          <text wx:if="{{meal.executed}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <view class="nutrition-analysis">
    <view class="section-title">营养分析</view>
    <view class="analysis-card">
      <view class="analysis-item">
        <view class="analysis-label">热量分配</view>
        <view class="analysis-chart">
          <view class="chart-bar protein" style="height: {{proteinPercentage}}%"></view>
          <view class="chart-bar carbohydrate" style="height: {{carbohydratePercentage}}%"></view>
          <view class="chart-bar fat" style="height: {{fatPercentage}}%"></view>
        </view>
        <view class="chart-legend">
          <view class="legend-item">
            <view class="legend-color protein"></view>
            <view class="legend-text">蛋白质</view>
          </view>
          <view class="legend-item">
            <view class="legend-color carbohydrate"></view>
            <view class="legend-text">碳水</view>
          </view>
          <view class="legend-item">
            <view class="legend-color fat"></view>
            <view class="legend-text">脂肪</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="plan-actions">
    <view class="action-btn" bindtap="recordDiet">记录饮食</view>
    <view class="action-btn optimize" bindtap="applyOptimization">申请优化</view>
    <view class="action-btn compare" bindtap="viewDetailedComparison">查看对比</view>
    <view class="action-btn eval-link" bindtap="goToNutritionEvaluation">查看营养评估</view>
    <view class="action-btn feedback-plan" bindtap="goFeedbackPlan">反馈本计划</view>
    <view class="action-btn abandon" bindtap="terminateService">解除服务</view>
  </view>
</view>