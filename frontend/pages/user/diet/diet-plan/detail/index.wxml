<view class="container">
  <view class="dashboard card">
    <view class="dashboard-top">
      <view class="dashboard-main">
        <view class="plan-source">
          <text wx:if="{{plan.source === 'ai'}}">🤖 系统智能推荐</text>
          <text wx:else>👨‍⚕️ 规划师定制</text>
        </view>
        <view class="plan-title">{{plan.title}}</view>
        <view class="plan-goal">目标：{{plan.goalText || plan.goal || '未填写'}}</view>
        <view class="plan-period">周期：{{plan.durationText || plan.duration || '未设置'}}</view>
      </view>
      <view class="dashboard-meta">
        <text class="meta-label">创建时间</text>
        <text class="meta-value">{{plan.createTime}}</text>
      </view>
    </view>
    <view class="plan-dietitian-meta" wx:if="{{plan.source !== 'ai' && plan.dietitianDisplay}}">
      <text class="plan-dietitian-text">规划师：{{plan.dietitianDisplay}}</text>
    </view>
  </view>

  <view class="metrics-wrap">
    <scroll-view scroll-x class="metrics-scroll" show-scrollbar="{{false}}">
      <view class="metric-card card">
        <text class="metric-value">{{plan.calories}}</text>
        <text class="metric-unit">kcal</text>
        <text class="metric-label">总热量</text>
      </view>
      <view class="metric-card card">
        <text class="metric-value">{{plan.protein}}</text>
        <text class="metric-unit">g</text>
        <text class="metric-label">蛋白质</text>
      </view>
      <view class="metric-card card">
        <text class="metric-value">{{plan.carbohydrate}}</text>
        <text class="metric-unit">g</text>
        <text class="metric-label">碳水</text>
      </view>
      <view class="metric-card card">
        <text class="metric-value">{{plan.fat}}</text>
        <text class="metric-unit">g</text>
        <text class="metric-label">脂肪</text>
      </view>
    </scroll-view>
  </view>

  <view class="date-selector">
    <text class="selector-label">查看日期</text>
    <picker mode="date" value="{{selectedDate}}" bindchange="changeDate">
      <view class="picker-view">
        <text class="date-value">{{selectedDateText}}</text>
        <text class="picker-arrow">▾</text>
      </view>
    </picker>
  </view>

  <view class="section-title">每日膳食安排</view>
  <view class="timeline-list card">
    <view class="timeline-item {{item.executed ? 'executed' : ''}}" wx:for="{{plan.meals}}" wx:key="type" bindtap="executeMeal" data-meal-index="{{index}}">
      <view class="timeline-left">
        <text class="meal-time">{{item.time}}</text>
        <view class="timeline-line"></view>
      </view>
      <view class="timeline-right">
        <view class="meal-head">
          <text class="meal-type">{{item.type}}</text>
          <text class="meal-calories">{{item.calories}}kcal</text>
        </view>
        <view class="meal-foods">
          <text wx:for="{{item.foods}}" wx:for-item="food" wx:key="name">{{food.name}} {{food.amount}}；</text>
        </view>
      </view>
      <view class="meal-check {{item.executed ? 'checked' : ''}}">
        <text wx:if="{{item.executed}}">✓</text>
      </view>
    </view>
  </view>

  <view class="section-title">营养分析</view>
  <view class="analysis-card card">
    <view class="analysis-chart">
      <view class="bar-group">
        <text class="bar-title">蛋白质</text>
        <view class="bar-track">
          <view class="bar-fill bar-protein" style="width: {{proteinPercentage}}%"></view>
        </view>
        <text class="bar-percent">{{proteinPercentage}}%</text>
      </view>
      <view class="bar-group">
        <text class="bar-title">碳水</text>
        <view class="bar-track">
          <view class="bar-fill bar-carbohydrate" style="width: {{carbohydratePercentage}}%"></view>
        </view>
        <text class="bar-percent">{{carbohydratePercentage}}%</text>
      </view>
      <view class="bar-group">
        <text class="bar-title">脂肪</text>
        <view class="bar-track">
          <view class="bar-fill bar-fat" style="width: {{fatPercentage}}%"></view>
        </view>
        <text class="bar-percent">{{fatPercentage}}%</text>
      </view>
    </view>
  </view>

  <view class="action-grid card">
    <view class="action-item" bindtap="applyOptimization">
      <text class="action-icon">⚙️</text>
      <text class="action-text">申请优化</text>
    </view>
    <view class="action-item" bindtap="viewDetailedComparison">
      <text class="action-icon">📊</text>
      <text class="action-text">查看对比</text>
    </view>
    <view class="action-item" bindtap="goToNutritionEvaluation">
      <text class="action-icon">🧪</text>
      <text class="action-text">营养评估</text>
    </view>
    <view class="action-item" bindtap="goFeedbackPlan">
      <text class="action-icon">💬</text>
      <text class="action-text">反馈计划</text>
    </view>
    <view class="action-item action-danger" bindtap="terminateService">
      <text class="action-icon">🛑</text>
      <text class="action-text">解除服务</text>
    </view>
  </view>

  <view class="sticky-action">
    <button class="primary-btn" bindtap="recordDiet">记录饮食</button>
  </view>
</view>