.container {
  --bg: #f4f7f6;
  --surface: #ffffff;
  --title: #1a1a1a;
  --text: #3a3a3a;
  --muted: #8e8e93;
  --brand: #07c160;
  --blue-soft: #9fc6ff;
  --orange-soft: #ffc98f;
  --green-soft: #9ddfb4;
  background: var(--bg);
  min-height: 100vh;
  padding: 20rpx 24rpx 150rpx;
  box-sizing: border-box;
}

.card {
  border-radius: 16rpx;
  background: var(--surface);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
  transition: transform 0.2s ease-in-out, background-color 0.2s ease-in-out;
}

.card:active {
  transform: scale(0.98);
  background-color: #f5f5f5;
}

.dashboard {
  padding: 22rpx;
  margin-bottom: 14rpx;
}

.dashboard-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.dashboard-main {
  flex: 1;
  min-width: 0;
}

.plan-source {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}

.plan-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--title);
  margin-bottom: 8rpx;
}

.plan-goal,
.plan-period {
  font-size: 24rpx;
  color: var(--text);
  margin-bottom: 6rpx;
}

.dashboard-meta {
  flex-shrink: 0;
  text-align: right;
  max-width: 260rpx;
}

.meta-label {
  display: block;
  font-size: 20rpx;
  color: var(--muted);
  margin-bottom: 6rpx;
}

.meta-value {
  display: block;
  font-size: 22rpx;
  color: var(--text);
  line-height: 1.4;
  word-break: break-word;
}

.plan-dietitian-meta {
  margin-top: 10rpx;
}

.plan-dietitian-text {
  font-size: 22rpx;
  color: var(--muted);
}

.metrics-wrap {
  margin-bottom: 14rpx;
}

.metrics-scroll {
  white-space: nowrap;
}

.metric-card {
  width: 180rpx;
  display: inline-block;
  margin-right: 10rpx;
  padding: 16rpx 14rpx;
  box-sizing: border-box;
}

.metric-card:last-child {
  margin-right: 0;
}

.metric-value {
  display: block;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--title);
}

.metric-unit {
  display: block;
  font-size: 20rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: var(--text);
  margin-top: 8rpx;
}

.date-selector {
  margin-bottom: 14rpx;
}

.selector-label {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}

.picker-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 4rpx 12rpx;
  border-bottom: 2rpx solid rgba(142, 142, 147, 0.25);
}

.date-value {
  font-size: 30rpx;
  color: var(--title);
  font-weight: 600;
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--muted);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--title);
  margin: 16rpx 0 10rpx;
}

.timeline-list {
  padding: 8rpx 10rpx;
}

.timeline-item {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid rgba(26, 26, 26, 0.08);
}

.timeline-item:last-child {
  border-bottom: none;
}

.timeline-item.executed {
  background: rgba(7, 193, 96, 0.07);
  border-radius: 12rpx;
}

.timeline-left {
  width: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.meal-time {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 6rpx;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: rgba(142, 142, 147, 0.25);
}

.timeline-right {
  flex: 1;
  min-width: 0;
}

.meal-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.meal-type {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--title);
}

.meal-calories {
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 700;
}

.meal-foods {
  font-size: 24rpx;
  color: var(--text);
  line-height: 1.5;
  word-break: break-word;
}

.meal-check {
  width: 34rpx;
  height: 34rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  color: transparent;
}

.meal-check.checked {
  background: var(--brand);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.analysis-card {
  padding: 18rpx 16rpx;
  margin-bottom: 14rpx;
}

.analysis-chart {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bar-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.bar-title {
  width: 84rpx;
  font-size: 22rpx;
  color: var(--text);
}

.bar-track {
  flex: 1;
  height: 16rpx;
  background: #edf0f2;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.bar-protein {
  background: var(--blue-soft);
}

.bar-carbohydrate {
  background: var(--orange-soft);
}

.bar-fat {
  background: var(--green-soft);
}

.bar-percent {
  width: 66rpx;
  text-align: right;
  font-size: 22rpx;
  color: var(--muted);
}

.action-grid {
  padding: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.action-item {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 12rpx 8rpx;
  text-align: center;
}

.action-icon {
  display: block;
  font-size: 30rpx;
  margin-bottom: 6rpx;
}

.action-text {
  display: block;
  font-size: 22rpx;
  color: var(--text);
}

.action-danger .action-text {
  color: #b24a4a;
}

.sticky-action {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  z-index: 30;
}

.primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: none;
  background: linear-gradient(135deg, #07c160 0%, #14a85a 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}
