.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 20rpx;
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23f8f8f8"/><path d="M0 0L100 100M100 0L0 100" stroke="%23e8e8e8" stroke-width="0.5" opacity="0.5"/></svg>');
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
  color: #333;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 80rpx;
}

.plan-overview {
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.plan-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-bottom: 12rpx;
}

.plan-source {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.plan-source text:first-child {
  margin-right: 10rpx;
  font-size: 32rpx;
}

.plan-dietitian-meta {
  margin-bottom: 16rpx;
}

.plan-dietitian-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.plan-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.plan-goal {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.plan-date {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.date-selector {
  margin: 20rpx 0;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.selector-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.picker-view {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.date-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.nutrition-summary {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.nutr-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.nutr-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 5rpx;
}

.nutr-label {
  font-size: 22rpx;
  color: #666;
}

.meals-section {
  margin: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #ff9800;
}

.meals-list {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-item:hover {
  background-color: #f9f9f9;
}

.meal-item.executed {
  background-color: #f0f9ff;
}

.meal-time {
  font-size: 24rpx;
  color: #666;
  width: 100rpx;
  text-align: center;
}

.meal-info {
  flex: 1;
  margin: 0 20rpx;
}

.meal-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 5rpx;
}

.meal-foods {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.meal-calories {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: 500;
  width: 100rpx;
  text-align: right;
}

.meal-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  transition: all 0.3s ease;
}

.meal-check.checked {
  background-color: #4caf50;
  border-color: #4caf50;
  color: #fff;
  font-weight: 600;
}

.nutrition-analysis {
  margin: 20rpx;
}

.analysis-card {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  padding: 30rpx;
}

.analysis-item {
  margin-bottom: 20rpx;
}

.analysis-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.analysis-chart {
  display: flex;
  align-items: flex-end;
  height: 150rpx;
  margin-bottom: 20rpx;
}

.chart-bar {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 4rpx 4rpx 0 0;
  transition: height 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.chart-bar.protein {
  background-color: #4caf50;
}

.chart-bar.carbohydrate {
  background-color: #2196f3;
}

.chart-bar.fat {
  background-color: #9c27b0;
}

.chart-legend {
  display: flex;
  justify-content: space-around;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.legend-color.protein {
  background-color: #4caf50;
}

.legend-color.carbohydrate {
  background-color: #2196f3;
}

.legend-color.fat {
  background-color: #9c27b0;
}

.legend-text {
  font-size: 22rpx;
  color: #666;
}

.plan-actions {
  display: flex;
  margin: 30rpx 20rpx;
  gap: 10rpx;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: calc(50% - 5rpx);
  padding: 18rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn:first-child {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.action-btn:first-child:hover {
  background-color: #f9f9f9;
}

.action-btn.optimize {
  background-color: #ff9800;
  color: #fff;
}

.action-btn.optimize:hover {
  background-color: #f57c00;
}

.action-btn.compare {
  background-color: #fff;
  color: #2196f3;
  border: 2rpx solid #2196f3;
}

.action-btn.compare:hover {
  background-color: #e3f2fd;
}

.action-btn.abandon {
  background-color: #fff;
  color: #f44336;
  border: 2rpx solid #f44336;
}

.action-btn.abandon:hover {
  background-color: #ffebee;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .nutrition-summary {
    flex-wrap: wrap;
  }
  
  .nutr-item {
    width: 50%;
    margin-bottom: 20rpx;
  }
  
  .meal-time {
    width: 80rpx;
  }
  
  .meal-calories {
    width: 80rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.plan-overview,
.meals-list,
.analysis-card {
  animation: fadeIn 0.5s ease-out;
}

.meal-item {
  animation: fadeIn 0.3s ease-out;
}

.meal-item:nth-child(1) { animation-delay: 0.1s; }
.meal-item:nth-child(2) { animation-delay: 0.2s; }
.meal-item:nth-child(3) { animation-delay: 0.3s; }
.meal-item:nth-child(4) { animation-delay: 0.4s; }