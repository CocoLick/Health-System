.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #666;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.form-item {
  margin-bottom: 32rpx;
  position: relative;
}

.form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.meal-type-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.meal-type-item {
  flex: 1;
  min-width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.meal-type-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: #667eea;
}

.meal-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.meal-text {
  font-size: 22rpx;
  font-weight: 500;
}

.food-list {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.food-count {
  font-size: 22rpx;
  color: #666;
}

.food-items {
  margin-bottom: 20rpx;
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border-left: 4rpx solid #667eea;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.food-details {
  display: flex;
  gap: 20rpx;
  font-size: 20rpx;
  color: #666;
}

.food-actions {
  display: flex;
  gap: 16rpx;
}

.edit-btn, .delete-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.edit-btn {
  background: #e3f2fd;
  color: #1976d2;
}

.delete-btn {
  background: #ffebee;
  color: #d32f2f;
}

.add-food-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #f0f8ff;
  border: 2rpx dashed #667eea;
  border-radius: 12rpx;
  color: #667eea;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 32rpx;
}

.add-icon {
  font-size: 32rpx;
  font-weight: bold;
}

.add-food-form {
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid #e0e0e0;
}

.form-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.form-input:focus {
  border-color: #667eea;
}

/* 分量和单位选择器样式 */
.amount-unit-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.amount-input {
  flex: 1;
}

.unit-picker {
  width: 140rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unit-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.unit-text {
  font-size: 24rpx;
  color: #333;
}

.unit-arrow {
  font-size: 18rpx;
  color: #999;
}

.gram-hint {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
  padding-left: 10rpx;
}

/* 搜索结果样式 */
.search-results {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 0 0 12rpx 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  border: 2rpx solid #e0e0e0;
  border-top: none;
  z-index: 100;
  max-height: 300rpx;
  overflow-y: auto;
}

.search-result-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background-color 0.3s;
}

.search-result-item:hover {
  background-color: #f9f9f9;
}

.result-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.result-info {
  font-size: 20rpx;
  color: #666;
}

.result-calorie {
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: #1976d2;
  font-size: 18rpx;
}

.nutrition-preview {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #e8f5e9;
  border-radius: 12rpx;
  border-left: 4rpx solid #4caf50;
}

.total-nutrition {
  margin-top: 32rpx;
  padding: 20rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
  border-left: 4rpx solid #1976d2;
}

.nutrition-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.nutrition-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nutrition-label {
  font-size: 22rpx;
  color: #666;
}

.nutrition-value {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #e0e0e0;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
}

.camera-section {
  margin-top: 40rpx;
  text-align: center;
}

.camera-tip {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.camera-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border: 2rpx dashed #667eea;
  border-radius: 12rpx;
  color: #667eea;
  font-size: 24rpx;
  font-weight: 500;
}

.camera-icon {
  font-size: 32rpx;
}

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.btn-submit:disabled {
  background: #ccc;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .meal-type-item {
    min-width: 120rpx;
    padding: 16rpx;
  }
  
  .meal-text {
    font-size: 20rpx;
  }
  
  .nutrition-grid {
    grid-template-columns: 1fr;
  }
}

/* --------------------------------
   Add-record page redesign
--------------------------------- */
.container {
  --ui-green: #07c160;
  --ui-title: #1a1a1a;
  --ui-text: #3a3a3a;
  --ui-sub: #8e8e93;
  --ui-surface: #ffffff;
  --ui-soft: #f9fafb;
  --radius-lg: 20rpx;
  --shadow-sm: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
  background: transparent;
  padding: 20rpx 24rpx 120rpx;
}

.card {
  transition: transform 0.2s ease-in-out, background-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}

.card:active {
  transform: scale(0.98);
  background-color: #f5f5f5;
}

.header {
  text-align: left;
  margin-bottom: 16rpx;
  padding: 26rpx 24rpx;
  border-radius: var(--radius-lg);
  background: var(--ui-surface);
  box-shadow: var(--shadow-sm);
}

.header-title {
  color: var(--ui-title);
  font-weight: 700;
  font-size: 38rpx;
}

.header-subtitle {
  color: var(--ui-sub);
}

.form-section {
  padding: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--ui-surface);
  box-shadow: var(--shadow-sm);
}

.form-label,
.section-title,
.nutrition-title,
.food-name {
  color: var(--ui-title);
}

.form-label {
  font-size: 24rpx;
  font-weight: 600;
}

.meal-type-item {
  background: var(--ui-soft);
  border: none;
  border-radius: 16rpx;
  min-width: 136rpx;
}

.meal-type-item.active {
  background: rgba(7, 193, 96, 0.14);
  border: none;
  color: #076b3d;
}

.meal-icon {
  font-size: 34rpx;
}

.meal-text {
  color: var(--ui-text);
}

.meal-type-item.active .meal-text {
  color: #076b3d;
  font-weight: 600;
}

.food-item {
  background: var(--ui-soft);
  border-left: none;
  border-radius: 16rpx;
  padding: 18rpx;
}

.food-details {
  color: var(--ui-sub);
}

.food-actions {
  gap: 10rpx;
}

.edit-btn,
.delete-btn {
  background: transparent;
  padding: 6rpx 8rpx;
  border-radius: 0;
  font-size: 22rpx;
}

.edit-btn {
  color: #2f7a56;
}

.delete-btn {
  color: #b24a4a;
}

.add-food-btn,
.camera-btn {
  border: none;
  border-radius: 16rpx;
  background: var(--ui-soft);
  color: var(--ui-text);
}

.add-food-btn {
  margin-bottom: 24rpx;
}

.add-icon,
.camera-icon {
  color: var(--ui-green);
}

.add-food-form {
  background: var(--ui-soft);
  border: none;
  border-radius: 16rpx;
  padding: 20rpx;
}

.form-input,
.unit-picker,
.search-results {
  border: none;
  background: #ffffff;
  border-radius: 14rpx;
}

.form-input {
  color: var(--ui-text);
}

.gram-hint,
.food-count,
.camera-tip,
.result-info,
.unit-arrow {
  color: var(--ui-sub);
}

.search-results {
  box-shadow: var(--shadow-sm);
}

.search-result-item {
  border-bottom: none;
  margin: 6rpx;
  border-radius: 10rpx;
  padding: 14rpx;
}

.search-result-item:hover {
  background-color: var(--ui-soft);
}

.result-calorie {
  background: rgba(7, 193, 96, 0.12);
  color: #0a5b34;
}

.nutrition-preview {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #ffffff;
  border: none;
  border-radius: 14rpx;
}

.nutrition-grid {
  gap: 10rpx;
}

.nutrition-item {
  background: var(--ui-soft);
  border-radius: 12rpx;
  padding: 12rpx;
}

.nutrition-label {
  color: var(--ui-sub);
  font-size: 22rpx;
}

.nutrition-value {
  color: var(--ui-title);
  font-size: 30rpx;
  font-weight: 700;
}

.nutrition-unit {
  font-size: 20rpx;
  color: var(--ui-sub);
  margin-left: 4rpx;
}

.total-nutrition {
  margin-top: 22rpx;
  padding: 20rpx;
  background: var(--ui-surface);
  border: none;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.nutrition-hero {
  background: var(--ui-soft);
  border-radius: 16rpx;
  padding: 18rpx 18rpx 16rpx;
  margin-bottom: 12rpx;
}

.nutrition-hero-label {
  display: block;
  font-size: 22rpx;
  color: var(--ui-sub);
  margin-bottom: 6rpx;
}

.nutrition-hero-value {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--ui-green);
  line-height: 1;
}

.nutrition-grid-sub {
  grid-template-columns: repeat(3, 1fr);
}

.form-actions {
  margin-top: 18rpx;
}

.btn-cancel,
.btn-confirm {
  border-radius: 16rpx;
  border: none;
}

.btn-cancel {
  background: #eef0f2;
  color: var(--ui-text);
}

.btn-confirm {
  background: var(--ui-green);
  color: #fff;
}

.submit-section {
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 -4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.btn-submit {
  background: var(--ui-green);
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-submit:disabled {
  background: #d1d5db;
}