.container {
  min-height: 100vh;
  background: transparent;
  padding: 20rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.header {
  margin-bottom: 14rpx;
  padding: 22rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(7, 193, 96, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.avatar-text {
  font-size: 38rpx;
  color: #06693a;
  font-weight: 700;
}

.info {
  flex: 1;
  min-width: 0;
}

.username {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}

.role {
  font-size: 22rpx;
  color: #8e8e93;
}

.menu-section {
  margin-bottom: 12rpx;
  padding: 2rpx 14rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 2rpx;
  border-bottom: 1rpx solid rgba(26, 26, 26, 0.08);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.menu-icon {
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid #4b5563;
  border-radius: 7rpx;
  opacity: 0.72;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.menu-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.menu-arrow {
  font-size: 28rpx;
  color: #9ca3af;
}

.logout-section {
  margin-top: 24rpx;
}

.logout-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: #fff;
  color: #b24a4a;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}
