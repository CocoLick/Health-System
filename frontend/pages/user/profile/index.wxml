<view class="container">
  <view class="header card">
    <view class="user-info">
      <view class="avatar">
        <text class="avatar-text">{{isLoggedIn ? (userInfo.username ? userInfo.username.charAt(0).toUpperCase() : '用') : '登'}}</text>
      </view>
      <view class="info">
        <view class="username">{{isLoggedIn ? (userInfo.username || '用户') : '请登录'}}</view>
        <view class="role">{{isLoggedIn ? '普通用户' : '未登录'}}</view>
      </view>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="text" bindtap="navigateTo" data-path="{{item.path}}">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">{{item.text}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item" bindtap="showAbout">
      <view class="menu-left">
        <view class="menu-icon"></view>
        <text class="menu-text">关于</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-section">
    <button class="logout-btn" bindtap="{{isLoggedIn ? 'handleLogout' : 'handleLogin'}}">{{isLoggedIn ? '退出登录' : '去登录'}}</button>
  </view>
</view>