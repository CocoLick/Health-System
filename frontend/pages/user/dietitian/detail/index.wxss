.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 40rpx 30rpx;
}

.dietitian-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
}

.basic-info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.title {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 6rpx;
}

.experience {
  font-size: 24rpx;
  opacity: 0.8;
}

.stats {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

.section {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.specialty-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 24rpx;
  background: #e8f5e9;
  color: #4caf50;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.introduction {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.case-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.case-item {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.case-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.case-desc {
  font-size: 24rpx;
  color: #999;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.review-item {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.review-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.reviewer {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.review-rating {
  font-size: 22rpx;
}

.review-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}

.btn-request {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

/* redesign */
.container {
  --u-green: #07c160;
  --u-title: #1a1a1a;
  --u-text: #3a3a3a;
  --u-sub: #8e8e93;
  --u-surface: #fff;
  --u-soft: #f9fafb;
  --u-radius: 20rpx;
  --u-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
  background: transparent;
}

.header,
.section,
.bottom-action {
  background: var(--u-surface);
  border: none;
  box-shadow: var(--u-shadow);
}

.header {
  margin: 20rpx 24rpx 14rpx;
  border-radius: var(--u-radius);
  color: var(--u-title);
  padding: 24rpx;
}

.avatar {
  background: var(--u-green);
}

.name,
.section-title,
.reviewer {
  color: var(--u-title);
  font-weight: 700;
}

.title,
.experience,
.review-content,
.case-desc {
  color: var(--u-sub);
}

.stats {
  background: var(--u-soft);
  border-radius: 16rpx;
}

.stat-value {
  color: var(--u-title);
}

.stat-label {
  color: var(--u-sub);
}

.stat-divider {
  background: rgba(142, 142, 147, 0.4);
}

.section {
  border-radius: var(--u-radius);
}

.tag {
  background: rgba(7, 193, 96, 0.12);
  color: #0a5b34;
  border-radius: 999rpx;
}

.case-item {
  background: var(--u-soft);
  border-radius: 16rpx;
}

.case-title {
  color: var(--u-text);
}

.review-item {
  border-bottom: none;
  background: var(--u-soft);
  border-radius: 14rpx;
  padding: 14rpx;
  margin-bottom: 10rpx;
}

.review-item:last-child {
  margin-bottom: 0;
}

.btn-request {
  background: var(--u-green);
  border-radius: 16rpx;
}