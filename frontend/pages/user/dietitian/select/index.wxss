.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.search-bar {
  padding: 20rpx 24rpx;
  background: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 64rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.filter-tabs {
  display: flex;
  padding: 20rpx 24rpx;
  background: #fff;
  margin-bottom: 20rpx;
  gap: 24rpx;
}

.filter-tab {
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-tab.active {
  background: #4caf50;
  color: #fff;
}

.dietitian-list {
  padding: 0 24rpx;
}

.dietitian-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.info {
  flex: 1;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.specialty {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.specialty-tag {
  padding: 4rpx 12rpx;
  background: #e8f5e9;
  color: #4caf50;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.rating {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.rating-star {
  font-size: 24rpx;
}

.rating-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff9800;
}

.service-count {
  font-size: 22rpx;
  color: #999;
}

.select-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* redesign */
.container {
  --u-green: #07c160;
  --u-title: #1a1a1a;
  --u-text: #3a3a3a;
  --u-sub: #8e8e93;
  --u-surface: #fff;
  --u-soft: #f9fafb;
  --u-radius: 20rpx;
  --u-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
  background: transparent;
}

.search-bar,
.filter-tabs,
.dietitian-card {
  background: var(--u-surface);
  border: none;
  border-radius: var(--u-radius);
  box-shadow: var(--u-shadow);
}

.search-bar {
  margin: 20rpx 24rpx 12rpx;
  padding: 18rpx;
}

.search-input-wrap {
  background: var(--u-soft);
  border-radius: 16rpx;
}

.search-input {
  color: var(--u-text);
}

.filter-tabs {
  margin: 0 24rpx 12rpx;
  gap: 10rpx;
  padding: 10rpx;
}

.filter-tab {
  background: var(--u-soft);
  color: var(--u-sub);
  border-radius: 999rpx;
}

.filter-tab.active {
  background: rgba(7, 193, 96, 0.14);
  color: #06693a;
}

.dietitian-list {
  padding: 0 24rpx;
}

.dietitian-card {
  margin-bottom: 12rpx;
  transition: transform 0.2s ease-in-out, background-color 0.2s ease-in-out;
}

.dietitian-card:active {
  transform: scale(0.98);
  background: #f5f5f5;
}

.avatar {
  background: var(--u-green);
}

.name {
  color: var(--u-title);
}

.title,
.service-count {
  color: var(--u-sub);
}

.specialty-tag {
  background: rgba(7, 193, 96, 0.12);
  color: #0a5b34;
  border-radius: 999rpx;
}

.rating-value {
  color: var(--u-title);
}

.select-btn {
  background: rgba(7, 193, 96, 0.14);
  color: #06693a;
  border-radius: 14rpx;
}