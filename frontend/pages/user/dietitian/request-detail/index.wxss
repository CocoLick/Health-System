.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: 100rpx;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #333;
  z-index: 101;
  position: relative;
  cursor: pointer;
}

.title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-right: 60rpx;
}

.request-detail {
  padding: 30rpx;
}

.detail-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.detail-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #666;
  min-width: 160rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
  padding-right: 12rpx;
  white-space: nowrap;
}

.value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  word-break: break-word;
  line-height: 40rpx;
}

.value.status {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.value.status.pending {
  background: #f0f0f0;
  color: #666;
}

.value.status.approved {
  background: #e6f7ee;
  color: #389e7a;
}

.value.status.rejected {
  background: #f7e6e6;
  color: #9e3838;
}

.value.status.cancelled {
  background: #f0f0f0;
  color: #666;
}

.action-buttons {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.cancel-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

/* redesign */
.container {
  --u-green: #07c160;
  --u-title: #1a1a1a;
  --u-text: #3a3a3a;
  --u-sub: #8e8e93;
  --u-surface: #fff;
  --u-soft: #f9fafb;
  --u-radius: 20rpx;
  --u-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
  background: transparent;
  padding-top: 0;
}

.header,
.detail-section {
  background: var(--u-surface);
  border: none;
  border-radius: var(--u-radius);
  box-shadow: var(--u-shadow);
}

.header {
  margin: 20rpx 24rpx 12rpx;
  position: static;
  height: auto;
  padding: 20rpx;
}

.title,
.section-title {
  color: var(--u-title);
  font-weight: 700;
}

.request-detail {
  padding: 0 24rpx 24rpx;
}

.detail-section {
  padding: 24rpx;
}

.section-title {
  border-bottom: none;
  margin-bottom: 16rpx;
  padding-bottom: 0;
}

.label {
  color: var(--u-sub);
}

.value {
  color: var(--u-text);
}

.value.status {
  border-radius: 999rpx;
}

.value.status.pending {
  background: rgba(142, 142, 147, 0.14);
  color: #636366;
}

.value.status.approved {
  background: rgba(7, 193, 96, 0.14);
  color: #06693a;
}

.value.status.rejected,
.value.status.cancelled {
  background: rgba(244, 67, 54, 0.12);
  color: #9e3838;
}

.cancel-btn {
  background: var(--u-soft);
  color: var(--u-text);
  border-radius: 16rpx;
}