.page {
  min-height: 100vh;
  background: linear-gradient(165deg, #ebe8e4 0%, #f4f2ef 45%, #f0ece8 100%);
}

.state {
  padding: 80rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6c757d;
}

.state.err {
  color: #c45c4a;
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 32rpx 48rpx;
}

.meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(196, 168, 130, 0.25);
  color: #5c5348;
}

.time {
  font-size: 24rpx;
  color: #8a8278;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2c2825;
  line-height: 1.35;
  margin-bottom: 16rpx;
}

.author {
  font-size: 26rpx;
  color: #5c5348;
  margin-bottom: 8rpx;
}

.category {
  font-size: 24rpx;
  color: #8a8278;
  margin-bottom: 20rpx;
}

.summary {
  font-size: 28rpx;
  color: #4a4540;
  line-height: 1.55;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  margin-bottom: 28rpx;
}

.body {
  font-size: 30rpx;
  color: #333;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
}
