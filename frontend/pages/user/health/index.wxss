.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.section {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #4caf50;
}

.info-grid {
  padding-top: 20rpx;
}

.info-row {
  display: flex;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.health-card {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.health-item {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  padding: 24rpx;
  border-radius: 12rpx;
}

.health-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.health-info {
  flex: 1;
}

.health-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.health-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.allergy-item {
  grid-column: span 2;
}

.allergy-value {
  flex: 1;
  word-break: break-all;
}

.evaluation-card {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 12rpx;
  padding: 24rpx;
}

.evaluation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.evaluation-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.evaluation-status.completed {
  background: #e8f5e9;
  color: #4caf50;
}

.evaluation-status.pending {
  background: #fff3e0;
  color: #ff9800;
}

.evaluation-status.expired {
  background: #fce4ec;
  color: #c2185b;
}

.evaluation-time {
  font-size: 24rpx;
  color: #999;
}

.evaluation-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.evaluation-item {
  display: flex;
  font-size: 26rpx;
}

.evaluation-label {
  color: #666;
}

.evaluation-value {
  color: #333;
  flex: 1;
}

.evaluation-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
}

.evaluation-tip {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 12rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}

.history-date {
  font-size: 26rpx;
  color: #666;
}

.history-data {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.history-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.picker-view {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-view::after {
  content: "▼";
  font-size: 20rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.login-tip {
  margin: 30rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.login-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.login-subtext {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 32rpx;
  line-height: 1.4;
}

.login-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.switch-container {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.gender-label {
  font-size: 24rpx;
  color: #999;
  transition: all 0.3s ease;
  min-width: 40rpx;
  text-align: center;
}

.gender-label.active {
  color: #667eea;
  font-weight: 500;
}

.switch-selector {
  flex: 0 0 auto;
}

.switch-track {
  width: 160rpx;
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
}

.switch-thumb {
  width: 52rpx;
  height: 52rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.switch-thumb.right {
  left: 104rpx;
}

.header-guest {
  background: linear-gradient(145deg, #ebe8e4 0%, #d8d4cf 100%);
  color: #3d3a36;
}

.health-main-tabs {
  display: flex;
  margin: 0 24rpx;
  margin-top: 20rpx;
  padding: 6rpx;
  background: #fff;
  border-radius: 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.h-main-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #6c757d;
  padding: 18rpx 0;
  border-radius: 10rpx;
  font-weight: 500;
}

.h-main-tab.active {
  background: linear-gradient(135deg, #c4a882 0%, #a68960 100%);
  color: #fff;
  font-weight: 600;
}

.edu-tab-panel {
  padding: 0 24rpx 120rpx;
}

.edu-intro {
  padding: 28rpx 8rpx 20rpx;
}

.edu-intro-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #2c2825;
  margin-bottom: 8rpx;
}

.edu-intro-desc {
  font-size: 24rpx;
  color: #8a8278;
  line-height: 1.45;
}

.edu-toolbar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.edu-filter {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #5c5348;
  padding: 18rpx 0;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.edu-filter.on {
  background: rgba(196, 168, 130, 0.35);
  border-color: rgba(166, 137, 96, 0.45);
  font-weight: 600;
  color: #3d3a36;
}

.edu-hint {
  font-size: 26rpx;
  color: #8a6d5a;
  padding: 24rpx 16rpx;
  line-height: 1.5;
}

.edu-loading {
  text-align: center;
  padding: 48rpx;
  color: #8a8278;
  font-size: 28rpx;
}

.edu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.edu-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.edu-item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.edu-item-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.edu-item-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.edu-item-tag.public {
  background: #e8f5e9;
  color: #2e7d32;
}

.edu-item-tag.assigned {
  background: #fff3e0;
  color: #e65100;
}

.edu-item-summary {
  font-size: 26rpx;
  color: #6c757d;
  line-height: 1.45;
  margin-bottom: 12rpx;
  display: block;
}

.edu-item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #9aa0a6;
}

.edu-item-author {
  color: #5c5348;
}

.edu-empty {
  text-align: center;
  padding: 80rpx 24rpx;
  color: #adb5bd;
  font-size: 28rpx;
}