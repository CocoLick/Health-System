  border-color: rgba(45, 106, 79, 0.28);
  color: var(--c-primary);
}

.edu-item {
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.edu-item-title {
  color: var(--c-text);
}

.edu-item-summary {
  color: var(--c-text-2);
}

.edu-item-tag.public {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.edu-item-tag.assigned {
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
}

.edu-item-meta {
  color: var(--c-text-3);
}

.edu-item-author {
  color: var(--c-text-2);
}

.header-guest {
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  background: var(--c-surface);
  color: var(--c-text);
}

.login-tip {
  margin: 18rpx 24rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.login-btn,
.btn-confirm {
  background: var(--c-primary);
}

/* ------------------------------
   Health tab polish v2
   - de-form style / soft cards
------------------------------ */
.container {
  --u-green: #07c160;
  --u-gray: #8e8e93;
  --u-bg-soft: #f9fafb;
  --u-shadow-sm: 0 4rpx 18rpx rgba(15, 23, 42, 0.05);
}

.health-main-tabs {
  margin-top: 4rpx;
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  border-radius: 0;
}

.h-main-tab {
  position: relative;
  border-radius: 0;
  padding: 20rpx 0 18rpx;
  color: var(--u-gray);
  font-weight: 500;
}

.h-main-tab.active {
  background: transparent;
  color: #1f1f1c;
  font-weight: 700;
}

.h-main-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: var(--u-green);
}

.section {
  background: #fff;
  border: none;
  box-shadow: var(--u-shadow-sm);
  padding: 28rpx;
}

.section-action {
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: var(--u-green);
  font-weight: 500;
}

.section-action::after {
  content: " >";
  color: var(--u-gray);
  font-size: 22rpx;
}

.info-item-card,
.health-item,
.evaluation-card,
.edu-item,
.login-tip,
.header-guest {
  border: none;
  box-shadow: var(--u-shadow-sm);
}

.info-item-card {
  background: var(--u-bg-soft);
}

.health-item {
  background: var(--u-bg-soft);
}

.health-icon,
.info-label,
.evaluation-label,
.history-date,
.history-empty,
.evaluation-time,
.evaluation-tip,
.edu-intro-desc,
.edu-item-meta,
.edu-item-author {
  color: var(--u-gray);
}

.health-value,
.info-value,
.evaluation-value {
  font-weight: 700;
}

.health-value {
  font-size: 34rpx;
}

.evaluation-bmi-value {
  font-size: 54rpx;
  color: var(--u-green);
}

.unit {
  font-size: 18rpx;
  color: var(--u-gray);
}

.evaluation-item,
.evaluation-bmi-item {
  background: var(--u-bg-soft);
}

.evaluation-status.completed {
  background: rgba(7, 193, 96, 0.12);
  color: #068d47;
}

.evaluation-status.pending,
.evaluation-status.expired {
  background: rgba(142, 142, 147, 0.14);
  color: #636366;
}

.history-item {
  border: none;
  box-shadow: none;
  background: var(--u-bg-soft);
}

.history-tag {
  background: rgba(7, 193, 96, 0.12);
  color: #0a5b34;
  border: none;
  padding: 6rpx 12rpx;
}

.allergy-value {
  white-space: normal;
  word-break: break-word;
  line-height: 1.6;
}

.edu-filter {
  border: none;
  background: #fff;
  box-shadow: var(--u-shadow-sm);
  color: var(--u-gray);
}

