<view class="auth-page register-page">
  <view class="auth-bg" aria-hidden="true">
    <view class="auth-bg-orb auth-bg-orb-1"></view>
    <view class="auth-bg-orb auth-bg-orb-2"></view>
  </view>

  <view class="auth-header">
    <text class="auth-eyebrow">CREATE ACCOUNT</text>
    <view class="auth-logo">
      <text class="auth-logo-icon" aria-hidden="true">🍽️</text>
    </view>
    <text class="auth-title">营养膳食规划</text>
    <text class="auth-subtitle">科学饮食，健康管理</text>
  </view>

  <view class="auth-card ui-card">
    <view class="auth-card-inner auth-card-inner--tall">
      <view class="auth-section-head">
        <text class="auth-welcome-title">创建账户</text>
        <text class="auth-welcome-desc">填写信息完成注册，与系统其他模块风格一致、数据互通</text>
      </view>

      <view class="input-group">
        <view class="input-wrapper">
          <view class="input-icon">👤</view>
          <input
            class="login-input"
            placeholder="请输入用户名"
            placeholder-class="placeholder"
            bindinput="bindUsername"
            value="{{username}}"
          />
        </view>

        <view class="input-wrapper">
          <view class="input-icon">🔒</view>
          <input
            class="login-input password-input"
            placeholder="请输入密码"
            placeholder-class="placeholder"
            bindinput="bindPassword"
            value="{{password}}"
            type="text"
            password="{{!showPassword}}"
          />
          <view class="password-toggle" bindtap="togglePassword">
            {{showPassword ? '👁️' : '👁️‍🗨️'}}
          </view>
        </view>

        <view class="input-wrapper">
          <view class="input-icon">📱</view>
          <input
            class="login-input"
            placeholder="请输入手机号"
            placeholder-class="placeholder"
            bindinput="bindPhone"
            value="{{phone}}"
          />
        </view>

        <view class="input-wrapper">
          <view class="input-icon">⚥</view>
          <picker bindchange="bindGenderChange" range="{{genderOptions}}" value="{{genderIndex}}">
            <view class="picker-view {{genderIndex < 0 ? 'picker-placeholder' : ''}}">
              {{genderOptions[genderIndex] || '请选择性别'}}
            </view>
          </picker>
        </view>

        <view class="input-wrapper">
          <view class="input-icon">🎂</view>
          <picker bindchange="bindAgeChange" range="{{ageOptions}}" value="{{ageIndex}}">
            <view class="picker-view {{ageIndex < 0 ? 'picker-placeholder' : ''}}">
              {{ageOptions[ageIndex] || '请选择年龄'}}
            </view>
          </picker>
        </view>

        <view class="input-wrapper">
          <view class="input-icon">📧</view>
          <input
            class="login-input"
            placeholder="请输入邮箱"
            placeholder-class="placeholder"
            bindinput="bindEmail"
            value="{{email}}"
          />
        </view>
      </view>

      <view class="message-area">
        <view wx:if="{{errorMessage}}" class="error-tip">{{errorMessage}}</view>
        <view wx:if="{{successMessage}}" class="success-tip">{{successMessage}}</view>
      </view>

      <view class="auth-btn btn-primary" hover-class="auth-btn-hover" bindtap="handleRegister">
        <text class="auth-btn-text">注 册</text>
      </view>

      <view class="auth-card-footer">
        <view class="auth-divider">
          <view class="auth-divider-line"></view>
          <text class="auth-divider-text">或</text>
          <view class="auth-divider-line"></view>
        </view>
        <view class="auth-switch-row">
          <text class="auth-switch-hint">已有账号？</text>
          <text class="auth-link" bindtap="navigateToLogin">立即登录</text>
        </view>
      </view>
    </view>
  </view>

  <view class="auth-legal">
    <text class="auth-legal-t">注册即表示同意</text>
    <text class="auth-legal-a">《用户协议》</text>
    <text class="auth-legal-t">和</text>
    <text class="auth-legal-a">《隐私政策》</text>
  </view>
</view>