/* 与营养评估中心 / app 全局：森林绿 + 米白面 + 点状底纹 */

page {
  --auth-radius: 20rpx;
  --auth-radius-sm: 12rpx;
}

.auth-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  padding: 32rpx 28rpx 48rpx;
  background-color: var(--c-bg);
  background-image:
    radial-gradient(rgba(60, 54, 45, 0.03) 0.8rpx, transparent 0.8rpx),
    linear-gradient(160deg, #f0ede8 0%, #f7f4ef 58%, #f1eee9 100%);
  background-size: 8rpx 8rpx, 100% 100%;
}

.auth-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.auth-bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(2rpx);
}

.auth-bg-orb-1 {
  width: 420rpx;
  height: 420rpx;
  top: -180rpx;
  right: -120rpx;
  background: radial-gradient(
    circle,
    rgba(45, 106, 79, 0.12) 0%,
    rgba(45, 106, 79, 0) 70%
  );
}

.auth-bg-orb-2 {
  width: 360rpx;
  height: 360rpx;
  bottom: -100rpx;
  left: -100rpx;
  background: radial-gradient(
    circle,
    rgba(192, 123, 79, 0.1) 0%,
    rgba(192, 123, 79, 0) 70%
  );
}

.auth-header {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 32rpx 0 40rpx;
}

.auth-eyebrow {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.14em;
  color: var(--c-text-3);
  margin-bottom: 20rpx;
}

.auth-logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, var(--c-primary) 0%, var(--c-primary-strong) 100%);
  box-shadow: 0 10rpx 32rpx rgba(45, 106, 79, 0.24);
  border: 1rpx solid rgba(45, 106, 79, 0.12);
}

.auth-logo-icon {
  font-size: 58rpx;
  line-height: 1;
}

.auth-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: -0.02em;
  margin-bottom: 10rpx;
}

.auth-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-2);
  letter-spacing: 0.04em;
}

.auth-card {
  position: relative;
  z-index: 1;
  border-radius: var(--auth-radius);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  background: var(--c-surface);
  overflow: hidden;
}

.auth-card-inner {
  padding: 40rpx 32rpx 36rpx;
}

.auth-section-head {
  margin-bottom: 36rpx;
}

.auth-welcome-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--c-text);
  letter-spacing: -0.02em;
  margin-bottom: 10rpx;
}

.auth-welcome-desc {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.55;
}

.input-group {
  margin-bottom: 8rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  position: relative;
  background: #fffcf8;
  border-radius: var(--auth-radius-sm);
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--c-border);
  box-sizing: border-box;
  transition: border-color 0.2s var(--ease-natural), box-shadow 0.2s;
}

.input-wrapper:focus-within {
  border-color: rgba(45, 106, 79, 0.35);
  background: #fffef9;
  box-shadow: 0 0 0 3rpx var(--c-primary-soft);
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  opacity: 0.88;
}

.login-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--c-text);
  height: 48rpx;
  line-height: 48rpx;
}

.password-input {
  padding-right: 64rpx;
}

.password-toggle {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  padding: 8rpx;
  opacity: 0.75;
}

.placeholder {
  color: var(--c-text-3);
  font-size: 28rpx;
}

.message-area {
  min-height: 48rpx;
  margin: 8rpx 0 20rpx;
}

.error-tip {
  font-size: 24rpx;
  color: #b42318;
  text-align: center;
  line-height: 1.4;
}

.success-tip {
  font-size: 24rpx;
  color: var(--c-primary);
  text-align: center;
}

.auth-btn {
  border-radius: 44rpx;
  padding: 24rpx 28rpx;
  text-align: center;
  margin-top: 8rpx;
}

.auth-btn-hover {
  opacity: 0.92;
  transform: translateY(1rpx);
}

.auth-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.2em;
}

.auth-card-footer {
  margin-top: 40rpx;
}

.auth-divider {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.auth-divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--c-border);
}

.auth-divider-text {
  font-size: 22rpx;
  color: var(--c-text-3);
  padding: 0 20rpx;
}

.auth-switch-row {
  text-align: center;
}

.auth-switch-hint {
  font-size: 26rpx;
  color: var(--c-text-2);
}

.auth-link {
  font-size: 26rpx;
  color: var(--c-primary);
  font-weight: 600;
  margin-left: 8rpx;
}

.auth-legal {
  position: relative;
  z-index: 1;
  margin-top: 40rpx;
  padding: 0 8rpx;
  text-align: center;
  line-height: 1.7;
}

.auth-legal-t {
  font-size: 22rpx;
  color: var(--c-text-3);
}

.auth-legal-a {
  font-size: 22rpx;
  color: var(--c-primary);
  font-weight: 500;
}
