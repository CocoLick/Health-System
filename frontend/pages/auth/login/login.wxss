.login-page {
  min-height: 100vh;
  background: linear-gradient(145deg, #f8f9fa 0%, #e9ecef 100%);
  position: relative;
  overflow: hidden;
}

.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: #4caf50;
  top: -150rpx;
  right: -100rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: #ff9800;
  top: 60%;
  left: -120rpx;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  background: #2196f3;
  bottom: 10%;
  right: 10%;
}

.login-header {
  padding: 120rpx 60rpx 60rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.logo-wrapper {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  border-radius: 36rpx;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(76, 175, 80, 0.3);
}

.logo-icon {
  font-size: 70rpx;
}

.app-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.app-subtitle {
  display: block;
  font-size: 28rpx;
  color: #6c757d;
  letter-spacing: 4rpx;
}

.login-card {
  padding: 0 40rpx;
  position: relative;
  z-index: 1;
}

.card-inner {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 60rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.welcome-text {
  margin-bottom: 50rpx;
}

.welcome-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  color: #868e96;
  line-height: 1.6;
}

.role-selector {
  margin-bottom: 40rpx;
}

.role-label {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.role-options {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.role-option {
  flex: 1;
  min-width: 180rpx;
  padding: 20rpx;
  border: 2rpx solid #dee2e6;
  border-radius: 12rpx;
  text-align: center;
  background: #f8f9fa;
  transition: all 0.3s ease;
}

.role-option:active {
  transform: scale(0.98);
}

.role-option.active {
  border-color: #4caf50;
  background: rgba(76, 175, 80, 0.05);
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
}

.role-text {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.role-option.active .role-text {
  color: #4caf50;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: #4caf50;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.login-input {
  flex: 1;
  font-size: 32rpx;
  color: #1a1a1a;
  height: 48rpx;
  line-height: 48rpx;
}

.password-input {
  padding-right: 60rpx;
}

.password-toggle {
  position: absolute;
  right: 30rpx;
  font-size: 36rpx;
  cursor: pointer;
}

.input-wrapper {
  position: relative;
}

.placeholder {
  color: #adb5bd;
  font-size: 32rpx;
}

.message-area {
  height: 60rpx;
  margin-bottom: 20rpx;
}

.error-tip {
  font-size: 26rpx;
  color: #dc3545;
  padding: 10rpx 0;
  text-align: center;
}

.success-tip {
  font-size: 26rpx;
  color: #28a745;
  padding: 10rpx 0;
  text-align: center;
}

.btn-login {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.25);
  transition: all 0.3s ease;
}

.btn-login:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.2);
}

.btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 8rpx;
}

.card-footer {
  margin-top: 50rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #dee2e6;
}

.divider-text {
  font-size: 24rpx;
  color: #adb5bd;
  padding: 0 24rpx;
}

.register-hint {
  text-align: center;
}

.hint-text {
  font-size: 28rpx;
  color: #6c757d;
}

.register-link {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: 500;
  margin-left: 8rpx;
}

.login-footer {
  padding: 60rpx 40rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.footer-text {
  font-size: 24rpx;
  color: #adb5bd;
}

.footer-link {
  font-size: 24rpx;
  color: #4caf50;
}