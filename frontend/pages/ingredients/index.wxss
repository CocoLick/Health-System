/* ingredients/index.wxss */

/* 全局样式 */
.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23f8f9fa"/><circle cx="20" cy="20" r="0.5" fill="%23e9ecef" opacity="0.5"/><circle cx="80" cy="80" r="0.5" fill="%23e9ecef" opacity="0.5"/><circle cx="40" cy="60" r="0.5" fill="%23e9ecef" opacity="0.5"/><circle cx="60" cy="40" r="0.5" fill="%23e9ecef" opacity="0.5"/><circle cx="30" cy="80" r="0.5" fill="%23e9ecef" opacity="0.5"/><circle cx="70" cy="20" r="0.5" fill="%23e9ecef" opacity="0.5"/></svg>');
  padding: 20rpx;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e9ecef;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  color: #6c757d;
}

.search-input input {
  flex: 1;
  font-size: 24rpx;
  color: #343a40;
  border: none;
  outline: none;
}

.filter-btn {
  padding: 0 24rpx;
  background-color: #4caf50;
  color: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease-out;
}

.filter-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* 分类导航 */
.category-nav {
  margin-bottom: 20rpx;
}

.category-scroll {
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #6c757d;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e9ecef;
  transition: all 0.3s ease-out;
}

.category-item.active {
  background-color: #4caf50;
  color: #ffffff;
  border-color: #4caf50;
}

.category-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 食材列表 */
.ingredients-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e9ecef;
  transition: all 0.3s ease-out;
}

.ingredient-item:hover {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-2rpx);
}

.ingredient-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background-color: #f8f9fa;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.ingredient-image text {
  font-size: 40rpx;
}

.ingredient-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ingredient-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #343a40;
}

.ingredient-nutrition {
  display: flex;
  gap: 24rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.nutrition-label {
  font-size: 18rpx;
  color: #6c757d;
}

.nutrition-value {
  font-size: 20rpx;
  font-weight: 500;
  color: #343a40;
}

.ingredient-action {
  margin-left: 16rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  background-color: #4caf50;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  transition: all 0.3s ease-out;
}

.action-btn:hover {
  transform: translateY(-1rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e9ecef;
  transition: all 0.3s ease-out;
}

.load-more:hover {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-2rpx);
}

.load-more text {
  font-size: 24rpx;
  color: #4caf50;
  font-weight: 500;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 16rpx;
  }
  
  .ingredient-item {
    padding: 20rpx;
  }
  
  .ingredient-image {
    width: 70rpx;
    height: 70rpx;
    margin-right: 16rpx;
  }
  
  .ingredient-image text {
    font-size: 32rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.search-bar,
.category-nav,
.ingredient-item,
.load-more {
  animation: fadeIn 0.5s ease-out forwards;
}

.search-bar {
  animation-delay: 0.1s;
}

.category-nav {
  animation-delay: 0.2s;
}

.ingredient-item {
  animation-delay: 0.3s;
}

.load-more {
  animation-delay: 0.4s;
}

/* 登录引导页样式 */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 0 40rpx;
  text-align: center;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.3);
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
}

.login-text {
  font-size: 32rpx;
  color: #6c757d;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

.login-btn {
  width: 80%;
  height: 90rpx;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 45rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.3);
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(76, 175, 80, 0.3);
}

/* 食材图片样式 */
.ingredient-image image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}