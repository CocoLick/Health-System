<view class="container">
  <view class="header">
    <view class="user-greeting">
      <view class="greeting-text">早上好</view>
      <view class="user-name">{{userInfo.username || '用户'}}</view>
    </view>
    <view class="header-date">{{today}}</view>
  </view>

  <view class="content">
    <view class="stats-cards">
      <view class="stat-card" bindtap="goToNutrition">
        <view class="stat-icon">🔥</view>
        <view class="stat-info">
          <view class="stat-value">{{todayIntake.calories}}</view>
          <view class="stat-label">今日热量(kcal)</view>
        </view>
      </view>
      <view class="stat-card" bindtap="goToHealth">
        <view class="stat-icon">💪</view>
        <view class="stat-info">
          <view class="stat-value">{{todayIntake.protein}}g</view>
          <view class="stat-label">蛋白质摄入</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">今日膳食计划</view>
        <view class="section-more" bindtap="goToDietPlan">更多 ›</view>
      </view>

      <view class="plan-card" wx:if="{{currentPlan}}" bindtap="viewPlanDetail">
        <view class="plan-header">
          <view class="plan-source">
            <text wx:if="{{currentPlan.source === 'ai'}}">🤖</text>
            <text wx:else>👨‍⚕️</text>
            <text>{{currentPlan.source === 'ai' ? '智能推荐' : '规划师定制'}}</text>
          </view>
          <view class="plan-status">进行中</view>
        </view>
        <view class="plan-title">{{currentPlan.title}}</view>
        <view class="plan-summary">
          <text>热量：{{currentPlan.calories}}kcal</text>
          <text>蛋白质：{{currentPlan.protein}}g</text>
        </view>
        <view class="plan-meals">
          <view class="meal-preview" wx:for="{{currentPlan.meals}}" wx:key="type">
            <text class="meal-type">{{item.type}}</text>
            <text class="meal-calories">{{item.calories}}kcal</text>
          </view>
        </view>
      </view>

      <view class="plan-empty" wx:else>
        <view class="empty-icon">📋</view>
        <view class="empty-text">暂无膳食计划</view>
        <view class="empty-actions">
          <view class="action-btn primary" bindtap="requestAiPlan">智能推荐</view>
          <view class="action-btn" bindtap="goToSelectDietitian">选择规划师</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">健康提醒</view>
      </view>
      <view class="tips-list">
        <view class="tip-item" wx:for="{{healthTips}}" wx:key="title">
          <view class="tip-icon">{{item.icon}}</view>
          <view class="tip-content">
            <view class="tip-title">{{item.title}}</view>
            <view class="tip-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="quick-nav">
      <view class="nav-item" bindtap="goToNutrition">
        <view class="nav-icon">📊</view>
        <view class="nav-text">营养</view>
      </view>
      <view class="nav-item" bindtap="goToDietPlan">
        <view class="nav-icon">📅</view>
        <view class="nav-text">膳食</view>
      </view>
      <view class="nav-item" bindtap="goToHealth">
        <view class="nav-icon">🏥</view>
        <view class="nav-text">健康</view>
      </view>
      <view class="nav-item" bindtap="goToProfile">
        <view class="nav-icon">👤</view>
        <view class="nav-text">我的</view>
      </view>
    </view>
  </view>
</view>