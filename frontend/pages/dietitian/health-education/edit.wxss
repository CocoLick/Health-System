.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 200rpx;
  box-sizing: border-box;
  background: transparent;
}

.context-bar {
  background: rgba(45, 106, 79, 0.1);
  border: 1rpx solid rgba(45, 106, 79, 0.24);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}

.context-text {
  font-size: 26rpx;
  color: var(--c-primary);
  line-height: 1.5;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 12rpx;
}

.input {
  background: #fffcf8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 1rpx solid var(--c-border);
}

.textarea {
  width: 100%;
  min-height: 320rpx;
  background: #fffcf8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.55;
  border: 1rpx solid var(--c-border);
  box-sizing: border-box;
}

.section {
  margin-top: 36rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 16rpx;
  display: block;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.radio-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--c-text-2);
  line-height: 1.45;
}

.hint-muted {
  font-size: 24rpx;
  color: var(--c-text-3);
  padding: 16rpx 0;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--c-surface);
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.check {
  font-size: 32rpx;
  color: var(--c-primary);
}

.uname {
  flex: 1;
  font-size: 28rpx;
  color: var(--c-text);
}

.uid {
  font-size: 22rpx;
  color: var(--c-text-3);
}

.footer-btns {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 248, 0.95);
  border-top: 1rpx solid var(--c-border);
  display: flex;
  gap: 20rpx;
  box-sizing: border-box;
}

.btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 12rpx;
  line-height: 2.2;
}

.btn.secondary {
  background: var(--c-surface);
  color: var(--c-text-2);
  border: 1rpx solid var(--c-border);
}

.btn.primary {
  background: var(--c-primary);
  color: #fff;
  border: none;
}
