.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 200rpx;
  box-sizing: border-box;
  background: linear-gradient(165deg, #ebe8e4 0%, #f4f2ef 50%, #f0ece8 100%);
}

.context-bar {
  background: rgba(184, 149, 108, 0.12);
  border: 1rpx solid rgba(184, 149, 108, 0.35);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}

.context-text {
  font-size: 26rpx;
  color: #5c5348;
  line-height: 1.5;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3d3a36;
  margin-bottom: 12rpx;
}

.input {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.textarea {
  width: 100%;
  min-height: 320rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.55;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.section {
  margin-top: 36rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #3d3a36;
  margin-bottom: 16rpx;
  display: block;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.radio-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 26rpx;
  color: #4a4540;
  line-height: 1.45;
}

.hint-muted {
  font-size: 24rpx;
  color: #8a8278;
  padding: 16rpx 0;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.check {
  font-size: 32rpx;
  color: #b8956c;
}

.uname {
  flex: 1;
  font-size: 28rpx;
  color: #2c2825;
}

.uid {
  font-size: 22rpx;
  color: #8a8278;
}

.footer-btns {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(244, 242, 239, 0.96);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 20rpx;
  box-sizing: border-box;
}

.btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 12rpx;
  line-height: 2.2;
}

.btn.secondary {
  background: #fff;
  color: #4a4540;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
}

.btn.primary {
  background: #b8956c;
  color: #fff;
  border: none;
}
