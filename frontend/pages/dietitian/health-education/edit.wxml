<view class="page">
  <view class="context-bar" wx:if="{{contextUserId}}">
    <text class="context-text">正在为服务用户编写（默认仅 TA 可见，可在下方修改范围）</text>
  </view>

  <view class="field">
    <text class="label">标题</text>
    <input class="input" placeholder="请输入标题" value="{{title}}" bindinput="onTitleInput" />
  </view>

  <view class="field">
    <text class="label">摘要（选填）</text>
    <input class="input" placeholder="列表中展示的简短说明" value="{{summary}}" bindinput="onSummaryInput" />
  </view>

  <view class="field">
    <text class="label">分类（选填）</text>
    <input class="input" placeholder="如：膳食理念、生活方式" value="{{category}}" bindinput="onCategoryInput" />
  </view>

  <view class="field">
    <text class="label">正文</text>
    <textarea
      class="textarea"
      placeholder="健康饮食知识、科学膳食理念、行为引导建议等"
      value="{{body}}"
      bindinput="onBodyInput"
      maxlength="20000"
      auto-height
    />
  </view>

  <view class="section">
    <text class="section-title">可见范围（发布时最终生效，草稿可先保存意向）</text>
    <radio-group class="radio-group" bindchange="onVisibilityChange">
      <label class="radio-row">
        <radio value="public" checked="{{visibility === 'public'}}" color="#b8956c" />
        <text>公开（所有登录用户将来可在用户端查看）</text>
      </label>
      <label class="radio-row">
        <radio value="assigned" checked="{{visibility === 'assigned'}}" color="#b8956c" />
        <text>仅指派用户（须为与您有已批准服务关系的用户，可多选）</text>
      </label>
    </radio-group>
  </view>

  <view class="section" wx:if="{{visibility === 'assigned'}}">
    <text class="section-title">选择用户</text>
    <view wx:if="{{serviceUsers.length === 0}}" class="hint-muted">暂无服务用户，请先通过服务申请并批准。</view>
    <view wx:for="{{serviceUsers}}" wx:key="userId" class="user-row" bindtap="toggleUser" data-userid="{{item.userId}}">
      <text class="check">{{selectedMap[item.userId] ? '☑' : '☐'}}</text>
      <text class="uname">{{item.username}}</text>
      <text class="uid">{{item.userId}}</text>
    </view>
  </view>

  <view class="footer-btns">
    <button class="btn secondary" loading="{{saving}}" bindtap="saveDraft">保存草稿</button>
    <button class="btn primary" loading="{{publishing}}" bindtap="publish">发布</button>
  </view>
</view>
