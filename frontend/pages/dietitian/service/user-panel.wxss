.user-panel {
  min-height: 100vh;
  background: transparent;
  padding-bottom: 40rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx 16rpx 12rpx;
}

.header-side {
  min-width: 200rpx;
  max-width: 220rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.header-side-left {
  justify-content: flex-start;
}

.header-side-right {
  justify-content: flex-end;
}

.back-btn {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 22rpx 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 248, 0.92);
  border: 1rpx solid var(--c-border);
}

.back-btn-hover {
  background: rgba(45, 106, 79, 0.08);
}

.back-chevron {
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
  font-size: 44rpx;
  line-height: 44rpx;
  font-weight: 300;
  color: var(--c-text);
}

.back-text {
  flex-shrink: 0;
  font-size: 28rpx;
  line-height: 44rpx;
  color: var(--c-text-2);
  font-weight: 500;
}

.panel-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--c-text);
  min-width: 0;
}

.user-info-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  background: var(--c-surface);
  border-radius: 16rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.user-avatar-large {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--c-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: 600;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text);
}

.user-meta {
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.5;
}

.service-cards {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-card {
  background: var(--c-surface);
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  border-left: 8rpx solid #ccc3b5;
  transition: transform 0.18s var(--ease-natural), box-shadow 0.18s var(--ease-natural);
}

.service-card.card-ok {
  border-left-color: var(--c-primary);
}

.service-card.card-warning {
  border-left-color: #b56d42;
}

.service-card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-press);
}

.service-card.card-static:active {
  transform: none;
  box-shadow: var(--shadow-card);
}

.service-card.card-edu {
  border-left-color: #8d5b39;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 36rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--c-text);
}

.card-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
  white-space: nowrap;
  line-height: 1.2;
  display: inline-block;
}

.card-status.status-ok {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.card-status.status-warning {
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
}

.card-body {
  margin-bottom: 16rpx;
  padding: 20rpx;
  background: rgba(255, 251, 245, 0.9);
  border-radius: 12rpx;
  border: 1rpx solid rgba(40, 38, 34, 0.08);
}

.profile-placeholder {
  margin-bottom: 0;
}

.profile-placeholder-text {
  font-size: 26rpx;
  color: var(--c-text-2);
  line-height: 1.55;
}

.health-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.health-cell {
  box-sizing: border-box;
  width: 50%;
  padding: 10rpx;
  display: flex;
  flex-direction: column;
}

.health-cell.span-2 {
  width: 100%;
}

.health-cell-empty {
  pointer-events: none;
}

.health-label {
  font-size: 24rpx;
  color: var(--c-text-3);
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.health-value {
  font-size: 28rpx;
  color: var(--c-text);
  line-height: 1.5;
  word-break: break-word;
}

.change-summary {
  margin-top: 14rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(40, 38, 34, 0.18);
}

.change-title {
  font-size: 25rpx;
  color: #3f372f;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.change-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
}

.change-label {
  font-size: 23rpx;
  color: var(--c-text-2);
}

.change-value {
  font-size: 24rpx;
  color: var(--c-text);
  font-weight: 500;
}

.evaluation-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.evaluation-time {
  font-size: 26rpx;
  color: var(--c-text);
}

.evaluation-hint {
  font-size: 24rpx;
  color: #a75f30;
}

.plan-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plan-title {
  font-size: 26rpx;
  color: var(--c-text);
}

.plan-status {
  font-size: 24rpx;
  color: var(--c-primary);
  background: rgba(45, 106, 79, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(40, 38, 34, 0.08);
}

.card-action {
  font-size: 26rpx;
  color: var(--c-primary);
  font-weight: 500;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 20rpx;
  display: block;
}

.service-history {
  padding: 8rpx 20rpx 30rpx;
}

.history-list {
  background: var(--c-surface);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.history-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 32rpx;
  margin-top: 4rpx;
}

.history-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-title {
  font-size: 28rpx;
  color: var(--c-text);
}

.history-time {
  font-size: 24rpx;
  color: var(--c-text-3);
}

.empty-text {
  text-align: center;
  font-size: 28rpx;
  color: var(--c-text-3);
  padding: 40rpx 0;
}