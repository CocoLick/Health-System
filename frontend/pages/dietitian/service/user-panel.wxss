.user-panel {
  min-height: 100vh;
  background: linear-gradient(145deg, #f8f9fa 0%, #e9ecef 100%);
  padding-bottom: 40rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx 22rpx 12rpx;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-side {
  min-width: 200rpx;
  max-width: 220rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.header-side-left {
  justify-content: flex-start;
}

.header-side-right {
  justify-content: flex-end;
}

.back-btn {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 22rpx 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(61, 58, 54, 0.06);
}

.back-btn-hover {
  background: rgba(61, 58, 54, 0.11);
}

.back-chevron {
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
  font-size: 44rpx;
  line-height: 44rpx;
  font-weight: 300;
  color: #3d3a36;
}

.back-text {
  flex-shrink: 0;
  font-size: 28rpx;
  line-height: 44rpx;
  color: #5c5348;
  font-weight: 500;
}

.panel-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  min-width: 0;
}

.user-info-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.user-avatar-large {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: 600;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.user-meta {
  font-size: 24rpx;
  color: #6c757d;
}

.service-cards {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border-left: 8rpx solid #dee2e6;
  transition: all 0.3s ease;
}

.service-card.card-ok {
  border-left-color: #4caf50;
}

.service-card.card-warning {
  border-left-color: #ff9800;
}

.service-card:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.service-card.card-static:active {
  transform: none;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.service-card.card-edu {
  border-left-color: #c4a882;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 36rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
  white-space: nowrap;
  line-height: 1.2;
  display: inline-block;
}

.card-status.status-ok {
  background: #d4edda;
  color: #155724;
}

.card-status.status-warning {
  background: #fff3cd;
  color: #856404;
}

.card-body {
  margin-bottom: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.profile-placeholder {
  margin-bottom: 0;
}

.profile-placeholder-text {
  font-size: 26rpx;
  color: #868e96;
  line-height: 1.55;
}

.health-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.health-cell {
  box-sizing: border-box;
  width: 50%;
  padding: 10rpx;
  display: flex;
  flex-direction: column;
}

.health-cell.span-2 {
  width: 100%;
}

.health-cell-empty {
  pointer-events: none;
}

.health-label {
  font-size: 24rpx;
  color: #868e96;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.health-value {
  font-size: 28rpx;
  color: #212529;
  line-height: 1.5;
  word-break: break-word;
}

.change-summary {
  margin-top: 14rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #d6d6d6;
}

.change-title {
  font-size: 25rpx;
  color: #4d3d2e;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.change-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
}

.change-label {
  font-size: 23rpx;
  color: #7a7268;
}

.change-value {
  font-size: 24rpx;
  color: #2f2a24;
  font-weight: 500;
}

.evaluation-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.evaluation-time {
  font-size: 26rpx;
  color: #1a1a1a;
}

.evaluation-hint {
  font-size: 24rpx;
  color: #ff9800;
}

.plan-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plan-title {
  font-size: 26rpx;
  color: #1a1a1a;
}

.plan-status {
  font-size: 24rpx;
  color: #4caf50;
  background: #d4edda;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-action {
  font-size: 26rpx;
  color: #2196f3;
  font-weight: 500;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  display: block;
}

.service-history {
  padding: 8rpx 20rpx 30rpx;
}

.history-list {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.history-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 32rpx;
  margin-top: 4rpx;
}

.history-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-title {
  font-size: 28rpx;
  color: #1a1a1a;
}

.history-time {
  font-size: 24rpx;
  color: #adb5bd;
}

.empty-text {
  text-align: center;
  font-size: 28rpx;
  color: #adb5bd;
  padding: 40rpx 0;
}