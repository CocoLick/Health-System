<view class="container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">膳食计划管理</view>
    <view class="header-right"></view>
  </view>

  <!-- 用户信息 -->
  <view class="user-info">
    <view class="user-avatar">{{userInfo.usernameInitial}}</view>
    <view class="user-details">
      <view class="user-name">{{userInfo.username}}</view>
      <view class="user-stats">
        <view class="stat-item">
          <view class="stat-label">身高</view>
          <view class="stat-value">{{userInfo.healthData.height}}cm</view>
        </view>
        <view class="stat-item">
          <view class="stat-label">体重</view>
          <view class="stat-value">{{userInfo.healthData.weight}}kg</view>
        </view>

      </view>
    </view>
  </view>

  <!-- 计划基本信息 -->
  <view class="plan-info">
    <view class="section-title">计划基本信息</view>
    <view class="form-item">
      <view class="form-label">计划标题</view>
      <input class="form-input" placeholder="请输入计划标题" value="{{planInfo.title}}" bindinput="bindPlanInfo" data-field="title"/>
    </view>
    <view class="form-item">
      <view class="form-label">计划周期</view>
      <input class="form-input" type="number" placeholder="请输入天数" value="{{planInfo.duration}}" bindinput="bindPlanInfo" bindblur="bindPlanBlur" data-field="duration"/>
    </view>
    <view class="form-item">
      <view class="form-label">计划开始时间</view>
      <picker class="form-picker" mode="date" start="{{today}}" bindchange="bindStartDateChange">
        <view class="picker-view">
          {{planInfo.startDate || '请选择开始日期'}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="ai-actions">
      <button class="ai-draft-btn" bindtap="openAIDraftModal">智能生成初稿</button>
      <button class="ai-optimize-btn" bindtap="openAIOptimizeModal">智能优化建议</button>
    </view>
  </view>

  <!-- 计划编辑 -->
  <view class="plan-days">
    <view class="section-title">{{planInfo.duration}}天计划编辑</view>
    <view class="day-tabs">
      <view
        class="day-tab {{currentDay === day.dayIndex ? 'active' : ''}}"
        wx:for="{{planDays}}"
        wx:for-item="day"
        wx:for-index="idx"
        wx:key="dayIndex"
        bindtap="switchDay"
        data-day="{{day.dayIndex}}"
      >
        第{{day.dayIndex}}天
      </view>
    </view>
    <view class="day-content">
      <view class="meals-list">
        <view class="meal-item" wx:for="{{currentDayMeals}}" wx:for-item="meal" wx:for-index="mealIndex" wx:key="type">
          <view class="meal-header">
            <view class="meal-type">{{meal.type}}</view>
            <view class="meal-time">{{meal.time}}</view>
            <view class="meal-calories">{{meal.calories}}kcal</view>
          </view>
          <view class="meal-foods">
            <view class="food-item" wx:for="{{meal.foods}}" wx:for-item="food" wx:for-index="foodIndex" wx:key="index">
              <view class="food-name">{{food.name}}</view>
              <view class="food-amount">{{food.amount}}</view>
              <view class="food-calories">{{food.calories}}kcal</view>
              <view class="food-actions">
                <button class="action-btn delete-btn" bindtap="deleteFood" data-meal-index="{{mealIndex}}" data-food-index="{{foodIndex}}">删除</button>
              </view>
            </view>
            <button class="add-food-btn" bindtap="addFood" data-meal-index="{{mealIndex}}">添加食物</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button class="action-btn save-btn" bindtap="savePlan">保存计划</button>
    <button class="action-btn publish-btn" bindtap="publishPlan">发布计划</button>
  </view>

  <!-- 食物选择模态框 -->
  <view class="modal {{showFoodModal ? 'show' : ''}}" catchtap="closeFoodModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">选择食物</view>
        <view class="modal-close" bindtap="closeFoodModal">×</view>
      </view>
      <view class="modal-body">
        <view class="search-box">
          <input class="search-input" placeholder="搜索食物" value="{{searchKeyword}}" bindinput="bindSearchKeyword"/>
        </view>
        <!-- 搜索结果 -->
        <view class="search-results" wx:if="{{showSearchResults}}">
          <view wx:for="{{searchResults}}" wx:key="index" class="search-result-item" bindtap="selectIngredient" data-ingredient="{{item}}">
            <view class="result-name">{{item.name}}</view>
            <view class="result-info">
              <text class="result-calorie">{{item.calorie_100g || 0}}kcal/100g</text>
            </view>
          </view>
        </view>
        <!-- 食材分类（可选） -->
        <view class="ingredient-categories" wx:if="{{!showSearchResults && ingredients.length > 0}}">
          <view class="category-title">常用食材</view>
          <view class="ingredient-grid">
            <view wx:for="{{ingredients.slice(0, 9)}}" wx:key="index" class="ingredient-item" bindtap="selectIngredient" data-ingredient="{{item}}">
            <view class="ingredient-item-inner">
              <view class="ingredient-name">{{item.name}}</view>
              <view class="ingredient-calorie">{{item.calorie_100g || 0}}kcal/100g</view>
            </view>
          </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 食物用量设置模态框 -->
  <view class="modal {{showAmountModal ? 'show' : ''}}" catchtap="closeAmountModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">设置用量</view>
        <view class="modal-close" bindtap="closeAmountModal">×</view>
      </view>
      <view class="modal-body">
        <view class="amount-info">
          <view class="amount-food-name">{{selectedFood.name}}</view>
          <view class="amount-calories">{{selectedFood.calories || 0}}kcal/100g</view>
        </view>
        <view class="amount-input-row">
          <input class="form-input amount-input" type="number" placeholder="数量" value="{{foodAmount}}" bindinput="bindFoodAmount" />
          <picker class="unit-picker" mode="selector" range="{{unitOptions}}" value="{{unitIndex}}" bindchange="changeUnit">
            <view class="unit-display">
              <text class="unit-text">{{foodUnit}}</text>
              <text class="unit-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="gram-hint" wx:if="{{currentIngredient}}">
          <text>≈ {{foodAmount * gramPerUnit}}克</text>
        </view>
        <button class="action-btn confirm-btn" bindtap="confirmFoodAmount">确认</button>
      </view>
    </view>
  </view>

  <!-- 智能初稿生成模态框 -->
  <view class="modal {{showAIDraftModal ? 'show' : ''}}" catchtap="closeAIDraftModal">
    <view class="modal-content ai-draft-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">智能生成初稿</view>
        <view class="modal-close" bindtap="closeAIDraftModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <view class="form-label">膳食目标</view>
          <view class="goal-options">
            <view class="goal-tag {{aiForm.dietGoal === 'weight_loss' ? 'active' : ''}}" bindtap="selectAIDietGoal" data-goal="weight_loss">减脂</view>
            <view class="goal-tag {{aiForm.dietGoal === 'muscle_gain' ? 'active' : ''}}" bindtap="selectAIDietGoal" data-goal="muscle_gain">增肌</view>
            <view class="goal-tag {{aiForm.dietGoal === 'maintenance' ? 'active' : ''}}" bindtap="selectAIDietGoal" data-goal="maintenance">维持健康</view>
            <view class="goal-tag {{aiForm.dietGoal === 'other' ? 'active' : ''}}" bindtap="selectAIDietGoal" data-goal="other">其他</view>
          </view>
          <input wx:if="{{aiForm.dietGoal === 'other'}}" class="form-input" placeholder="请输入具体目标" value="{{aiForm.otherGoal}}" bindinput="bindAIField" data-field="otherGoal"/>
        </view>
        <view class="form-item">
          <view class="form-label">活动水平</view>
          <picker class="form-picker" mode="selector" range="{{['久坐','轻度活动','中度活动','高度活动']}}" value="{{aiForm.activityLevel === 'sedentary' ? 0 : aiForm.activityLevel === 'lightly_active' ? 1 : aiForm.activityLevel === 'very_active' ? 3 : 2}}" bindchange="bindAIActivityChange">
            <view class="picker-view">
              {{aiForm.activityLevel === 'sedentary' ? '久坐' : aiForm.activityLevel === 'lightly_active' ? '轻度活动' : aiForm.activityLevel === 'very_active' ? '高度活动' : '中度活动'}}
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="form-item">
          <view class="form-label">疾病情况</view>
          <textarea class="form-textarea" placeholder="如：高血压、糖尿病等" value="{{aiForm.disease}}" bindinput="bindAIField" data-field="disease"/>
        </view>
        <view class="form-item">
          <view class="form-label">过敏食物</view>
          <textarea class="form-textarea" placeholder="如：海鲜、花生等" value="{{aiForm.allergy}}" bindinput="bindAIField" data-field="allergy"/>
        </view>
        <view class="form-item">
          <view class="form-label">其他需求</view>
          <textarea class="form-textarea" placeholder="如：口味偏好、忌口、预算等" value="{{aiForm.demand}}" bindinput="bindAIField" data-field="demand"/>
        </view>
        <button class="ai-generate-btn" loading="{{aiGeneratingDraft}}" disabled="{{aiGeneratingDraft}}" bindtap="generateAIDraft">生成初稿</button>
      </view>
    </view>
  </view>

  <!-- 智能优化建议（身体变化 + 反馈 + 说明） -->
  <view class="modal {{showAIOptimizeModal ? 'show' : ''}}" catchtap="closeAIOptimizeModal">
    <view class="modal-content ai-draft-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">智能优化建议</view>
        <view class="modal-close" bindtap="closeAIOptimizeModal">×</view>
      </view>
      <view class="modal-body">
        <view class="optimize-hint" wx:if="{{optimizeChangeHint}}">{{optimizeChangeHint}}</view>
        <view class="form-item">
          <view class="form-label">规划师补充（可选）</view>
          <textarea class="form-textarea" placeholder="如：希望减少主食、增加蛋白等" value="{{optimizePlannerNote}}" bindinput="bindOptimizePlannerNote"/>
        </view>
        <view class="form-item" wx:if="{{optimizeFeedbackList.length}}">
          <view class="form-label">纳入的用户反馈（可选勾选）</view>
          <view class="feedback-pick-list">
            <view
              class="feedback-pick-item {{item.checked ? 'checked' : ''}}"
              wx:for="{{optimizeFeedbackList}}"
              wx:key="feedback_id"
              bindtap="toggleOptimizeFeedback"
              data-id="{{item.feedback_id}}"
            >
              <text class="feedback-pick-title">{{item.title}}</text>
              <text class="feedback-pick-preview">{{item.content_preview}}</text>
            </view>
          </view>
        </view>
        <view class="form-item muted" wx:else>
          <text>暂无该用户的待选反馈，将使用近期反馈由服务端自动选取。</text>
        </view>
        <button class="ai-generate-btn" loading="{{aiOptimizing}}" disabled="{{aiOptimizing}}" bindtap="generateAIOptimizeDraft">生成优化草案</button>
      </view>
    </view>
  </view>

  <!-- 智能优化结果：分节分点，可滚动 -->
  <view
    class="modal optimize-result-overlay {{showOptimizeResultModal ? 'show' : ''}}"
    catchtap="dismissOptimizeResult"
  >
    <view class="modal-content optimize-result-modal" catchtap="stopPropagation">
      <view class="optimize-result-top">
        <view>
          <view class="optimize-result-h1">智能优化说明</view>
          <view class="optimize-result-sub">草案已加载到下方「各日计划」，审阅后再保存/发布</view>
        </view>
        <view class="modal-close" catchtap="dismissOptimizeResult">×</view>
      </view>
      <view class="optimize-result-meta" wx:if="{{optimizeResultSourceLabel}}">
        <text class="optimize-result-tag">{{optimizeResultSourceLabel}}</text>
      </view>
      <scroll-view scroll-y class="optimize-result-scroll" show-scrollbar="{{true}}">
        <view
          class="optimize-result-section"
          wx:for="{{optimizeResultSections}}"
          wx:for-item="sec"
          wx:key="key"
        >
          <view class="optimize-result-sec-title">{{sec.title}}</view>
          <view
            class="optimize-result-line"
            wx:for="{{sec.items}}"
            wx:for-item="line"
            wx:for-index="li"
            wx:key="li"
          >· {{line}}</view>
        </view>
      </scroll-view>
      <view class="optimize-result-footer">
        <button class="optimize-result-btn" type="default" catchtap="dismissOptimizeResult">我知道了</button>
      </view>
    </view>
  </view>
</view>