.confirm-btn:hover {
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
  transform: translateY(-2rpx);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .user-stats {
    gap: 20rpx;
  }
  
  .stat-value {
    font-size: 20rpx;
  }
  
  .stat-label {
    font-size: 18rpx;
  }
  
  .day-tab {
    min-width: 70rpx;
    font-size: 20rpx;
  }
  
  .meal-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 5rpx;
  }
  
  .meal-time {
    margin-left: 0;
  }
  
  .meal-calories {
    margin-left: 0;
  }
}
