.container {
  min-height: 100vh;
  background: transparent;
  padding: 18rpx 22rpx 130rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 86rpx;
  padding: 0 18rpx;
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-radius: 16rpx;
  box-shadow: var(--shadow-card);
  position: sticky;
  top: 10rpx;
  z-index: 80;
  margin-bottom: 20rpx;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(45, 106, 79, 0.1);
}

.back-icon {
  font-size: 30rpx;
  color: var(--c-primary);
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text);
}

.header-right {
  width: 56rpx;
}

.user-info,
.plan-info,
.plan-days,
.nutrition-ratio,
.modal-content,
.search-input,
.search-results,
.ingredient-item-inner,
.unit-picker {
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-radius: 16rpx;
  box-shadow: var(--shadow-card);
}

.user-info,
.plan-info,
.plan-days,
.nutrition-ratio {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 10rpx;
}

.user-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 22rpx;
  color: var(--c-text-3);
}

.stat-value {
  font-size: 24rpx;
  color: var(--c-text);
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 18rpx;
}

.form-item {
  margin-bottom: 18rpx;
}

.form-item.muted {
  font-size: 24rpx;
  color: var(--c-text-3);
  line-height: 1.5;
}

.form-label {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin-bottom: 8rpx;
  display: block;
}

.form-input,
.form-picker,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--c-border);
  border-radius: 12rpx;
  background: #fffcf8;
  color: var(--c-text);
}

.form-input {
  height: 78rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
}

.form-picker {
  min-height: 78rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--c-text-2);
}

.picker-view {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 18rpx;
  color: var(--c-text-3);
}

.form-textarea {
  min-height: 128rpx;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.ai-actions {
  display: flex;
  gap: 12rpx;
}

.ai-draft-btn,
.ai-optimize-btn {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.ai-draft-btn {
  background: rgba(45, 106, 79, 0.1);
  color: var(--c-primary);
}

.ai-optimize-btn {
  background: var(--c-primary);
  color: #fff;
}

.ai-optimize-btn::after,
.ai-draft-btn::after,
.ai-generate-btn::after,
.optimize-result-btn::after,
.confirm-btn::after,
.save-btn::after,
.publish-btn::after,
.add-food-btn::after,
.action-btn::after {
  border: none;
}

.optimize-hint {
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.feedback-pick-list {
  max-height: 360rpx;
  overflow-y: auto;
}

.feedback-pick-item {
  border: 1rpx solid var(--c-border);
  border-radius: 10rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 10rpx;
  background: #fffcf8;
}

.feedback-pick-item.checked {
  border-color: rgba(45, 106, 79, 0.38);
  background: rgba(45, 106, 79, 0.08);
}

.feedback-pick-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
}

.feedback-pick-preview {
  display: block;
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goal-options {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.goal-tag {
  padding: 10rpx 18rpx;
  border: 1rpx solid var(--c-border);
  border-radius: 999rpx;
  background: #fffcf8;
  color: var(--c-text-2);
  font-size: 22rpx;
}

.goal-tag.active {
  background: rgba(45, 106, 79, 0.12);
  border-color: rgba(45, 106, 79, 0.35);
  color: var(--c-primary);
}

.ai-generate-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: var(--c-primary);
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
  margin-top: 18rpx;
}

.plan-days {
  margin-bottom: 18rpx;
}

.day-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.day-tab {
  min-width: 104rpx;
  height: 60rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--c-border);
  background: #fffcf8;
  color: var(--c-text-2);
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-tab.active {
  background: rgba(45, 106, 79, 0.14);
  color: var(--c-primary);
  border-color: rgba(45, 106, 79, 0.35);
  font-weight: 600;
}

.day-content {
  min-height: 360rpx;
}

.meals-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-item {
  border: 1rpx solid var(--c-border);
  border-radius: 14rpx;
  padding: 16rpx;
  background: #fffcf8;
}

.meal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.meal-type {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--c-text);
}

.meal-time {
  font-size: 22rpx;
  color: var(--c-text-3);
}

.meal-calories {
  font-size: 22rpx;
  color: var(--c-primary);
  background: rgba(45, 106, 79, 0.12);
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.meal-foods {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.food-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx;
  border-radius: 10rpx;
  background: #fff;
  border: 1rpx solid rgba(40, 38, 34, 0.08);
}

.food-name {
  flex: 1;
  font-size: 24rpx;
  color: var(--c-text);
}

.food-amount,
.food-calories {
  font-size: 20rpx;
  color: var(--c-text-2);
}

.food-calories {
  color: var(--c-primary);
}

.food-actions {
  display: flex;
  gap: 8rpx;
}

.action-btn {
  border-radius: 999rpx;
  border: none;
  padding: 8rpx 14rpx;
  font-size: 20rpx;
  line-height: 1.3;
}

.delete-btn {
  background: rgba(192, 123, 79, 0.15);
  color: #8d4d27;
}

.add-food-btn {
  width: 100%;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 12rpx;
  border: 1rpx dashed rgba(45, 106, 79, 0.34);
  background: rgba(45, 106, 79, 0.08);
  color: var(--c-primary);
  font-size: 24rpx;
  margin-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 18rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 248, 0.96);
  border-top: 1rpx solid var(--c-border);
  display: flex;
  gap: 12rpx;
}

.save-btn,
.publish-btn {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
}

.save-btn {
  background: #f3eee8;
  color: var(--c-text-2);
  border: 1rpx solid var(--c-border);
}

.publish-btn {
  background: var(--c-primary);
  color: #fff;
  border: none;
}

.modal {
  position: fixed;
  inset: 0;
  background-color: rgba(24, 22, 20, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.18s var(--ease-natural);
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 88%;
  max-width: 640rpx;
  overflow: hidden;
  animation: modalIn 0.22s var(--ease-natural);
}

@keyframes modalIn {
  from {
    transform: translateY(18rpx) scale(0.98);
    opacity: 0;
  }
  to {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
}

.modal-close {
  font-size: 40rpx;
  color: var(--c-text-3);
}

.modal-body {
  padding: 18rpx 20rpx 20rpx;
  max-height: 62vh;
  overflow-y: auto;
}

.search-box {
  margin-bottom: 16rpx;
}

.search-input {
  width: 100%;
  height: 78rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.search-results {
  margin-top: 14rpx;
  max-height: 420rpx;
  overflow-y: auto;
}

.search-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 16rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.search-result-item:last-child {
  border-bottom: none;
}

.result-name {
  font-size: 24rpx;
  color: var(--c-text);
}

.result-calorie {
  font-size: 20rpx;
  color: var(--c-text-2);
  background: rgba(45, 106, 79, 0.08);
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
}

.ingredient-categories {
  margin-top: 16rpx;
}

.category-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 10rpx;
}

.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.ingredient-item {
  width: 31%;
}

.ingredient-item-inner {
  padding: 12rpx;
  text-align: center;
}

.ingredient-name {
  font-size: 22rpx;
  color: var(--c-text);
  margin-bottom: 6rpx;
}

.ingredient-calorie {
  font-size: 20rpx;
  color: var(--c-text-2);
}

.amount-info {
  margin-bottom: 16rpx;
}

.amount-food-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 8rpx;
}

.amount-calories {
  font-size: 22rpx;
  color: var(--c-text-2);
}

.amount-input-row {
  display: flex;
  gap: 10rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.amount-input {
  flex: 1;
}

.unit-picker {
  width: 150rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unit-display {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.unit-text {
  font-size: 24rpx;
  color: var(--c-text);
}

.unit-arrow {
  font-size: 18rpx;
  color: var(--c-text-3);
}

.gram-hint {
  text-align: center;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--c-text-3);
}

.confirm-btn {
  width: 100%;
  height: 78rpx;
  line-height: 78rpx;
  background: var(--c-primary);
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
  margin-top: 14rpx;
}

.ai-draft-modal {
  max-height: 80vh;
}

.optimize-result-overlay {
  z-index: 1100;
}

.optimize-result-modal {
  width: 90%;
  max-width: 640rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  overflow: hidden;
  border-radius: 16rpx;
}

.optimize-result-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.optimize-result-h1 {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
}

.optimize-result-sub {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 8rpx;
}

.optimize-result-meta {
  padding: 10rpx 20rpx 0;
}

.optimize-result-tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--c-primary);
  background: rgba(45, 106, 79, 0.1);
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
}

.optimize-result-scroll {
  height: 400rpx;
  max-height: 44vh;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
}

.optimize-result-section {
  margin-bottom: 12rpx;
  padding: 12rpx;
  background: #fffcf8;
  border-radius: 12rpx;
  border: 1rpx solid var(--c-border);
}

.optimize-result-sec-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 8rpx;
}

.optimize-result-line {
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.55;
  margin-bottom: 8rpx;
}

.optimize-result-footer {
  padding: 12rpx 16rpx 16rpx;
  border-top: 1rpx solid rgba(40, 38, 34, 0.08);
  background: #fff;
}

.optimize-result-btn {
  width: 100%;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 12rpx;
  background: var(--c-primary);
  color: #fff;
  font-size: 28rpx;
}
