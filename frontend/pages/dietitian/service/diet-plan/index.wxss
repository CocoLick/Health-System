  margin-bottom: 24rpx;
}

.amount-food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.amount-calories {
  font-size: 22rpx;
  color: #666;
  background: #f9f9f9;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.amount-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 24rpx;
}

.amount-input {
  flex: 1;
}

.unit-picker {
  width: 140rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.3s;
}

.unit-picker:focus {
  border-color: #667eea;
}

.unit-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.unit-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.unit-arrow {
  font-size: 18rpx;
  color: #667eea;
}

.gram-hint {
  text-align: center;
  margin-top: 24rpx;
  font-size: 22rpx;
