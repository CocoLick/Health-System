.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 顶部导航栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background-color: #fff;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  position: sticky;
  top: 0;
  z-index: 100;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: #667eea;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 60rpx;
}

/* 用户信息 */
.user-info {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.user-stats {
  display: flex;
  gap: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 24rpx;
  font-weight: 500;
  color: #667eea;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
}

/* 计划基本信息 */
.plan-info {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 24rpx;
  position: relative;
}

.form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #333;
  transition: border-color 0.3s;
}

.form-input:focus {
  border-color: #667eea;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #333;
  transition: border-color 0.3s;
}

.form-picker:focus {
  border-color: #667eea;
}

.picker-arrow {
  font-size: 20rpx;
  color: #667eea;
}

/* 营养比例设置 */
.nutrition-ratio {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.ratio-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.ratio-label {
  width: 120rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.ratio-input {
  flex: 1;
  display: flex;
  align-items: center;
}

.ratio-input .form-input {
  flex: 1;
  margin-right: 16rpx;
}

.ratio-unit {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.ratio-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

.ratio-status {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.ratio-status.valid {
  background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.ratio-status.invalid {
  background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(244, 67, 54, 0.3);
}

/* 7天计划编辑 */
.plan-days {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.day-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  padding-bottom: 12rpx;
}

.day-tab {
  flex: 1;
  min-width: 90rpx;
  height: 60rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  color: #666;
  background: #f9f9f9;
  transition: all 0.3s;
}

.day-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: #667eea;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.day-content {
  min-height: 400rpx;
}

.meals-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.meal-item {
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 24rpx;
  transition: all 0.3s;
}

.meal-item:hover {
  border-color: #667eea;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.1);
}

.meal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.meal-type {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.meal-time {
  font-size: 22rpx;
  color: #666;
}

.meal-calories {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.meal-foods {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.food-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

.food-name {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.food-amount {
  font-size: 20rpx;
  color: #666;
  margin: 0 12rpx;
}

.food-calories {
  font-size: 20rpx;
  color: #667eea;
  margin: 0 12rpx;
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.food-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  border: none;
  cursor: pointer;
  transition: all 0.3s;
}

.delete-btn {
  background: #ffebee;
  color: #d32f2f;
}

.delete-btn:hover {
  background: #ef5350;
  color: #fff;
}

.add-food-btn {
  width: 100%;
  height: 70rpx;
  background: #f0f8ff;
  border: 2rpx dashed #667eea;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  transition: all 0.3s;
}

.add-food-btn:hover {
  background: #e3f2fd;
  border-style: solid;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  gap: 16rpx;
}

.save-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #e0e0e0;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.save-btn:hover {
  background: #e0e0e0;
}

.publish-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.publish-btn:hover {
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.4);
  transform: translateY(-2rpx);
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

@keyframes modalIn {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #667eea;
  cursor: pointer;
  transition: all 0.3s;
}

.modal-close:hover {
  color: #764ba2;
  transform: rotate(90deg);
}

.modal-body {
  padding: 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.search-box {
  margin-bottom: 24rpx;
  position: relative;
}

.search-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #333;
  transition: border-color 0.3s;
}

.search-input:focus {
  border-color: #667eea;
}

/* 搜索结果 */
.search-results {
  margin-top: 20rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.search-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
}

.result-name {
  font-size: 32rpx;
  color: #333;
}

.result-info {
  display: flex;
  align-items: center;
}

.result-calorie {
  font-size: 28rpx;
  color: #999;
  margin-right: 10rpx;
}

/* 食材分类 */
.ingredient-categories {
  margin-top: 20rpx;
}

.category-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  padding: 0 20rpx;
}

.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx;
}

.ingredient-item {
  width: 33.33%;
  padding: 10rpx;
  box-sizing: border-box;
  cursor: pointer;
}

.ingredient-item-inner {
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 15rpx;
  text-align: center;
}

.ingredient-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.ingredient-calorie {
  font-size: 24rpx;
  color: #999;
}

/* 用量设置 */
.amount-info {
  margin-bottom: 20rpx;
}

.amount-food-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.amount-calories {
  font-size: 20rpx;
  color: #666;
}

.amount-input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.amount-input {
  flex: 1;
  margin-right: 20rpx;
}

.unit-picker {
  width: 150rpx;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unit-display {
  display: flex;
  align-items: center;
}

.unit-text {
  font-size: 32rpx;
  color: #333;
  margin-right: 10rpx;
}

.unit-arrow {
  font-size: 24rpx;
  color: #999;
}

.gram-hint {
  text-align: center;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.confirm-btn {
  width: 100%;
  height: 50rpx;
  background-color: #4CAF50;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 搜索结果 */
.search-results {
  margin-top: 24rpx;
  max-height: 500rpx;
  overflow-y: auto;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.search-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: background-color 0.3s;
}

.search-result-item:hover {
  background-color: #f9f9f9;
}

.result-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.result-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.result-calorie {
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: #1976d2;
  font-size: 18rpx;
  font-weight: 500;
}

/* 食材分类 */
.ingredient-categories {
  margin-top: 24rpx;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
