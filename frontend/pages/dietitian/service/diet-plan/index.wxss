  width: 31%;
  padding: 0;
  box-sizing: border-box;
  cursor: pointer;
}

.ingredient-item-inner {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  transition: all 0.3s;
  border: 2rpx solid #f0f0f0;
}

.ingredient-item-inner:hover {
  background: #e3f2fd;
  border-color: #667eea;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.ingredient-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.ingredient-calorie {
  font-size: 20rpx;
  color: #667eea;
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

/* 用量设置 */
