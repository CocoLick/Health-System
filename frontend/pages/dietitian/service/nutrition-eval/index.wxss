.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: #fff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.sub {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.section {
  margin: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.hint {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.ctx-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  margin-bottom: 20rpx;
}

.ctx-row .label {
  font-size: 24rpx;
  color: #868e96;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.ctx-value {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  line-height: 1.55;
  word-break: break-word;
}

.field-label {
  font-size: 24rpx;
  color: #666;
  margin: 16rpx 0 8rpx;
}

.input, .textarea {
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

/* 与其它 .input 字号、内边距一致，仅保证整块可点、单行易读 */
.input-energy {
  display: block;
  width: 100% !important;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.5;
  padding: 16rpx;
  min-height: 72rpx;
}

.textarea {
  min-height: 140rpx;
}

.textarea-lg {
  min-height: 200rpx;
}

.picker {
  padding: 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.submit-bar {
  padding: 24rpx 30rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #4caf50, #43a047);
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  padding: 24rpx;
  border-radius: 44rpx;
}
