.page {
  min-height: 100vh;
  background: transparent;
  padding: 10rpx 0 40rpx;
}

.header {
  background: transparent;
  padding: 20rpx 30rpx 12rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--c-text);
}

.sub {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin-top: 8rpx;
  line-height: 1.5;
}

.section {
  margin: 20rpx;
  background: var(--c-surface);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.hint {
  font-size: 22rpx;
  color: var(--c-text-2);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.ctx-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  margin-bottom: 20rpx;
}

.ctx-row .label {
  font-size: 24rpx;
  color: var(--c-text-3);
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.ctx-value {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--c-text);
  line-height: 1.55;
  word-break: break-word;
}

.field-label {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin: 16rpx 0 8rpx;
  font-weight: 600;
}

.input, .textarea {
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  padding: 16rpx;
  background: #fffcf8;
  border-radius: 12rpx;
  border: 1rpx solid var(--c-border);
}

/* 与其它 .input 字号、内边距一致，仅保证整块可点、单行易读 */
.input-energy {
  display: block;
  width: 100% !important;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.5;
  padding: 16rpx;
  min-height: 72rpx;
}

.textarea {
  min-height: 140rpx;
}

.textarea-lg {
  min-height: 200rpx;
}

.picker {
  padding: 16rpx;
  background: #fffcf8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--c-text);
  border: 1rpx solid var(--c-border);
}

.submit-bar {
  padding: 24rpx 30rpx;
}

.submit-btn {
  background: var(--c-primary);
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  padding: 24rpx;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 16rpx rgba(45, 106, 79, 0.2);
}

.d7-hint {
  font-size: 22rpx;
  color: var(--c-text-2);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.d7-muted {
  color: var(--c-text-3);
}

.d7-warn {
  color: #b45309;
}

.d7-filters {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.d7-filter {
  flex: 1;
  min-width: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.d7-filter-label {
  font-size: 22rpx;
  color: var(--c-text-3);
  font-weight: 600;
}

.d7-picker-line {
  font-size: 26rpx;
  color: var(--c-text);
  background: #fffcf8;
  border: 1rpx solid var(--c-border);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

.d7-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.d7-row:active {
  opacity: 0.75;
}

.d7-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.d7-dt {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
}

.d7-sub {
  font-size: 22rpx;
  color: var(--c-text-3);
}

.d7-right-macro {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  text-align: right;
  max-width: 60%;
  flex-shrink: 0;
}

.d7-macro-k {
  font-size: 26rpx;
  color: var(--c-text-2);
  font-variant-numeric: tabular-nums;
  line-height: 1.35;
}

.d7-macro-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--c-text-3);
  line-height: 1.35;
  word-break: break-word;
  font-variant-numeric: tabular-nums;
}

.d7-macro-na {
  font-size: 26rpx;
  color: var(--c-text-3);
  padding-top: 4rpx;
}

.d7-day-total {
  padding: 12rpx 0 8rpx;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.1);
}

.d7-day-total-title {
  font-size: 22rpx;
  color: var(--c-text-3);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.d7-day-total-k {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
  line-height: 1.4;
  font-variant-numeric: tabular-nums;
}

.d7-day-total-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.45;
  font-variant-numeric: tabular-nums;
  word-break: break-word;
}

.d7-meal-macro {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--c-text-2);
  line-height: 1.45;
  font-variant-numeric: tabular-nums;
  word-break: break-word;
  padding-bottom: 4rpx;
}

.d7-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2000;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  /* 与屏幕四边留边，避免内容贴边、底部被 home indicator 裁切 */
  padding: 48rpx 40rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.d7-sheet {
  width: 100%;
  max-width: 100%;
  /* 与遮罩内边距一起，保证整卡落在可视区内 */
  max-height: 68vh;
  background: var(--c-surface);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 0 1 auto;
}

.d7-sheet-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
  flex-shrink: 0;
}

.d7-sheet-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
}

.d7-sheet-close {
  font-size: 40rpx;
  line-height: 1;
  color: var(--c-text-3);
  padding: 8rpx 12rpx;
}

.d7-body-native {
  position: relative;
  width: 100%;
  height: 50vh;
  max-height: 50vh;
  overflow: hidden;
}

.d7-body-native-inner {
  height: 100%;
  max-height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
  width: 100%;
  padding: 12rpx 0 0;
  padding-left: 28rpx;
  /* 为右侧滚动条与文字留出整列空间；长词强制换行 */
  padding-right: 16rpx;
  /* iOS 11+ safe area */
  padding-bottom: max(40rpx, constant(safe-area-inset-bottom));
  padding-bottom: max(40rpx, env(safe-area-inset-bottom));
}

.d7-meal {
  margin-top: 20rpx;
}

.d7-meal:first-child {
  margin-top: 0;
}

.d7-meal-block {
  margin-bottom: 6rpx;
}

.d7-meal-titlerow {
  width: 100%;
  box-sizing: border-box;
  padding-right: 0;
}

.d7-meal-t {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
  line-height: 1.45;
  word-wrap: break-word;
  word-break: break-all;
  padding-right: 12rpx;
}

.d7-meal-krow {
  display: block;
  margin-top: 2rpx;
  padding-left: 0;
  width: 100%;
  box-sizing: border-box;
  padding-right: 12rpx;
}

.d7-meal-k {
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.4;
}

.d7-item {
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.5;
  padding: 4rpx 0;
  padding-right: 12rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: block;
  word-wrap: break-word;
  word-break: break-all;
  overflow-wrap: break-word;
}
