.page {
  min-height: 100vh;
  background: transparent;
  padding: 10rpx 0 40rpx;
}

.header {
  background: transparent;
  padding: 20rpx 30rpx 12rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--c-text);
}

.sub {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin-top: 8rpx;
  line-height: 1.5;
}

.section {
  margin: 20rpx;
  background: var(--c-surface);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.hint {
  font-size: 22rpx;
  color: var(--c-text-2);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.ctx-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  margin-bottom: 20rpx;
}

.ctx-row .label {
  font-size: 24rpx;
  color: var(--c-text-3);
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.ctx-value {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--c-text);
  line-height: 1.55;
  word-break: break-word;
}

.field-label {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin: 16rpx 0 8rpx;
  font-weight: 600;
}

.input, .textarea {
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  padding: 16rpx;
  background: #fffcf8;
  border-radius: 12rpx;
  border: 1rpx solid var(--c-border);
}

/* 与其它 .input 字号、内边距一致，仅保证整块可点、单行易读 */
.input-energy {
  display: block;
  width: 100% !important;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.5;
  padding: 16rpx;
  min-height: 72rpx;
}

.textarea {
  min-height: 140rpx;
}

.textarea-lg {
  min-height: 200rpx;
}

.picker {
  padding: 16rpx;
  background: #fffcf8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--c-text);
  border: 1rpx solid var(--c-border);
}

.submit-bar {
  padding: 24rpx 30rpx;
}

.submit-btn {
  background: var(--c-primary);
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  padding: 24rpx;
  border-radius: 44rpx;
  box-shadow: 0 6rpx 16rpx rgba(45, 106, 79, 0.2);
}
