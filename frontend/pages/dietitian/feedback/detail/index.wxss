.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 200rpx;
  box-sizing: border-box;
  background: linear-gradient(165deg, #ebe8e4 0%, #f4f2ef 50%, #f0ece8 100%);
}

.state {
  text-align: center;
  padding: 80rpx;
  color: #8a8278;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.meta-card .row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
}

.meta-card .row:last-child {
  border-bottom: none;
}

.label {
  color: #8a8278;
}

.value {
  color: #3d3a36;
  text-align: right;
  max-width: 65%;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-tag.pending {
  background: #fff3e0;
  color: #e65100;
}

.status-tag.done {
  background: #e8f5e9;
  color: #2e7d32;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2825;
  margin-bottom: 16rpx;
}

.original {
  font-size: 28rpx;
  color: #4a4540;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #5c5348;
  margin: 8rpx 0 16rpx;
}

.msg {
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.msg-mine {
  border-left: 6rpx solid #c4a882;
}

.msg-user {
  border-left: 6rpx solid #6c9bd2;
}

.msg-head {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.msg-name {
  font-weight: 600;
  color: #3d3a36;
}

.msg-role {
  color: #8a8278;
  font-size: 22rpx;
}

.msg-time {
  margin-left: auto;
  color: #adb5bd;
  font-size: 22rpx;
}

.msg-body {
  font-size: 28rpx;
  color: #333;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.empty-replies {
  font-size: 26rpx;
  color: #adb5bd;
  padding: 24rpx 0 40rpx;
}

.reply-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(244, 242, 239, 0.96);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.reply-input {
  width: 100%;
  min-height: 120rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.reply-btn {
  background: #b8956c;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}
