.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 200rpx;
  box-sizing: border-box;
  background: transparent;
}

.state {
  text-align: center;
  padding: 80rpx;
  color: var(--c-text-3);
  font-size: 28rpx;
}

.card {
  background: var(--c-surface);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.meta-card .row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
  font-size: 26rpx;
}

.meta-card .row:last-child {
  border-bottom: none;
}

.label {
  color: var(--c-text-3);
}

.value {
  color: var(--c-text);
  text-align: right;
  max-width: 65%;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-tag.pending {
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
}

.status-tag.done {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 16rpx;
}

.original {
  font-size: 28rpx;
  color: var(--c-text);
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text-2);
  margin: 8rpx 0 16rpx;
}

.msg {
  background: var(--c-surface);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--c-border);
}

.msg-mine {
  border-left: 6rpx solid #8d5b39;
}

.msg-user {
  border-left: 6rpx solid var(--c-primary);
}

.msg-head {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.msg-name {
  font-weight: 600;
  color: var(--c-text);
}

.msg-role {
  color: var(--c-text-3);
  font-size: 22rpx;
}

.msg-time {
  margin-left: auto;
  color: var(--c-text-3);
  font-size: 22rpx;
}

.msg-body {
  font-size: 28rpx;
  color: var(--c-text);
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.empty-replies {
  font-size: 26rpx;
  color: var(--c-text-3);
  padding: 24rpx 0 40rpx;
}

.reply-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 248, 0.95);
  border-top: 1rpx solid var(--c-border);
  box-sizing: border-box;
}

.reply-input {
  width: 100%;
  min-height: 120rpx;
  background: #fffcf8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--c-border);
  box-sizing: border-box;
}

.reply-btn {
  background: var(--c-primary);
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}
