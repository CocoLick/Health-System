}

.feedback-tabs {
  display: flex;
  background: white;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.feedback-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #6c757d;
  transition: all 0.3s ease;
}

.feedback-tab.active {
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
