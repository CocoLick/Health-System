  align-items: center;
  gap: 12rpx;
}

.feedback-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.feedback-username {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.feedback-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
