.sub-tab-badge {
  background: #ff5722;
  color: white;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  font-weight: 600;
  min-width: 32rpx;
  text-align: center;
}

.sub-tab-item.active .sub-tab-badge {
  background: white;
  color: #2196f3;
