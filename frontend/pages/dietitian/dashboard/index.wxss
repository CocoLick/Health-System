.dietitian-dashboard {
  min-height: 100vh;
  background: transparent;
  padding-bottom: 140rpx;
}

.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 26rpx 18rpx;
}

.dashboard-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 248, 0.88);
  border: 1rpx solid var(--c-border);
}

.welcome-text {
  font-size: 24rpx;
  color: var(--c-text-2);
}

.user-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--c-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.custom-tab-bar {
  display: flex;
  background: rgba(255, 252, 248, 0.98);
  padding: 10rpx 8rpx 8rpx;
  padding-bottom: calc(8rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  border-top: 1rpx solid var(--c-border);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 0;
  border-radius: 12rpx;
  transition: background 0.18s var(--ease-natural);
}

.tab-item.active {
  background: rgba(45, 106, 79, 0.1);
}

.tab-icon {
  font-size: 34rpx;
}

.tab-text {
  font-size: 21rpx;
  color: var(--c-text-3);
}

.tab-item.active .tab-text {
  color: var(--c-primary);
  font-weight: 600;
}

.tab-content {
  padding: 0 22rpx 12rpx;
}

.content-panel {
  animation: fadeIn 0.24s var(--ease-natural);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stats-overview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stat-card,
.quick-btn,
.activity-list,
.notice-list,
.filter-tabs,
.sub-tabs,
.feedback-tabs,
.feedback-item,
.request-item,
.user-item,
.search-input,
.history-list,
.he-item,
.mine-menu,
.request-detail-modal,
.chart-placeholder,
.rating-card {
  background: var(--c-surface);
  border-radius: 16rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.stat-card {
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.stat-card:active,
.quick-btn:active,
.feedback-item:active,
.user-item:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-press);
}

.stat-icon {
  font-size: 42rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-icon,
.plan-icon,
.article-icon,
.feedback-icon {
  background: rgba(45, 106, 79, 0.1);
}

.stat-content {
  flex: 1;
}

.stat-number {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 4rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--c-text-2);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 14rpx;
  display: block;
}

.quick-access,
.recent-activity,
.system-notices,
.chart-section,
.request-management {
  margin-bottom: 28rpx;
}

.quick-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.quick-btn {
  padding: 24rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.btn-icon {
  font-size: 42rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
}

.activity-list,
.notice-list,
.feedback-list,
.request-list,
.user-list,
.he-list {
  padding: 14rpx 18rpx;
}

.activity-item,
.notice-item,
.history-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 4rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.activity-item:last-child,
.notice-item:last-child,
.history-item:last-child {
  border-bottom: none;
}

.activity-text,
.notice-title,
.request-user-id,
.user-name {
  display: block;
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 600;
}

.feedback-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.feedback-title-wrap {
  flex: 1;
  min-width: 0;
}

.feedback-title {
  display: block;
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.feedback-user {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.feedback-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
}

.feedback-username {
  font-size: 23rpx;
  color: var(--c-text-2);
}

.activity-time,
.notice-time,
.feedback-time,
.user-last-service,
.history-time,
.he-time {
  display: block;
  font-size: 22rpx;
  color: var(--c-text-3);
}

.notice-text,
.feedback-content,
.request-label,
.request-value,
.detail-label,
.detail-value,
.he-summary {
  color: var(--c-text-2);
}

.feedback-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.feedback-type {
  font-size: 21rpx;
  color: var(--c-primary);
  background: rgba(45, 106, 79, 0.1);
  border: 1rpx solid rgba(45, 106, 79, 0.22);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.feedback-body {
  background: rgba(45, 106, 79, 0.05);
  border-radius: 10rpx;
  padding: 12rpx;
}

.feedback-content {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--c-text-2);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-footer {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
}

.feedback-action {
  font-size: 22rpx;
  color: var(--c-primary);
  font-weight: 600;
}

.empty-text {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--c-text-3);
  padding: 32rpx 0;
}

.search-input {
  padding: 16rpx 20rpx;
  margin-bottom: 22rpx;
  font-size: 28rpx;
}

.filter-tabs,
.feedback-tabs,
.sub-tabs {
  display: flex;
  padding: 8rpx;
  margin-bottom: 22rpx;
}

.filter-tab,
.feedback-tab,
.sub-tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 8rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: var(--c-text-2);
}

.filter-tab.active,
.feedback-tab.active,
.sub-tab-item.active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
  font-weight: 700;
}

.badge,
.sub-tab-badge {
  background: rgba(192, 123, 79, 0.2);
  color: #8d4d27;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.feedback-tab.active .badge,
.sub-tab-item.active .sub-tab-badge {
  background: #fff;
  color: var(--c-primary);
}

.user-item,
.feedback-item,
.request-item {
  padding: 22rpx;
  margin-bottom: 14rpx;
}

.request-item {
  position: relative;
}

.user-avatar-small,
.feedback-avatar,
.request-avatar,
.personal-avatar-large {
  background: var(--c-primary);
}

.user-avatar-small,
.request-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.user-info-small {
  flex: 1;
  min-width: 0;
}

.user-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.user-enter-cta {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(45, 106, 79, 0.08);
  border: 1rpx solid rgba(45, 106, 79, 0.18);
  flex-shrink: 0;
}

.user-enter-text {
  font-size: 21rpx;
  color: var(--c-primary);
  font-weight: 600;
}

.user-enter-arrow {
  font-size: 24rpx;
  color: var(--c-primary);
  line-height: 1;
}

.user-status {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.user-status .status-tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  border: 1rpx solid transparent;
}

.user-status .status-tag.status-ok {
  color: #2b5f46;
  background: rgba(45, 106, 79, 0.08);
  border-color: rgba(45, 106, 79, 0.2);
}

.user-status .status-tag.status-warning {
  color: #8d4d27;
  background: rgba(192, 123, 79, 0.12);
  border-color: rgba(192, 123, 79, 0.24);
}

.status-tag,
.feedback-status,
.request-status,
.card-status,
.he-badge,
.he-tag,
.feedback-type {
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
}

.status-tag.status-ok,
.feedback-status.status-replied,
.request-status.approved,
.request-status.completed,
.he-badge.status-published {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.status-tag.status-warning,
.feedback-status.status-pending,
.request-status.pending,
.request-status.rejected,
.request-status.cancelled,
.he-badge.status-draft {
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
}

.request-status-corner {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 2;
}

.request-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(40, 38, 34, 0.08);
}

.request-main {
  flex: 1;
  min-width: 0;
}

.request-user {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.request-user-texts {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
  padding-right: 128rpx;
}

.request-time {
  font-size: 21rpx;
  color: var(--c-text-3);
}

.request-body {
  margin-bottom: 10rpx;
}

.request-meta-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.request-meta-tag {
  font-size: 21rpx;
  color: var(--c-primary);
  background: rgba(45, 106, 79, 0.1);
  border: 1rpx solid rgba(45, 106, 79, 0.22);
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.request-meta-goal {
  color: #8d4d27;
  background: rgba(192, 123, 79, 0.14);
  border-color: rgba(192, 123, 79, 0.28);
}

.request-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 10rpx 12rpx;
  background: rgba(45, 106, 79, 0.05);
  border-radius: 10rpx;
}

.request-label {
  width: auto;
  font-size: 22rpx;
  color: var(--c-text-3);
}

.request-value {
  font-size: 24rpx;
  color: var(--c-text);
  line-height: 1.45;
}

.request-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 8rpx;
}

.request-action-text {
  font-size: 22rpx;
  color: var(--c-primary);
  font-weight: 600;
}

.request-actions .action-btn,
.request-detail-modal .modal-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.request-actions .action-btn.approve,
.request-detail-modal .modal-btn.approve {
  background: rgba(45, 106, 79, 0.14);
  color: var(--c-primary);
}

.request-actions .action-btn.reject,
.request-detail-modal .modal-btn.reject {
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(26, 24, 22, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.request-detail-modal {
  width: 88%;
  max-width: 640rpx;
  max-height: 82vh;
  overflow: hidden;
  animation: riseIn 0.24s var(--ease-natural);
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 个人中心弹窗（与管理员工作台一致） */
@keyframes pc-modal-in {
  from {
    opacity: 0;
    transform: scale(0.97) translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.personal-center-modal {
  position: relative;
  width: 86%;
  max-width: 620rpx;
  overflow: hidden;
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-radius: var(--radius-lg);
  box-shadow: 0 24rpx 56rpx rgba(33, 30, 26, 0.18), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  animation: pc-modal-in 0.32s var(--ease-natural) both;
}

.personal-center-modal::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--c-primary) 0%, rgba(45, 106, 79, 0.4) 55%, rgba(192, 123, 79, 0.35) 100%);
  opacity: 0.9;
}

.pc-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 28rpx 28rpx 22rpx 32rpx;
  border-bottom: 1rpx solid var(--c-border);
}

.pc-head-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
  padding-top: 4rpx;
}

.pc-eyebrow {
  font-size: 20rpx;
  letter-spacing: 0.12em;
  color: var(--c-text-3);
}

.pc-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: 0.02em;
  line-height: 1.25;
}

.pc-close {
  width: 64rpx;
  height: 64rpx;
  margin: -4rpx -4rpx 0 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
  color: var(--c-text-3);
  background: rgba(45, 106, 79, 0.06);
  border: 1rpx solid rgba(40, 38, 34, 0.06);
  flex-shrink: 0;
  transition: background 0.2s ease, color 0.2s ease, transform 0.18s var(--ease-natural);
}

.pc-close-press {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-text-2);
  transform: scale(0.95);
}

.pc-body {
  padding: 12rpx 0 0;
}

.pc-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx 32rpx;
  text-align: center;
}

.pc-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: linear-gradient(150deg, var(--c-primary) 0%, var(--c-primary-strong) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 50rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(45, 106, 79, 0.28);
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  margin-bottom: 18rpx;
  transition: transform 0.2s var(--ease-natural);
}

.pc-avatar:active {
  transform: scale(0.98);
}

.pc-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 6rpx;
}

.pc-role {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-3);
}

.pc-list {
  padding: 0 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pc-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-press);
}

.pc-item--danger {
  border-color: rgba(154, 77, 34, 0.2);
  background: rgba(154, 77, 34, 0.05);
}

.pc-item-main {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.pc-ico {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-primary);
  background: var(--c-primary-soft);
  border: 1rpx solid rgba(45, 106, 79, 0.12);
  flex-shrink: 0;
}

.pc-ico--out {
  color: #8d4d27;
  background: rgba(154, 77, 34, 0.1);
  border-color: rgba(154, 77, 34, 0.18);
}

.pc-label {
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 500;
  flex: 1;
}

.pc-item--danger .pc-label {
  color: #7a3a18;
  font-weight: 600;
}

.pc-chev {
  font-size: 36rpx;
  line-height: 1;
  color: var(--c-text-3);
  margin-left: 8rpx;
  flex-shrink: 0;
}

.pc-item--danger .pc-chev {
  color: rgba(122, 58, 24, 0.55);
}

.pc-item-press {
  background: #efe9e1;
  box-shadow: none;
}

.pc-item--danger.pc-item-press {
  background: rgba(154, 77, 34, 0.12) !important;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
}

.modal-close {
  font-size: 44rpx;
  color: var(--c-text-3);
}

.modal-body,
.request-detail-modal .modal-body {
  padding: 20rpx 24rpx;
}

.request-detail-modal .modal-footer {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx 22rpx;
  border-top: 1rpx solid rgba(40, 38, 34, 0.08);
}

.personal-info-card {
  background: linear-gradient(155deg, #2d6a4f 0%, #3f7a60 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  color: #fdf8f1;
  box-shadow: 0 8rpx 24rpx rgba(45, 106, 79, 0.24);
  display: flex;
  gap: 20rpx;
}

.personal-avatar-large {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.32);
}

.personal-name-large {
  font-size: 36rpx;
  font-weight: 700;
}

.personal-role-large {
  display: block;
  font-size: 24rpx;
  margin-top: 4rpx;
  opacity: 0.9;
}

.personal-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.stat-item .stat-number {
  font-size: 30rpx;
  color: #fff;
}

.stat-item .stat-label {
  color: rgba(255, 255, 255, 0.84);
}

.mine-menu {
  overflow: hidden;
}

.menu-section {
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.menu-section:last-child {
  border-bottom: none;
}

.menu-section .section-title {
  font-size: 24rpx;
  color: var(--c-text-3);
  padding: 16rpx 24rpx 8rpx;
  margin-bottom: 0;
}

.menu-section .menu-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 22rpx 24rpx;
  border-top: 1rpx solid rgba(40, 38, 34, 0.08);
}

.menu-section .menu-item:active {
  background: rgba(45, 106, 79, 0.06);
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--c-text);
}

.menu-arrow {
  color: var(--c-text-3);
}

.logout-section {
  padding: 18rpx 24rpx 24rpx;
}

.logout-btn {
  border: 1rpx solid rgba(192, 123, 79, 0.34);
  color: #8d4d27;
  border-radius: 12rpx;
  padding: 18rpx;
  display: flex;
  justify-content: center;
  gap: 10rpx;
}

.logout-btn:active {
  background: rgba(192, 123, 79, 0.1);
}

.logout-icon,
.logout-text {
  color: #8d4d27;
}

.empty-state {
  text-align: center;
  padding: 56rpx 0;
}

.empty-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.he-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.he-filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
}

.he-picker {
  font-size: 24rpx;
  color: var(--c-text-2);
  background: var(--c-surface);
  padding: 14rpx 16rpx;
  border-radius: 10rpx;
  border: 1rpx solid var(--c-border);
}

.he-new-btn {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: #8d5b39;
  padding: 14rpx 20rpx;
  border-radius: 10rpx;
}

.he-item {
  padding: 18rpx 18rpx 16rpx;
}

.he-item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.he-title {
  flex: 1;
  font-size: 29rpx;
  font-weight: 700;
  color: var(--c-text);
  line-height: 1.4;
}

.he-item-subline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.he-time {
  font-size: 22rpx;
  color: var(--c-text-3);
}

.he-summary {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.55;
  padding: 12rpx;
  background: rgba(45, 106, 79, 0.05);
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.he-tag {
  font-size: 20rpx;
  color: var(--c-primary);
  background: rgba(45, 106, 79, 0.1);
  border: 1rpx solid rgba(45, 106, 79, 0.2);
}

.he-targets {
  margin-top: 2rpx;
  padding: 10rpx 12rpx;
  background: rgba(192, 123, 79, 0.08);
  border-radius: 10rpx;
}

.he-targets-label {
  display: block;
  font-size: 22rpx;
  color: #8d4d27;
  margin-bottom: 4rpx;
}

.he-targets-text {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.45;
}

.he-item-foot {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
}

.he-item-action {
  font-size: 22rpx;
  color: var(--c-primary);
  font-weight: 600;
}