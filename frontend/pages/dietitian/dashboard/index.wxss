}

.feedback-status.status-pending {
  background: #fff3cd;
  color: #856404;
}

.feedback-status.status-replied {
  background: #d4edda;
  color: #155724;
}

.feedback-body {
  margin-bottom: 16rpx;
}

.feedback-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.feedback-content {
  display: block;
  font-size: 26rpx;
  color: #6c757d;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.feedback-time {
  font-size: 22rpx;
  color: #adb5bd;
}

.feedback-type {
  font-size: 22rpx;
  color: #6c757d;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.chart-section {
  margin-bottom: 40rpx;
}

.chart-placeholder {
  background: white;
  border-radius: 16rpx;
  padding: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.chart-text {
  font-size: 28rpx;
  color: #adb5bd;
}

.rating-card {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.rating-score {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.star {
  font-size: 36rpx;
  color: #dee2e6;
}

.star-active {
  color: #ffc107;
}

/* 个人中心弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.personal-center-modal {
  width: 85%;
  max-width: 600rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.personal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.personal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.modal-close {
  font-size: 48rpx;
  color: #adb5bd;
  line-height: 1;
  padding: 0 10rpx;
}

.personal-content {
  padding: 30rpx;
}

.personal-info {
  text-align: center;
  margin-bottom: 40rpx;
}

.personal-avatar {
