<view class="dietitian-dashboard">
  <view class="dashboard-header">
    <text class="dashboard-title">👋 欢迎，营养师</text>
    <view class="user-info" bindtap="showPersonalCenter">
      <text class="welcome-text">{{dietitianName}}</text>
      <view class="user-avatar">营</view>
    </view>
  </view>

  <view class="custom-tab-bar">
    <view class="tab-item {{activeTab === 'home' ? 'active' : ''}}" bindtap="switchTab" data-tab="home">
      <text class="tab-icon">🏠</text>
      <text class="tab-text">工作台首页</text>
    </view>
    <view class="tab-item {{activeTab === 'service' ? 'active' : ''}}" bindtap="switchTab" data-tab="service">
      <text class="tab-icon">📋</text>
      <text class="tab-text">服务中心</text>
    </view>
    <view class="tab-item {{activeTab === 'feedback' ? 'active' : ''}}" bindtap="switchTab" data-tab="feedback">
      <text class="tab-icon">💬</text>
      <text class="tab-text">反馈中心</text>
    </view>
    <view class="tab-item {{activeTab === 'mine' ? 'active' : ''}}" bindtap="switchTab" data-tab="mine">
      <text class="tab-icon">👤</text>
      <text class="tab-text">我的</text>
    </view>
  </view>

  <view class="tab-content">
    <!-- 工作台首页 -->
    <view wx:if="{{activeTab === 'home'}}" class="content-panel">
      <view class="stats-overview">
        <view class="stat-card" bindtap="navigateToService">
          <view class="stat-icon plan-icon">📋</view>
          <view class="stat-content">
            <text class="stat-number">{{stats.pendingPlans || 0}}</text>
            <text class="stat-label">待制定计划</text>
          </view>
        </view>
        <view class="stat-card" bindtap="navigateToHealthEducationTab">
          <view class="stat-icon article-icon">📄</view>
          <view class="stat-content">
            <text class="stat-number">{{heDraftCount}}</text>
            <text class="stat-label">健康教育草稿</text>
          </view>
        </view>
        <view class="stat-card" bindtap="navigateToFeedback">
          <view class="stat-icon feedback-icon">💬</view>
          <view class="stat-content">
            <text class="stat-number">{{stats.pendingFeedbacks || 0}}</text>
            <text class="stat-label">待回复反馈</text>
          </view>
        </view>
        <view class="stat-card">
          <view class="stat-icon user-icon">👥</view>
          <view class="stat-content">
            <text class="stat-number">{{stats.serviceUsers || 0}}</text>
            <text class="stat-label">服务用户数</text>
          </view>
        </view>
      </view>

      <view class="quick-access">
        <text class="section-title">📌 快捷操作</text>
        <view class="quick-buttons">
          <view class="quick-btn" bindtap="navigateToService">
            <view class="btn-icon">👥</view>
            <text class="btn-text">服务用户</text>
          </view>
          <view class="quick-btn" bindtap="navigateToHealthEducationNew">
            <view class="btn-icon">✍️</view>
            <text class="btn-text">健康教育</text>
          </view>
        </view>
      </view>

      <view class="recent-activity">
        <text class="section-title">📋 最近活动</text>
        <view class="activity-list">
          <view wx:for="{{recentActivities}}" wx:key="index" class="activity-item">
            <view class="activity-icon">{{item.icon}}</view>
            <view class="activity-content">
              <text class="activity-text">{{item.text}}</text>
              <text class="activity-time">{{item.time}}</text>
            </view>
          </view>
          <view wx:if="{{recentActivities.length === 0}}" class="empty-text">暂无最近活动</view>
        </view>
      </view>

      <view class="system-notices">
        <text class="section-title">🔔 系统通知</text>
        <view class="notice-list">
          <view wx:for="{{notices}}" wx:key="index" class="notice-item">
            <view class="notice-icon">📢</view>
            <view class="notice-content">
              <text class="notice-title">{{item.title}}</text>
              <text class="notice-text">{{item.content}}</text>
              <text class="notice-time">{{item.time}}</text>
            </view>
          </view>
          <view wx:if="{{notices.length === 0}}" class="empty-text">暂无系统通知</view>
        </view>
      </view>
    </view>

    <!-- 服务中心 -->
    <view wx:if="{{activeTab === 'service'}}" class="content-panel">
      <!-- 子标签页 -->
      <view class="sub-tabs">
        <view class="sub-tab-item {{serviceSubTab === 'requests' ? 'active' : ''}}" bindtap="switchServiceSubTab" data-subtab="requests">
          <text class="sub-tab-text">服务申请</text>
          <view class="sub-tab-badge" wx:if="{{stats.pendingRequests > 0}}">{{stats.pendingRequests}}</view>
        </view>
        <view class="sub-tab-item {{serviceSubTab === 'users' ? 'active' : ''}}" bindtap="switchServiceSubTab" data-subtab="users">
          <text class="sub-tab-text">用户列表</text>
        </view>
        <view class="sub-tab-item {{serviceSubTab === 'education' ? 'active' : ''}}" bindtap="switchServiceSubTab" data-subtab="education">
          <text class="sub-tab-text">健康教育</text>
        </view>
      </view>

      <!-- 服务申请列表 -->
      <view wx:if="{{serviceSubTab === 'requests'}}" class="sub-tab-content">
        <!-- 申请管理模块 -->
        <view class="request-management">
          <view class="filter-tabs">
            <view class="filter-tab {{filterType === 'pending' ? 'active' : ''}}" bindtap="switchFilter" data-filter="pending">
              <text>待处理</text>
            </view>
            <view class="filter-tab {{filterType === 'approved' ? 'active' : ''}}" bindtap="switchFilter" data-filter="approved">
              <text>已通过</text>
            </view>
            <view class="filter-tab {{filterType === 'all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">
              <text>全部</text>
            </view>
          </view>

          <view class="request-list">
            <view wx:for="{{filteredRequests}}" wx:key="index" class="request-item" bindtap="viewRequestDetail" data-index="{{index}}">
              <view class="request-header">
                <view class="request-user">
                  <view class="request-avatar">{{item.user_id ? item.user_id.substring(0, 1) : '?'}}</view>
                  <text class="request-user-id">{{item.user_id}}</text>
                </view>
                <view class="request-status {{item.status}}">{{item.statusText}}</view>
              </view>
              <view class="request-body">
                <view class="request-row">
                  <text class="request-label">服务类型：</text>
                  <text class="request-value">{{item.serviceTypeText}}</text>
                </view>
                <view class="request-row">
                  <text class="request-label">饮食目标：</text>
                  <text class="request-value">{{item.dietGoalText}}</text>
                </view>
                <view class="request-row">
                  <text class="request-label">申请时间：</text>
                  <text class="request-value">{{item.createTimeText}}</text>
                </view>
              </view>
              <view class="request-actions" catchtap="stopPropagation" wx:if="{{item.status === 'pending'}}">
                <view class="action-btn approve" bindtap="approveRequest" data-requestid="{{item.request_id}}">通过</view>
                <view class="action-btn reject" bindtap="rejectRequest" data-requestid="{{item.request_id}}">拒绝</view>
              </view>
            </view>
            <view wx:if="{{filteredRequests.length === 0}}" class="empty-state">
              <text class="empty-icon">📋</text>
              <text class="empty-text">暂无服务申请</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 用户列表 -->
      <view wx:if="{{serviceSubTab === 'education'}}" class="sub-tab-content he-tab">
        <view class="he-toolbar">
          <view class="he-filter-row">
            <picker mode="selector" range="{{heStatusLabels}}" value="{{heStatusIndex}}" bindchange="onHeStatusPick">
              <view class="he-picker">状态：{{heStatusLabels[heStatusIndex]}}</view>
            </picker>
            <picker mode="selector" range="{{heVisLabels}}" value="{{heVisIndex}}" bindchange="onHeVisPick">
              <view class="he-picker">范围：{{heVisLabels[heVisIndex]}}</view>
            </picker>
          </view>
          <view class="he-new-btn" bindtap="navigateToHealthEducationNew">+ 新建</view>
        </view>
        <view class="he-list">
          <view wx:for="{{heFilteredList}}" wx:key="he_id" class="he-item" bindtap="openHealthEducationEdit" data-id="{{item.he_id}}">
            <view class="he-item-top">
              <text class="he-title">{{item.title}}</text>
              <text class="he-badge status-{{item.content_status}}">{{item.content_status === 'published' ? '已发布' : '草稿'}}</text>
            </view>
            <text class="he-summary" wx:if="{{item.summary}}">{{item.summary}}</text>
            <view class="he-item-meta">
              <text class="he-tag">{{item.visibility === 'assigned' ? '指派' : '公开'}}</text>
              <text class="he-time">{{item.updated_at}}</text>
            </view>
            <view class="he-targets" wx:if="{{item.targetNamesText}}">
              <text class="he-targets-label">对象：</text>
              <text class="he-targets-text">{{item.targetNamesText}}</text>
            </view>
          </view>
          <view wx:if="{{heFilteredList.length === 0}}" class="empty-state">
            <text class="empty-icon">📄</text>
            <text class="empty-text">暂无健康教育内容</text>
          </view>
        </view>
      </view>

      <view wx:if="{{serviceSubTab === 'users'}}" class="sub-tab-content">
        <view class="service-users">
          <view class="search-box">
            <input class="search-input" placeholder="搜索用户..." bindinput="onSearchUser" value="{{searchKeyword}}"/>
          </view>

          <view class="user-list">
            <view wx:for="{{users}}" wx:key="index" class="user-item" bindtap="enterUserPanel" data-userid="{{item.userId}}">
              <view class="user-avatar-small">{{item.usernameInitial}}</view>
              <view class="user-info-small">
                <text class="user-name">{{item.username}}</text>
                <view class="user-status">
                  <text class="status-tag {{item.hasProfile ? 'status-ok' : 'status-warning'}}">{{item.hasProfile ? '档案✅' : '档案❌'}}</text>
                  <text class="status-tag {{item.hasEvaluation ? 'status-ok' : 'status-warning'}}">{{item.hasEvaluation ? '评估✅' : '评估❌'}}</text>
                  <text class="status-tag {{item.hasPlan ? 'status-ok' : 'status-warning'}}">{{item.hasPlan ? '计划✅' : '计划❌'}}</text>
                </view>
                <text class="user-last-service">最后服务：{{item.lastServiceTime}}</text>
              </view>
              <text class="arrow">></text>
            </view>
            <view wx:if="{{users.length === 0}}" class="empty-state">
              <text class="empty-icon">👥</text>
              <text class="empty-text">暂无用户数据</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 服务请求详情弹窗 -->
    <view wx:if="{{showRequestDetail}}" class="modal-mask" bindtap="closeRequestDetail">
      <view class="request-detail-modal" catchtap="stopPropagation">
        <view class="modal-header">
          <text class="modal-title">申请详情</text>
          <view class="modal-close" bindtap="closeRequestDetail">×</view>
        </view>
        <view class="modal-body" wx:if="{{selectedRequest}}">
          <view class="detail-section">
            <view class="detail-row">
              <text class="detail-label">申请人ID：</text>
              <text class="detail-value">{{selectedRequest.user_id}}</text>
            </view>
            <view class="detail-row">
              <text class="detail-label">服务类型：</text>
              <text class="detail-value">{{selectedRequest.serviceTypeText}}</text>
            </view>
            <view class="detail-row">
              <text class="detail-label">饮食目标：</text>
              <text class="detail-value">{{selectedRequest.dietGoalText}}</text>
            </view>
            <view class="detail-row">
              <text class="detail-label">申请时间：</text>
              <text class="detail-value">{{selectedRequest.createTimeText}}</text>
            </view>
            <view class="detail-row">
              <text class="detail-label">当前状态：</text>
              <text class="detail-value status-{{selectedRequest.status}}">{{selectedRequest.statusText}}</text>
            </view>
          </view>
          <view class="detail-section" wx:if="{{selectedRequest.health_data}}">
            <text class="detail-section-title">健康信息</text>
            <view class="detail-row" wx:if="{{selectedRequest.health_data.disease}}">
              <text class="detail-label">疾病史：</text>
              <text class="detail-value">{{selectedRequest.health_data.disease || '无'}}</text>
            </view>
            <view class="detail-row" wx:if="{{selectedRequest.health_data.allergy}}">
              <text class="detail-label">过敏食物：</text>
              <text class="detail-value">{{selectedRequest.health_data.allergy || '无'}}</text>
            </view>
            <view class="detail-row" wx:if="{{selectedRequest.health_data.demand}}">
              <text class="detail-label">特殊需求：</text>
              <text class="detail-value">{{selectedRequest.health_data.demand || '无'}}</text>
            </view>
          </view>
        </view>
        <view class="modal-footer" wx:if="{{selectedRequest && selectedRequest.status === 'pending'}}">
          <view class="modal-btn approve" bindtap="approveRequest" data-requestid="{{selectedRequest.request_id}}">批准申请</view>
          <view class="modal-btn reject" bindtap="rejectRequest" data-requestid="{{selectedRequest.request_id}}">拒绝申请</view>
        </view>
      </view>
    </view>

    <!-- 反馈中心 -->
    <view wx:if="{{activeTab === 'feedback'}}" class="content-panel">
      <view class="feedback-tabs">
        <view class="feedback-tab {{feedbackSubTab === 'pending' ? 'active' : ''}}" bindtap="switchFeedbackSubTab" data-subtab="pending">
          <text>待回复</text>
          <text class="badge" wx:if="{{pendingFeedbackCount > 0}}">{{pendingFeedbackCount}}</text>
        </view>
        <view class="feedback-tab {{feedbackSubTab === 'replied' ? 'active' : ''}}" bindtap="switchFeedbackSubTab" data-subtab="replied">
          <text>已回复</text>
        </view>
      </view>

      <view class="feedback-list">
        <view wx:for="{{feedbacks}}" wx:key="index" class="feedback-item" bindtap="viewFeedbackDetail" data-index="{{index}}">
          <view class="feedback-header">
            <view class="feedback-user">
              <text class="feedback-avatar">{{item.userInitial}}</text>
              <text class="feedback-username">{{item.username}}</text>
            </view>
            <text class="feedback-status {{item.status === '待回复' ? 'status-pending' : 'status-replied'}}">{{item.status}}</text>
          </view>
          <view class="feedback-body">
            <text class="feedback-title">{{item.title}}</text>
            <text class="feedback-content">{{item.content}}</text>
          </view>
          <view class="feedback-footer">
            <text class="feedback-time">{{item.time}}</text>
            <text class="feedback-type">{{item.type}}</text>
          </view>
        </view>
        <view wx:if="{{feedbacks.length === 0}}" class="empty-state">
          <text class="empty-icon">💬</text>
          <text class="empty-text">暂无反馈数据</text>
        </view>
      </view>
    </view>

    <!-- 我的 -->
    <view wx:if="{{activeTab === 'mine'}}" class="content-panel">
      <view class="mine-header">
        <view class="personal-info-card">
          <view class="personal-avatar-large" bindtap="chooseAvatar">营</view>
          <view class="personal-details">
            <text class="personal-name-large">{{dietitianName}}</text>
            <text class="personal-role-large">营养师</text>
            <view class="personal-stats">
              <view class="stat-item">
                <text class="stat-number">{{stats.serviceUsers || 0}}</text>
                <text class="stat-label">服务用户</text>
              </view>
              <view class="stat-item">
                <text class="stat-number">{{stats.totalPlans || 0}}</text>
                <text class="stat-label">制定计划</text>
              </view>
              <view class="stat-item">
                <text class="stat-number">{{stats.avgRating || 0}}</text>
                <text class="stat-label">平均评分</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="mine-menu">
        <view class="menu-section">
          <text class="section-title">账户管理</text>
          <view class="menu-item" bindtap="editProfile">
            <text class="menu-icon">👤</text>
            <text class="menu-text">个人资料</text>
            <text class="menu-arrow">→</text>
          </view>
          <view class="menu-item" bindtap="changePassword">
            <text class="menu-icon">�</text>
            <text class="menu-text">修改密码</text>
            <text class="menu-arrow">→</text>
          </view>
        </view>

        <view class="menu-section">
          <text class="section-title">工作统计</text>
          <view class="menu-item" bindtap="viewServiceStats">
            <text class="menu-icon">📊</text>
            <text class="menu-text">服务统计</text>
            <text class="menu-arrow">→</text>
          </view>
          <view class="menu-item" bindtap="viewPlanStats">
            <text class="menu-icon">�</text>
            <text class="menu-text">计划统计</text>
            <text class="menu-arrow">→</text>
          </view>
        </view>

        <view class="menu-section">
          <text class="section-title">其他</text>
          <view class="menu-item" bindtap="viewHelp">
            <text class="menu-icon">❓</text>
            <text class="menu-text">帮助中心</text>
            <text class="menu-arrow">→</text>
          </view>
          <view class="menu-item" bindtap="viewAbout">
            <text class="menu-icon">ℹ️</text>
            <text class="menu-text">关于我们</text>
            <text class="menu-arrow">→</text>
          </view>
        </view>

        <view class="logout-section">
          <view class="logout-btn" bindtap="handleLogout">
            <text class="logout-icon">🚪</text>
            <text class="logout-text">退出登录</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 个人中心弹窗 -->
  <view wx:if="{{showPersonalCenterModal}}" class="modal-mask" bindtap="hidePersonalCenter">
    <view class="personal-center-modal" catchtap="stopPropagation">
      <view class="personal-header">
        <text class="personal-title">个人中心</text>
        <view class="modal-close" bindtap="hidePersonalCenter">×</view>
      </view>
      <view class="personal-content">
        <view class="personal-info">
          <view class="personal-avatar" bindtap="chooseAvatar">营</view>
          <text class="personal-name">{{dietitianName}}</text>
          <text class="personal-role">营养师</text>
        </view>
        <view class="personal-menu">
          <view class="menu-item" bindtap="editProfile">
            <text class="menu-icon">👤</text>
            <text class="menu-text">个人资料</text>
            <text class="menu-arrow">→</text>
          </view>
          <view class="menu-item" bindtap="changePassword">
            <text class="menu-icon">🔒</text>
            <text class="menu-text">修改密码</text>
            <text class="menu-arrow">→</text>
          </view>
          <view class="menu-item" bindtap="handleLogout">
            <text class="menu-icon">🚪</text>
            <text class="menu-text logout-text">退出登录</text>
            <text class="menu-arrow">→</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>