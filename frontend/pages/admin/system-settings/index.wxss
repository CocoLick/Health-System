.settings-page {
  min-height: 100vh;
  background: transparent;
  padding: 20rpx;
}

.page-header {
  padding: 8rpx 2rpx 16rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--c-text);
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
}

.section-card {
  background: var(--c-surface);
  border-radius: 14rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 12rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-main {
  flex: 1;
  padding-right: 12rpx;
}

.setting-title {
  display: block;
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 600;
}

.setting-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--c-text-3);
  line-height: 1.45;
}

.policy-row {
  padding: 14rpx 0;
  border-bottom: 1rpx dashed rgba(40, 38, 34, 0.12);
}

.policy-row:last-child {
  border-bottom: none;
}

.policy-key {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-3);
}

.policy-val {
  display: block;
  margin-top: 6rpx;
  font-size: 27rpx;
  color: var(--c-text);
}

.tip-card {
  border-left: 8rpx solid #b56d42;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--c-text-2);
}

.action-row {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.action {
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.action.ghost {
  border: 1rpx solid rgba(40, 38, 34, 0.12);
  color: var(--c-text-2);
  background: #f5f1eb;
}

.action.solid {
  background: var(--c-primary);
  color: #fff;
}