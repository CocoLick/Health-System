.admin-dashboard {
  min-height: 100vh;
  background: linear-gradient(145deg, #f8f9fa 0%, #e9ecef 100%);
  padding-bottom: 140rpx;
}

.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.dashboard-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.welcome-text {
  font-size: 28rpx;
  color: #6c757d;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
}

.custom-tab-bar {
  display: flex;
  background: white;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #4caf50;
}

.tab-item.active::before {
  content: '';
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 40rpx;
}

.tab-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #6c757d;
}

.tab-item.active .tab-text {
  color: #4caf50;
  font-weight: 600;
}

.tab-content {
  padding: 20rpx;
}

.content-panel {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stats-overview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.stat-card:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stat-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-icon {
  background: rgba(33, 150, 243, 0.1);
}

.dietitian-icon {
  background: rgba(255, 152, 0, 0.1);
}

.plan-icon {
  background: rgba(76, 175, 80, 0.1);
}

.article-icon {
  background: rgba(156, 39, 176, 0.1);
}

.stat-content {
  flex: 1;
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #6c757d;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  display: block;
}

.recent-activity {
  margin-bottom: 40rpx;
}

.activity-list {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-icon {
  font-size: 32rpx;
  margin-top: 4rpx;
}

.activity-content {
  flex: 1;
}

.activity-text {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.activity-time {
  display: block;
  font-size: 24rpx;
  color: #adb5bd;
}

.system-notices {
  margin-bottom: 40rpx;
}

.notice-list {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-icon {
  font-size: 32rpx;
  margin-top: 4rpx;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.notice-text {
  display: block;
  font-size: 24rpx;
  color: #6c757d;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.notice-time {
  display: block;
  font-size: 22rpx;
  color: #adb5bd;
}

.manage-tabs-container {
  position: relative;
  margin-bottom: 20rpx;
}

.audit-tabs, .manage-tabs {
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
  background: white;
  border-radius: 12rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  position: relative;
}

.scroll-indicator {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
  animation: pulse 2s infinite;
}

.indicator-icon {
  font-size: 36rpx;
  color: #4caf50;
  font-weight: bold;
}

@keyframes pulse {
  0% {
    transform: translateY(-50%) scale(1);
    opacity: 1;
  }
  50% {
    transform: translateY(-50%) scale(1.1);
    opacity: 0.8;
  }
  100% {
    transform: translateY(-50%) scale(1);
    opacity: 1;
  }
}

.audit-tabs::after, .manage-tabs::after {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 60rpx;
  background: linear-gradient(to left, white, transparent);
  pointer-events: none;
  border-radius: 0 12rpx 12rpx 0;
}

.audit-tabs::-webkit-scrollbar, .manage-tabs::-webkit-scrollbar {
  display: none;
}

.audit-tab, .manage-tab {
  flex: 0 0 auto;
  min-width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #6c757d;
  transition: all 0.3s ease;
  position: relative;
}

.tab-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff3cd;
  border: 2rpx solid #ffeaa7;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  animation: fadeIn 0.3s ease;
  cursor: pointer;
  transition: all 0.3s ease;
}

.tab-hint:active {
  background: #ffeaa7;
  transform: scale(0.98);
}

.hint-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.hint-text {
  flex: 1;
  font-size: 26rpx;
  color: #856404;
  line-height: 1.4;
}

.hint-close {
  font-size: 32rpx;
  color: #856404;
  line-height: 1;
  padding: 4rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
}

.tab-icon {
  font-size: 32rpx;
  line-height: 1;
}

.audit-tab.active, .manage-tab.active {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
  font-weight: 600;
}

.badge {
  background: #ff5722;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.audit-tab.active .badge, .manage-tab.active .badge {
  background: white;
  color: #4caf50;
}

.audit-item, .manage-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.item-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-right: 20rpx;
}

.item-status {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #fff3cd;
  color: #856404;
}

.status-approved {
  background: #d4edda;
  color: #155724;
}

.status-rejected {
  background: #f8d7da;
  color: #721c24;
}

.status-active {
  background: #d4edda;
  color: #155724;
}

.status-inactive {
  background: #f8d7da;
  color: #721c24;
}

.item-body {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-info {
  display: flex;
  margin-bottom: 12rpx;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: #6c757d;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a1a;
  flex: 1;
}

.article-preview {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.preview-text {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  align-items: center;
}

.btn-primary {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.2);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

.btn-secondary {
  background: #f8f9fa;
  color: #1a1a1a;
  border: 2rpx solid #dee2e6;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: #e9ecef;
}

.btn-text {
  font-size: 24rpx;
  color: #4caf50;
  font-weight: 500;
  padding: 12rpx 24rpx;
  transition: all 0.3s ease;
}

.btn-text:active {
  color: #2e7d32;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  text-align: center;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6c757d;
}

.user-avatar-small {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.user-info-small {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-subtitle {
  font-size: 24rpx;
  color: #6c757d;
}

.item-desc {
  font-size: 26rpx;
  color: #6c757d;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-time {
  font-size: 24rpx;
  color: #adb5bd;
}

.settings-list {
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background: #f8f9fa;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.settings-text {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}

.settings-arrow {
  font-size: 28rpx;
  color: #adb5bd;
}

.chart-section {
  margin-bottom: 40rpx;
}

.chart-placeholder {
  background: white;
  border-radius: 16rpx;
  padding: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.chart-text {
  font-size: 28rpx;
  color: #adb5bd;
}

/* 规划师头像 */
.dietitian-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

/* 添加规划师按钮 */
.add-dietitian-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 2rpx dashed #dee2e6;
  transition: all 0.3s ease;
}

.add-dietitian-btn:active {
  background: #f8f9fa;
  border-color: #4caf50;
}

.add-icon {
  font-size: 36rpx;
  color: #4caf50;
  font-weight: 600;
}

.add-text {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: 500;
}

/* 危险按钮 */
.btn-danger {
  color: #ff5722 !important;
}

.btn-danger:active {
  color: #e64a19 !important;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.modal-close {
  font-size: 48rpx;
  color: #adb5bd;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #6c757d;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #4caf50;
  background: white;
}

.picker-view {
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  background: #f8f9fa;
  color: #1a1a1a;
}

.form-message {
  min-height: 40rpx;
  margin-top: 10rpx;
}

.error-text {
  font-size: 24rpx;
  color: #ff5722;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6c757d;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: white;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  border-radius: 12rpx;
  font-weight: 500;
}

/* 个人中心弹窗 */
@keyframes pc-modal-in {
  from {
    opacity: 0;
    transform: scale(0.97) translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.personal-center-modal {
  position: relative;
  width: 86%;
  max-width: 620rpx;
  overflow: hidden;
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-radius: var(--radius-lg);
  box-shadow: 0 24rpx 56rpx rgba(33, 30, 26, 0.18), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  animation: pc-modal-in 0.32s var(--ease-natural) both;
}

.personal-center-modal::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--c-primary) 0%, rgba(45, 106, 79, 0.4) 55%, rgba(192, 123, 79, 0.35) 100%);
  opacity: 0.9;
}

.pc-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 28rpx 28rpx 22rpx 32rpx;
  border-bottom: 1rpx solid var(--c-border);
}

.pc-head-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
  padding-top: 4rpx;
}

.pc-eyebrow {
  font-size: 20rpx;
  letter-spacing: 0.12em;
  color: var(--c-text-3);
}

.pc-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: 0.02em;
  line-height: 1.25;
}

.pc-close {
  width: 64rpx;
  height: 64rpx;
  margin: -4rpx -4rpx 0 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
  color: var(--c-text-3);
  background: rgba(45, 106, 79, 0.06);
  border: 1rpx solid rgba(40, 38, 34, 0.06);
  flex-shrink: 0;
  transition: background 0.2s ease, color 0.2s ease, transform 0.18s var(--ease-natural);
}

.pc-close-press {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-text-2);
  transform: scale(0.95);
}

.pc-body {
  padding: 12rpx 0 0;
}

.pc-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx 32rpx;
  text-align: center;
}

.pc-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: linear-gradient(150deg, var(--c-primary) 0%, var(--c-primary-strong) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 50rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(45, 106, 79, 0.28);
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  margin-bottom: 18rpx;
  transition: transform 0.2s var(--ease-natural);
}

.pc-avatar:active {
  transform: scale(0.98);
}

.pc-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 6rpx;
}

.pc-role {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-3);
}

.pc-list {
  padding: 0 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pc-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-press);
}

.pc-item--danger {
  border-color: rgba(154, 77, 34, 0.2);
  background: rgba(154, 77, 34, 0.05);
}

.pc-item-main {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.pc-ico {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-primary);
  background: var(--c-primary-soft);
  border: 1rpx solid rgba(45, 106, 79, 0.12);
  flex-shrink: 0;
}

.pc-ico--out {
  color: #8d4d27;
  background: rgba(154, 77, 34, 0.1);
  border-color: rgba(154, 77, 34, 0.18);
}

.pc-label {
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 500;
  flex: 1;
}

.pc-item--danger .pc-label {
  color: #7a3a18;
  font-weight: 600;
}

.pc-chev {
  font-size: 36rpx;
  line-height: 1;
  color: var(--c-text-3);
  margin-left: 8rpx;
  flex-shrink: 0;
}

.pc-item--danger .pc-chev {
  color: rgba(122, 58, 24, 0.55);
}

.pc-item-press {
  background: #efe9e1;
  box-shadow: none;
}

.pc-item--danger.pc-item-press {
  background: rgba(154, 77, 34, 0.12) !important;
}

/* 悬浮效果 */
.user-info {
  cursor: pointer;
  transition: all 0.3s ease;
}

.user-info:active {
  transform: scale(0.95);
}

/* 类别筛选 */
.category-filter {
  margin-bottom: 20rpx;
  background: white;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.category-scroll {
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.category-scroll::-webkit-scrollbar {
  display: none;
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #6c757d;
  background: #f8f9fa;
  transition: all 0.3s ease;
  border: 2rpx solid #dee2e6;
}

.category-item.active {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
  border-color: #4caf50;
  font-weight: 600;
}

.category-item:active {
  transform: translateY(2rpx);
}

/* 分页控件 */
.pagination {
  margin-top: 30rpx;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.pagination-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.pagination-info text {
  font-size: 24rpx;
  color: #6c757d;
}

.pagination-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.btn-page {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #4caf50;
  border: 2rpx solid #4caf50;
  transition: all 0.3s ease;
}

.btn-page:active {
  background: #4caf50;
  color: white;
}

.btn-page.disabled {
  color: #adb5bd;
  border-color: #dee2e6;
  cursor: not-allowed;
}

.btn-page.disabled:active {
  background: transparent;
  color: #adb5bd;
}

.page-size-selector {
  flex: 1;
  max-width: 200rpx;
}

/* 营养信息布局 */
.nutrition-info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.nutrition-item .info-label {
  width: auto;
  font-size: 24rpx;
}

.nutrition-item .info-value {
  font-size: 26rpx;
  font-weight: 500;
}

/* 添加营养数据按钮 */
.add-nutrition-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 2rpx dashed #dee2e6;
  transition: all 0.3s ease;
}

.add-nutrition-btn:active {
  background: #f8f9fa;
  border-color: #4caf50;
}

/* 类别标签 */
.item-category {
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: #e3f2fd;
  color: #1976d2;
}

/* ===== 管理员工作台视觉重构（仅样式） ===== */
.admin-dashboard {
  min-height: 100vh;
  background: transparent;
  padding-bottom: 140rpx;
}

.dashboard-header {
  margin: 18rpx 20rpx 14rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.dashboard-title {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: var(--c-text);
}

.welcome-text {
  font-size: 24rpx;
  color: var(--c-text-3);
}

.user-avatar {
  background: var(--c-primary);
  box-shadow: 0 6rpx 14rpx rgba(45, 106, 79, 0.22);
}

.user-info {
  padding: 8rpx 14rpx 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 245, 0.96);
  border: 1rpx solid var(--c-border);
}

.user-info:active {
  transform: scale(0.97);
}

.tab-content {
  padding: 0 20rpx 20rpx;
}

.content-panel {
  animation: page-enter 0.24s var(--ease-natural);
}

@keyframes page-enter {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stats-overview {
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.stat-card {
  border-radius: 14rpx;
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  padding: 22rpx;
  transition: transform 0.18s var(--ease-natural), box-shadow 0.18s var(--ease-natural);
}

.stat-card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-press);
}

.stat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  font-size: 40rpx;
}

.user-icon {
  background: rgba(45, 106, 79, 0.12);
}

.dietitian-icon {
  background: rgba(141, 91, 57, 0.14);
}

.plan-icon {
  background: rgba(85, 92, 74, 0.14);
}

.article-icon {
  background: rgba(192, 123, 79, 0.16);
}

.stat-number,
.section-title {
  color: var(--c-text);
}

.stat-label,
.activity-time,
.notice-time,
.item-time {
  color: var(--c-text-3);
}

.recent-activity,
.system-notices,
.chart-section {
  margin-bottom: 18rpx;
}

.activity-list,
.notice-list,
.settings-list,
.chart-placeholder,
.audit-tabs,
.manage-tabs,
.history-filter .filter-btn,
.tab-hint,
.pagination,
.category-filter {
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.activity-list,
.notice-list,
.settings-list,
.chart-placeholder,
.pagination,
.category-filter {
  border-radius: 14rpx;
}

.activity-item,
.notice-item,
.settings-item {
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.activity-text,
.notice-title,
.settings-text,
.item-title,
.info-value,
.preview-text {
  color: var(--c-text);
}

.notice-text,
.item-desc,
.info-label,
.filter-text,
.tab-text,
.item-subtitle {
  color: var(--c-text-2);
}

.custom-tab-bar {
  background: rgba(255, 252, 248, 0.96);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid var(--c-border);
  box-shadow: 0 -6rpx 24rpx rgba(33, 30, 26, 0.08);
  padding: 12rpx 8rpx;
  padding-bottom: calc(12rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}

.tab-item {
  gap: 6rpx;
  border-radius: 12rpx;
  transition: background 0.18s var(--ease-natural), transform 0.18s var(--ease-natural);
}

.tab-item.active {
  background: rgba(45, 106, 79, 0.1);
}

.tab-item.active::before {
  top: 0;
  width: 46%;
  height: 3rpx;
  background: var(--c-primary);
}

.tab-item.active .tab-text,
.tab-item.active {
  color: var(--c-primary);
}

.audit-tabs,
.manage-tabs {
  border-radius: 12rpx;
  padding: 8rpx;
}

.audit-tab,
.manage-tab {
  min-width: 132rpx;
  border-radius: 10rpx;
  font-size: 25rpx;
  color: var(--c-text-2);
  transition: background 0.18s var(--ease-natural), color 0.18s var(--ease-natural), transform 0.18s var(--ease-natural);
}

.audit-tab.active,
.manage-tab.active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.badge {
  background: rgba(181, 109, 66, 0.15);
  color: #8d4d27;
  border-radius: 999rpx;
}

.audit-tab.active .badge,
.manage-tab.active .badge {
  background: var(--c-primary);
  color: #fff;
}

.tab-hint {
  border-radius: 12rpx;
  background: rgba(255, 248, 239, 0.96);
  border: 1rpx solid rgba(181, 109, 66, 0.28);
}

.hint-text,
.hint-close {
  color: #8d4d27;
}

.audit-item,
.manage-item {
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-radius: 14rpx;
  border-left: 8rpx solid #c0b19d;
  box-shadow: var(--shadow-card);
  padding: 22rpx;
  margin-bottom: 14rpx;
}

.item-status {
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  background: rgba(192, 123, 79, 0.14);
  color: #8d4d27;
}

.status-approved,
.status-active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.status-rejected,
.status-inactive {
  background: rgba(181, 109, 66, 0.16);
  color: #8d4d27;
}

.item-body {
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.article-preview,
.reject-reason {
  background: #f8f4ee;
  border-radius: 10rpx;
}

.item-footer {
  gap: 10rpx;
}

.btn-primary,
.btn-confirm {
  background: var(--c-primary);
  color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 6rpx 16rpx rgba(45, 106, 79, 0.2);
  transition: transform 0.18s var(--ease-natural), box-shadow 0.18s var(--ease-natural), background 0.18s var(--ease-natural);
}

.btn-primary:active,
.btn-confirm:active {
  transform: translateY(2rpx);
  background: var(--c-primary-strong);
  box-shadow: 0 2rpx 8rpx rgba(45, 106, 79, 0.18);
}

.btn-secondary,
.btn-cancel,
.btn-page {
  background: #f4efe9;
  color: var(--c-text-2);
  border: 1rpx solid var(--c-border);
  border-radius: 10rpx;
}

.btn-text,
.add-text,
.add-icon {
  color: var(--c-primary);
}

.btn-danger,
.btn-danger:active {
  color: #9a4d22 !important;
}

.empty-state {
  background: var(--c-surface);
  border: 1rpx dashed rgba(40, 38, 34, 0.18);
  border-radius: 14rpx;
  box-shadow: var(--shadow-card);
}

.empty-text {
  color: var(--c-text-3);
}

.user-avatar-small,
.dietitian-avatar {
  background: var(--c-primary);
}

.settings-item:active,
.pc-item-press,
.btn-secondary:active,
.btn-cancel:active {
  background: #efe9e1;
}

.settings-arrow,
.menu-arrow,
.filter-icon {
  color: var(--c-text-3);
}

.chart-placeholder {
  padding: 48rpx 24rpx;
}

.chart-text {
  color: var(--c-text-3);
}

.scroll-indicator {
  background: rgba(255, 251, 245, 0.95);
  box-shadow: 0 4rpx 14rpx rgba(33, 30, 26, 0.12);
}

.indicator-icon {
  color: var(--c-primary);
}

.modal-mask {
  background: rgba(31, 31, 28, 0.38);
}

.modal-content {
  background: var(--c-surface);
  border-radius: 18rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: 0 18rpx 42rpx rgba(33, 30, 26, 0.2);
}

.modal-header {
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.modal-title {
  color: var(--c-text);
}

.modal-close {
  color: var(--c-text-3);
}

.form-label,
.form-hint {
  color: var(--c-text-3);
}

.form-input,
.picker-view {
  border: 1rpx solid var(--c-border);
  background: #fffdf9;
  color: var(--c-text);
}

.form-message .error-text {
  color: #9a4d22;
}

.category-item {
  border: 1rpx solid rgba(40, 38, 34, 0.12);
  background: #f3eee7;
  color: var(--c-text-2);
}

.category-item.active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
  border-color: rgba(45, 106, 79, 0.24);
}

.pagination-info {
  border-bottom: 1rpx solid rgba(40, 38, 34, 0.08);
}

.pagination-info text {
  color: var(--c-text-3);
}

.btn-page {
  color: var(--c-primary);
  border-color: rgba(45, 106, 79, 0.35);
}

.btn-page:active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.btn-page.disabled,
.btn-page.disabled:active {
  color: #a9a59b;
  border-color: rgba(40, 38, 34, 0.12);
  background: #f4efe9;
}

.item-category {
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
  border-radius: 999rpx;
}
