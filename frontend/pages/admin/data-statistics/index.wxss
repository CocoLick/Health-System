.stats-page {
  min-height: 100vh;
  background: transparent;
  padding: 20rpx;
}

.page-header {
  padding: 8rpx 2rpx 16rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--c-text);
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
}

.range-card,
.trend-card,
.insight-card {
  background: var(--c-surface);
  border-radius: 14rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.range-label {
  display: block;
  font-size: 24rpx;
  color: var(--c-text-3);
}

.range-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.range-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f3eee7;
  color: var(--c-text-2);
  font-size: 24rpx;
}

.range-pill.active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.overview-card {
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
  border-radius: 14rpx;
  padding: 20rpx;
}

.overview-label {
  display: block;
  font-size: 22rpx;
  color: var(--c-text-3);
}

.overview-value {
  display: block;
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text);
}

.overview-trend {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--c-primary);
  background: rgba(45, 106, 79, 0.1);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 12rpx;
}

.trend-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.trend-row:last-child {
  margin-bottom: 0;
}

.day {
  width: 70rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
}

.bar-group {
  flex: 1;
  margin: 0 12rpx;
}

.bar {
  height: 10rpx;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
}

.bar:last-child {
  margin-bottom: 0;
}

.user-bar {
  background: rgba(45, 106, 79, 0.7);
}

.service-bar {
  background: rgba(192, 123, 79, 0.75);
}

.value {
  width: 140rpx;
  text-align: right;
  font-size: 23rpx;
  color: var(--c-text-3);
}

.insight-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.insight-row:last-child {
  margin-bottom: 0;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin: 11rpx 10rpx 0 0;
  background: var(--c-accent-warm);
}

.insight-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.55;
}