.ingredient-page {
  min-height: 100vh;
  background: transparent;
  padding: 20rpx;
}

.page-header {
  padding: 8rpx 2rpx 16rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--c-text);
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
}

.toolbar-card {
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-radius: 14rpx;
  box-shadow: var(--shadow-card);
  padding: 18rpx;
  margin-bottom: 16rpx;
}

.search-input {
  border-radius: 12rpx;
  border: 1rpx solid var(--c-border);
  background: #fffdf9;
  padding: 16rpx 18rpx;
  font-size: 28rpx;
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.cat-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3eee7;
  color: var(--c-text-2);
  font-size: 23rpx;
}

.cat-pill.active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.add-btn {
  margin-top: 14rpx;
  display: inline-block;
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
  background: var(--c-primary);
  color: #fff;
  font-size: 24rpx;
}

.empty-card {
  background: var(--c-surface);
  border: 1rpx dashed rgba(40, 38, 34, 0.2);
  border-radius: 14rpx;
  padding: 44rpx 22rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--c-text);
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--c-text-3);
}

.ingredient-card {
  margin-top: 14rpx;
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-left: 8rpx solid #8d5b39;
  border-radius: 14rpx;
  padding: 20rpx;
  box-shadow: var(--shadow-card);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
}

.cat {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
}

.nutri-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.nutri-cell {
  background: #f8f4ee;
  border: 1rpx solid rgba(40, 38, 34, 0.08);
  border-radius: 10rpx;
  padding: 12rpx;
}

.nutri-cell .k {
  display: block;
  font-size: 22rpx;
  color: var(--c-text-3);
}

.nutri-cell .v {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: var(--c-text);
  font-weight: 600;
}

.actions {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(40, 38, 34, 0.08);
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.action {
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
}

.action.ghost {
  background: #f5f1eb;
  border: 1rpx solid rgba(40, 38, 34, 0.1);
  color: var(--c-text-2);
}

.action.danger {
  background: rgba(181, 109, 66, 0.14);
  color: #9a4d22;
}
