.audit-center {
  min-height: 100vh;
  background: linear-gradient(145deg, #f8f9fa 0%, #e9ecef 100%);
}

.tab-bar {
  display: flex;
  background: white;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  padding: 30rpx 0;
  text-align: center;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #4caf50;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  border-radius: 2rpx;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #6c757d;
}

.tab-item.active .tab-text {
  color: #4caf50;
  font-weight: 600;
}

.audit-content {
  padding: 20rpx;
}

.audit-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.item-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-right: 20rpx;
}

.item-status {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #fff3cd;
  color: #856404;
}

.status-approved {
  background: #d4edda;
  color: #155724;
}

.status-rejected {
  background: #f8d7da;
  color: #721c24;
}

.item-body {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-info {
  display: flex;
  margin-bottom: 12rpx;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: #6c757d;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a1a;
  flex: 1;
}

.article-preview {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.preview-text {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.reject-reason {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8d7da;
  border-radius: 12rpx;
}

.reason-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #721c24;
  margin-right: 8rpx;
}

.reason-text {
  font-size: 24rpx;
  color: #721c24;
  line-height: 1.5;
}

.item-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  align-items: center;
}

.btn-primary {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.2);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

.btn-secondary {
  background: #f8f9fa;
  color: #1a1a1a;
  border: 2rpx solid #dee2e6;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: #e9ecef;
}

.btn-text {
  font-size: 24rpx;
  color: #4caf50;
  font-weight: 500;
  padding: 12rpx 24rpx;
  transition: all 0.3s ease;
}

.btn-text:active {
  color: #2e7d32;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6c757d;
}

.history-filter {
  margin-bottom: 20rpx;
}

.filter-btn {
  background: white;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.filter-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.filter-icon {
  font-size: 24rpx;
  color: #6c757d;
}
