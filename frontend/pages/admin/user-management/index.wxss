.admin-page {
  min-height: 100vh;
  background: transparent;
  padding: 20rpx 20rpx 36rpx;
}

.page-header {
  padding: 8rpx 4rpx 16rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--c-text);
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
}

.metrics-grid {
  display: flex;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.metric-card {
  flex: 1;
  background: var(--c-surface);
  border-radius: 14rpx;
  padding: 20rpx 18rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: var(--c-text-3);
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text);
}

.metric-value.ok {
  color: var(--c-primary);
}

.metric-value.warn {
  color: #a35f2e;
}

.filter-card {
  background: var(--c-surface);
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid var(--c-border);
  box-shadow: var(--shadow-card);
}

.search-input {
  border-radius: 12rpx;
  border: 1rpx solid var(--c-border);
  background: #fffdf9;
  padding: 16rpx 18rpx;
  font-size: 28rpx;
}

.tab-row {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tab-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f3eee7;
  font-size: 24rpx;
  color: var(--c-text-2);
  border: 1rpx solid transparent;
}

.tab-pill.active {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
  border-color: rgba(45, 106, 79, 0.24);
}

.list-wrap {
  margin-top: 16rpx;
}

.empty-card {
  background: var(--c-surface);
  border: 1rpx dashed rgba(40, 38, 34, 0.2);
  border-radius: 14rpx;
  padding: 44rpx 22rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--c-text);
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--c-text-3);
}

.user-card {
  background: var(--c-surface);
  border: 1rpx solid var(--c-border);
  border-left: 8rpx solid #bcae98;
  border-radius: 14rpx;
  padding: 22rpx;
  margin-bottom: 14rpx;
  box-shadow: var(--shadow-card);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-main .name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
}

.user-main .role {
  display: block;
  margin-top: 4rpx;
  font-size: 23rpx;
  color: var(--c-text-3);
}

.status-chip {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.status-chip.ok {
  background: rgba(45, 106, 79, 0.12);
  color: var(--c-primary);
}

.status-chip.warn {
  background: rgba(192, 123, 79, 0.16);
  color: #8d4d27;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
}

.info-row .label {
  color: var(--c-text-3);
}

.info-row .value {
  color: var(--c-text);
}

.card-actions {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(40, 38, 34, 0.08);
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.action {
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
}

.action.ghost {
  background: #f5f1eb;
  color: var(--c-text-2);
  border: 1rpx solid rgba(40, 38, 34, 0.1);
}

.action.solid {
  background: var(--c-primary);
  color: #fff;
}

.list-loading {
  text-align: center;
  padding: 48rpx 24rpx;
  color: var(--c-text-3);
  font-size: 26rpx;
}

.action.ghost.disabled {
  opacity: 0.7;
  font-size: 22rpx;
}